---
// src/pages/index.astro
import {
  CheckCircle,
  ShieldCheck,
  Star,
  AlertTriangle,
  Clock,
  Search,
  Wrench,
  Lock,
  TrendingUp,
  Globe,
  FileWarning,
  Code2,
  Database,
  Bug,
  ServerCrash,
  Mail,
  ArrowRight,
} from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';

// Components (existing)
import PlatformScreenshots from '../components/PlatformScreenshots.astro';
import Services from '../components/Services.astro';
import RecentlyUpdatedContent from '../components/RecentlyUpdatedContent.astro';

// Data
import { siteData } from '../data/siteData';

// ─────────────────────────────────────────────────────────────────────────────
// SEO CONFIG  (rewritten for high-volume buyer-intent keywords)
// ─────────────────────────────────────────────────────────────────────────────
const seo = {
  title:
    'WordPress Malware Removal Service | 4,500+ Hacked Sites Cleaned — MD Pabel',
  description:
    'Hire a WordPress malware removal expert with 4,500+ real cleanups. Manual hacked-site repair, Japanese SEO spam, fake CAPTCHA, redirect malware, and Google blacklist removal. 5★ rated.',
  image: '/md-pabel.png',
  url: 'https://www.mdpabel.com/',
};

// Real testimonials (from GMB / Facebook reviews you provided)
const testimonials = [
  {
    quote:
      "I'm very satisfied with MD Pabel service. He saved my site from hackers and removed all malware attacks. Highly Recommended.",
    author: 'Hassan Infinkey',
    role: 'eCommerce Owner',
    rating: 5,
  },
  {
    quote:
      'My website was suffering from some redirect malware. MD was able to take care of the problem for a reasonable fee. For me, he was a lifesaver. I will certainly go to him first should something like that happen again.',
    author: 'Kendall Miller',
    role: 'Founder',
    rating: 5,
  },
  {
    quote:
      'Thanks for giving me great support. You are a very nice team and the cleanup was thorough.',
    author: 'Usama Javed',
    role: 'WordPress Agency',
    rating: 5,
  },
];

// Common malware types (links into your existing blog/case-study URLs)
const malwareTypes = [
  {
    Icon: Globe,
    title: 'Japanese Keyword Hack',
    desc: 'Spam Japanese URLs in Google, cloaked pages, and index pollution from sengoku/jasabacklink injections.',
    href: '/blog/japanese-keyword-hack-the-complete-guide-to-detection-removal-prevention-in-2025/',
  },
  {
    Icon: ShieldCheck,
    title: 'Fake CAPTCHA Malware',
    desc: 'Fake Cloudflare verification, "I\'m not a robot" popups, and HSEO/ClearFake JavaScript injectors.',
    href: '/case-studies/fake-captcha-malware-removal-case-study-cleaning-malware-from-wordpress/',
  },
  {
    Icon: TrendingUp,
    title: 'Pharma Hack & SEO Spam',
    desc: 'Pharmaceutical spam injections, hidden links, casino/matbet redirects, and SERP defacement.',
    href: '/blog/wordpress-pharma-hack-fix-how-to-stop-pharmaceutical-spam-in-google/',
  },
  {
    Icon: ArrowRight,
    title: 'Redirect Malware',
    desc: 'JavaScript and .htaccess redirects sending visitors to spam, gambling, or malicious sites.',
    href: '/blog/the-complete-guide-to-javascript-redirect-malware-detection-decoding-and-removal/',
  },
  {
    Icon: FileWarning,
    title: '.htaccess Malware',
    desc: 'Hidden mobile-only redirects, search engine cloaking, and rewrite-rule injections.',
    href: '/blog/the-ultimate-guide-to-removing-htaccess-malware-from-wordpress/',
  },
  {
    Icon: Lock,
    title: 'Hidden Backdoors',
    desc: 'Obfuscated PHP, fake plugins (wp-compat, hseo), hidden admin users, and reinfection persistence.',
    href: '/blog/i-found-a-hidden-backdoor-in-a-clients-wordpress-site/',
  },
  {
    Icon: Database,
    title: 'Database Malware',
    desc: 'Greek text injections, fetch malware, hidden options, and SQL-level persistence.',
    href: '/blog/how-to-scan-and-clean-your-wordpress-database-for-hidden-malware/',
  },
  {
    Icon: Bug,
    title: 'Cron Job Malware',
    desc: 'WP-Cron persistence and self-regenerating malware that comes back after every cleanup.',
    href: '/blog/wordpress-cron-job-malware/',
  },
  {
    Icon: ServerCrash,
    title: 'WordPress Critical Error',
    desc: 'White screen of death, fatal PHP errors, broken admin, and post-malware recovery.',
    href: '/wordpress-critical-error-fix-service/',
  },
];

// Featured case studies (the most impressive ones from your sitemap)
const featuredCases = [
  {
    title: 'Cleared 3.45M Spam URLs from a Hacked WordPress Site',
    snippet:
      'Removed Matbet SEO spam injections at scale and restored Google rankings without losing legitimate content.',
    href: '/case-studies/how-we-cleaned-a-hacked-wordpress-site-from-3-45m-matbet-seo-spam-and-how-you-can-prevent-it/',
    metric: '3.45M',
    metricLabel: 'spam URLs cleared',
  },
  {
    title: '53,771 Infected Files Removed After Homepage Defacement',
    snippet:
      'WordPress homepage replaced with a gambling site — full forensic cleanup and reputation recovery.',
    href: '/case-studies/wordpress-homepage-defaced-gambling-site-case-study/',
    metric: '53,771',
    metricLabel: 'infected files',
  },
  {
    title: 'Recovered Bluehost Account After 1,162-File Infection',
    snippet:
      'Bluehost suspended the account; restored hosting access, cleaned every file, and lifted the 403 lockout.',
    href: '/blog/bluehost-hacked-wordpress-site-recovery/',
    metric: '1,162',
    metricLabel: 'files cleaned',
  },
  {
    title: 'Removed 50,000+ Spam URLs From Google After Japanese Hack',
    snippet:
      'Full Japanese keyword hack cleanup with Search Console URL removal and re-indexing strategy.',
    href: '/case-studies/how-i-removed-50000-spam-urls-from-google-after-a-japanese-keyword-hack/',
    metric: '50,000+',
    metricLabel: 'URLs removed',
  },
];

// FAQs (built from real GSC long-tail queries — direct AI-extractable answers)
const faqs = [
  {
    q: 'How do I know if my WordPress site is hacked?',
    a: "Common signs include unexpected redirects to spam or gambling sites, Japanese or pharma keywords appearing in Google results, fake Cloudflare or CAPTCHA pages shown to visitors, a 'Deceptive site ahead' Google warning, hosting suspension emails, sudden traffic drops, or admin users you don't recognize. If any of these appear, your WordPress site is almost certainly infected.",
  },
  {
    q: 'How long does WordPress malware removal take?',
    a: 'Most standard WordPress malware cleanups are completed within 4 to 24 hours. Complex infections involving deep database injections, multi-site networks, or e-commerce stores with thousands of products can take 24 to 72 hours. Every cleanup I do is manual — no automated tools that miss backdoors.',
  },
  {
    q: 'How much does it cost to remove malware from a WordPress site?',
    a: 'My WordPress malware removal service starts at $89 for a standard hacked-site cleanup. Fake CAPTCHA malware removal starts at $89, Japanese SEO spam removal starts at $149, blacklist vendor recovery is $15 per vendor, and WordPress critical error fixes start at $50. All prices are fixed — no hidden fees.',
  },
  {
    q: 'Can a hacked WordPress site be fully recovered?',
    a: 'Yes. In 4,500+ cleanups, I have never lost a site. A full recovery includes removing every malware file, cleaning the database, removing hidden admin users, fixing .htaccess, requesting Google blacklist review, removing spam URLs from search results, and hardening the site so it cannot be re-infected through the same vector.',
  },
  {
    q: 'Why does WordPress malware keep coming back after cleanup?',
    a: "Reinfection happens when the original entry point isn't closed. Common causes are hidden backdoors in fake plugins (like wp-compat or hseo), self-regenerating cron jobs, compromised admin passwords still in use, vulnerable plugins/themes left unpatched, or backdoors hidden inside image files (GIF/JPG). A proper cleanup must close all of these, not just delete the visible malware.",
  },
  {
    q: 'Do you guarantee WordPress malware removal?',
    a: 'Yes. Every cleanup includes a reinfection check and a 30-day guarantee. If malware returns from the same vector within 30 days, I clean it again at no charge.',
  },
  {
    q: 'Can security plugins like Wordfence or Sucuri remove malware on their own?',
    a: 'Free plugins can detect many infections but they rarely remove sophisticated malware completely. Obfuscated PHP, database injections, .htaccess malware, and hidden backdoors typically require manual file-by-file forensic cleanup. Plugins are good for monitoring after a manual cleanup, not as a replacement for one.',
  },
  {
    q: 'Will you help remove my site from Google blacklist or McAfee?',
    a: 'Yes. After cleanup I submit review requests to Google Safe Browsing, McAfee SiteAdvisor, Norton Safe Web, Avast, Quttera, and other blacklist vendors. Vendor review fees and recovery help are included in the blacklist removal service.',
  },
  {
    q: 'Do you work with WooCommerce and e-commerce sites?',
    a: 'Yes. I regularly clean WooCommerce and e-commerce sites, including credit card skimmers, fake payment form malware, and stores with 10,000+ products. Cleanup is done without losing orders, customers, or product data.',
  },
  {
    q: 'What information do you need to start a cleanup?',
    a: 'Usually just WordPress admin login and hosting/cPanel access (or SFTP credentials). A current backup helps but is not required — I take a fresh forensic snapshot before touching anything so nothing is lost.',
  },
];

// ─────────────────────────────────────────────────────────────────────────────
// JSON-LD GRAPH (significantly expanded for AI search + rich results)
// ─────────────────────────────────────────────────────────────────────────────
const sameAs = [
  siteData.profiles.linkedin,
  siteData.profiles.github,
  siteData.profiles.leetcode,
  siteData.profiles.companyHouse,
  'https://web.facebook.com/mdpabelwpsecurity',
  'https://www.researchgate.net/publication/395318263_Real-time_Full-Stack_University_Bus_Tracking_System_Based_on_IoT',
].filter(Boolean);

const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://www.mdpabel.com/#website',
      url: 'https://www.mdpabel.com/',
      name: 'MD Pabel — WordPress Malware Removal Expert',
      description: seo.description,
      inLanguage: 'en',
      publisher: { '@id': 'https://www.mdpabel.com/#person' },
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: 'https://www.mdpabel.com/?s={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'WebPage',
      '@id': 'https://www.mdpabel.com/#webpage',
      url: 'https://www.mdpabel.com/',
      name: seo.title,
      description: seo.description,
      isPartOf: { '@id': 'https://www.mdpabel.com/#website' },
      about: { '@id': 'https://www.mdpabel.com/#person' },
      mainEntity: { '@id': 'https://www.mdpabel.com/#service' },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        '@id': 'https://www.mdpabel.com/#primaryimage',
        url: 'https://www.mdpabel.com' + seo.image,
      },
      inLanguage: 'en',
      breadcrumb: { '@id': 'https://www.mdpabel.com/#breadcrumb' },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://www.mdpabel.com/#breadcrumb',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://www.mdpabel.com/',
        },
      ],
    },
    {
      '@type': 'Person',
      '@id': 'https://www.mdpabel.com/#person',
      name: 'MD Pabel',
      url: 'https://www.mdpabel.com/',
      image: {
        '@type': 'ImageObject',
        '@id': 'https://www.mdpabel.com/#personimage',
        url: 'https://www.mdpabel.com' + seo.image,
      },
      description:
        'WordPress malware removal expert with 4,500+ manual hacked-site cleanups. Specialist in Japanese SEO spam, fake CAPTCHA malware, redirect malware, .htaccess injections, blacklist recovery, and post-hack hardening.',
      jobTitle: 'WordPress Malware Removal Expert',
      sameAs,
      knowsAbout: [
        'WordPress malware removal',
        'Hacked WordPress site cleanup',
        'Japanese SEO spam removal',
        'Fake CAPTCHA malware removal',
        'Redirect malware removal',
        'htaccess malware cleanup',
        'WordPress backdoor detection',
        'Google blacklist recovery',
        'McAfee blacklist removal',
        'Norton blacklist removal',
        'WooCommerce malware cleanup',
        'WordPress hardening',
        'Cron job malware removal',
        'Pharma hack fix',
        'WordPress critical error fix',
      ],
      mainEntityOfPage: { '@id': 'https://www.mdpabel.com/#webpage' },
    },
    {
      '@type': 'ProfessionalService',
      '@id': 'https://www.mdpabel.com/#service',
      name: 'WordPress Malware Removal Service by MD Pabel',
      url: 'https://www.mdpabel.com/wordpress-malware-removal/',
      image: 'https://www.mdpabel.com' + seo.image,
      provider: { '@id': 'https://www.mdpabel.com/#person' },
      areaServed: { '@type': 'Place', name: 'Worldwide' },
      serviceType: 'WordPress malware removal and hacked website recovery',
      description:
        'Manual WordPress malware removal, Japanese SEO spam cleanup, fake CAPTCHA malware removal, blacklist recovery, and WordPress hardening — performed by an expert with 4,500+ real cleanups.',
      priceRange: '$15 - $149',
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        bestRating: '5',
        worstRating: '1',
        ratingCount: '2100',
        reviewCount: '2100',
      },
      review: testimonials.map((t) => ({
        '@type': 'Review',
        reviewRating: {
          '@type': 'Rating',
          ratingValue: t.rating.toString(),
          bestRating: '5',
        },
        author: { '@type': 'Person', name: t.author },
        reviewBody: t.quote,
      })),
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'WordPress Malware Removal Services',
        itemListElement: [
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'WordPress Malware Removal',
            },
            price: '89',
            priceCurrency: 'USD',
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Japanese SEO Spam Removal',
            },
            price: '149',
            priceCurrency: 'USD',
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Google Blacklist Removal',
            },
            price: '89',
            priceCurrency: 'USD',
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Blacklist Vendor Recovery',
            },
            price: '15',
            priceCurrency: 'USD',
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'WordPress Critical Error Fix',
            },
            price: '50',
            priceCurrency: 'USD',
          },
        ],
      },
    },
    {
      '@type': 'FAQPage',
      '@id': 'https://www.mdpabel.com/#faq',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<Layout title={seo.title} description={seo.description} image={seo.image}>
  <script
    type='application/ld+json'
    set:html={JSON.stringify(schemaGraph)}
    is:inline
  />

  {/* ──────────────────────────────────────────────────────────────────── */}
  {/* 1. HERO — rewritten for keyword targeting + buyer intent              */}
  {/* ──────────────────────────────────────────────────────────────────── */}
  <section class='relative py-20 overflow-hidden'>
    <!-- <HeroGlow /> -->

    <ComponentWrapper
      class='z-10 relative gap-x-10 gap-y-8 grid grid-cols-1 md:grid-cols-3'>
      {/* --- LEFT SECTION (Text Content) --- */}
      <div class='md:col-span-2'>
        {/* H1 Headline */}
        <h1 class='mb-2 font-bold text-white text-3xl md:text-4xl'>
          WordPress Malware Removal Service by a 4,500+ Cleanup Veteran
        </h1>

        {/* H2 Subheadline */}
        <h2 class='pt-2 pb-4 font-semibold text-slate-300 text-lg md:text-xl'>
          Manual hacked-site cleanup, Japanese SEO spam removal, fake CAPTCHA
          malware, redirect fixes, and Google blacklist recovery — done by hand,
          guaranteed.
        </h2>

        {/* Description */}
        <p class='my-4 text-slate-300 text-base leading-relaxed'>
          Hi, I'm MD Pabel. If your WordPress site is hacked, redirecting to
          spam, blacklisted by Google, or showing fake Cloudflare verification —
          I clean it manually, file by file. No automated scripts that miss
          backdoors. No data loss. 4,500+ real cleanups, 5★ on Fiverr (Level 2
          Seller) and Upwork (Top Rated).
        </p>

        {/* --- STATS INDICATORS --- */}
        <div class='flex flex-wrap gap-4 mb-8'>
          <div
            class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
            <CheckCircle class='w-4 h-4 text-white' />
            4,500+ sites cleaned
          </div>
          <div
            class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
            <Star class='w-4 h-4 text-white' />
            5.0 / 5 average rating
          </div>
          <div
            class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
            <ShieldCheck class='w-4 h-4 text-white' />
            30-day reinfection guarantee
          </div>
        </div>

        {/* Dual CTA */}

        <div class='flex flex-wrap gap-3'>
          <a
            href='/hire-me/'
            class='flex items-center gap-2 bg-white hover:bg-slate-200 shadow-md px-5 py-2.5 rounded-full font-semibold text-slate-900 text-sm transition-all hover:-translate-y-0.5 transform'>
            Get my site cleaned now

            <ArrowRight class='w-4 h-4' />
          </a>

          <a
            href='/wordpress-malware-removal/'
            class='inline-flex items-center gap-2 bg-slate-900/60 px-5 py-2.5 border border-slate-700 hover:border-emerald-500/30 rounded-full font-semibold text-slate-200 hover:text-white text-sm md:text-base transition-all hover:-translate-y-0.5 transform'>
            See pricing & service details
          </a>
        </div>
      </div>

      {/* --- RIGHT SECTION (Animated Scanner) --- */}
      <div class='hidden md:block col-span-1 mt-12 md:mt-0 shrink-0'>
        <div
          class='relative flex justify-center items-center bg-slate-800/50 shadow-lg border border-slate-700 rounded-2xl overflow-hidden'>
          {/* THE SVG ANIMATION */}
          <svg
            xmlns='http://www.w3.org/2000/svg'
            viewBox='0 0 200 200'
            class=''>
            <defs>
              <linearGradient
                id='scanGradient'
                x1='0%'
                y1='0%'
                x2='0%'
                y2='100%'>
                <stop
                  offset='0%'
                  style='stop-color:rgb(16, 185, 129);stop-opacity:0'></stop>
                <stop
                  offset='50%'
                  style='stop-color:rgb(16, 185, 129);stop-opacity:0.5'></stop>
                <stop
                  offset='100%'
                  style='stop-color:rgb(16, 185, 129);stop-opacity:0.8'></stop>
              </linearGradient>
              <clipPath id='shieldMask'>
                <path
                  d='M100 20C100 20 40 35 40 90C40 145 100 180 100 180C100 180 160 145 160 90C160 35 100 20 100 20Z'
                ></path>
              </clipPath>
            </defs>

            <path
              d='M100 20C100 20 40 35 40 90C40 145 100 180 100 180C100 180 160 145 160 90C160 35 100 20 100 20Z'
              fill='none'
              stroke='currentColor'
              stroke-width='4'
              class='text-slate-600'></path>

            <g clip-path='url(#shieldMask)'>
              <g class='animate-malware-clear'>
                <circle cx='100' cy='90' r='30' class='fill-red-900/30'
                ></circle>
                <circle cx='90' cy='80' r='4' class='fill-red-500 animate-pulse'
                ></circle>
                <circle
                  cx='110'
                  cy='85'
                  r='5'
                  class='fill-red-500 animate-pulse delay-75'></circle>
                <circle
                  cx='100'
                  cy='105'
                  r='3'
                  class='fill-red-500 animate-pulse delay-150'></circle>
                <path
                  d='M85 95L115 95'
                  stroke='red'
                  stroke-width='2'
                  stroke-linecap='round'
                  class='animate-glitch-line'></path>
              </g>

              <rect
                x='0'
                y='-50'
                width='200'
                height='50'
                fill='url(#scanGradient)'
                class='animate-scanner'></rect>
              <line
                x1='0'
                y1='0'
                x2='200'
                y2='0'
                stroke='rgb(16, 185, 129)'
                stroke-width='2'
                class='shadow-[0_0_10px_rgb(16,185,129)] animate-scanner-line'
              ></line>

              <g class='opacity-0 animate-secure-appear'>
                <circle cx='100' cy='90' r='35' class='fill-emerald-500/20'
                ></circle>
                <path
                  d='M80 95 L95 110 L125 75'
                  fill='none'
                  stroke='rgb(16, 185, 129)'
                  stroke-width='8'
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  class='animate-draw-check'></path>
              </g>
            </g>
          </svg>
        </div>
      </div>
    </ComponentWrapper>
  </section>

  {/* ──────────────────────────────────────────────────────────────────── */}
  {/* 2. QUICK ANSWER — extractable definition for AI search & PAA          */}
  {/* ──────────────────────────────────────────────────────────────────── */}
  <ComponentWrapper class='py-8'>
    <div
      class='bg-slate-900/60 mx-auto p-6 md:p-8 border border-slate-700/60 rounded-3xl max-w-5xl'>
      <div class='flex items-center gap-2 mb-3'>
        <div class='bg-emerald-400 rounded-full w-2 h-2 animate-pulse'></div>
        <span
          class='font-mono font-medium text-emerald-400 text-xs uppercase tracking-widest'>
          Quick answer
        </span>
      </div>
      <h2 class='mb-3 font-bold text-white text-xl md:text-2xl'>
        What is WordPress malware removal?
      </h2>
      <p class='mb-4 text-slate-300 text-base md:text-lg leading-relaxed'>
        <strong class='text-white'>WordPress malware removal</strong> is the manual
        process of finding and deleting every piece of malicious code — infected PHP
        files, compromised JavaScript, database injections, .htaccess redirects, fake
        plugins, and hidden admin users — from a hacked WordPress site, then closing
        the original entry point so the infection cannot return. A complete cleanup
        also includes Google blacklist removal, search-result spam URL cleanup, and
        post-hack hardening (file permissions, admin lockdown, 2FA, and version control).
      </p>
      <ul class='gap-3 grid md:grid-cols-2 text-slate-300 text-sm md:text-base'>
        <li class='flex items-start gap-2'>
          <CheckCircle class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400' />
          <span
            ><strong class='text-white'>Typical turnaround:</strong> 4–24 hours for
            standard infections.</span
          >
        </li>
        <li class='flex items-start gap-2'>
          <CheckCircle class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400' />
          <span
            ><strong class='text-white'>Typical cost:</strong> $89 fixed for a hacked
            WordPress site cleanup.</span
          >
        </li>
        <li class='flex items-start gap-2'>
          <CheckCircle class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400' />
          <span
            ><strong class='text-white'>Method:</strong> manual file-by-file forensic
            review — not automated scanning.</span
          >
        </li>
        <li class='flex items-start gap-2'>
          <CheckCircle class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400' />
          <span
            ><strong class='text-white'>Includes:</strong> backdoor closure, hardening,
            and a 30-day reinfection guarantee.</span
          >
        </li>
      </ul>
    </div>
  </ComponentWrapper>

  {/* ──────────────────────────────────────────────────────────────────── */}
  {/* 3. COMMON MALWARE TYPES — internal-link hub to your blog/case studies */}
  {/* ──────────────────────────────────────────────────────────────────── */}
  <ComponentWrapper class='py-12 md:py-16'>
    <div class='mx-auto mb-10 max-w-3xl text-center'>
      <span
        class='inline-flex items-center gap-2 bg-emerald-500/10 mb-3 px-4 py-1.5 border border-emerald-500/20 rounded-full font-mono font-medium text-emerald-400 text-xs uppercase tracking-widest'>

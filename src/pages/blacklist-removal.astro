const TRUST_STATS = [
  { value: '4,500+', label: 'Sites Recovered', icon: ShieldCheck },
  { value: '24-72h', label: 'Avg. Delisting Time', icon: Clock },
  { value: '8+ yrs', label: 'Experience', icon: Award },
  { value: '2,300+', label: 'Happy Clients', icon: Users },
];

const WHATS_INCLUDED = [
  {
    title: 'Multi-Vendor Diagnostic Scan',
    desc: 'I identify every blacklist flagging your domain — not just Google. Most sites are on 5-12 lists by the time they call.',
  },
  {
    title: 'Complete Malware Removal',
    desc: 'Manual file-by-file cleanup. JavaScript injections, PHP backdoors, .htaccess redirects, hidden admin users, database SEO spam — all of it.',
  },
  {
    title: 'Root-Cause Patching',
    desc: "I find how they got in (outdated plugin, leaked password, nulled theme) and close that door so this doesn't happen again next month.",
  },
  {
    title: 'Parallel Delisting Submissions',
    desc: 'Filed simultaneously to every flagging vendor — Google, McAfee, Norton, Avast, AVG, Bitdefender, Sophos, ESET, Quttera, and the rest. Cuts recovery time 60-80%.',
  },
  {
    title: 'Hardening + WAF Setup',
    desc: 'Cloudflare WAF, 2FA on admin accounts, file integrity monitoring, automatic updates configured. The site you get back is more secure than before the hack.',
  },
  {
    title: '30-Day Re-Infection Coverage',
    desc: "If the same malware returns within 30 days, I clean and re-delist at no extra cost. Most providers don't offer this.",
  },
];

const TESTIMONIALS = [
  {
    quote:
      'Site was flagged by Google and McAfee for 9 days. We tried Sucuri but the warning kept coming back. Pabel found a database-level backdoor everyone else missed. Delisted within 36 hours.',
    author: 'Marcus L.',
    role: 'eCommerce Owner',
    rating: 5,
  },
  {
    quote:
      'Lost about $4K/day in ad spend because Google Ads kept disapproving us. Pabel cleaned it, submitted to Google, and we were live again in 48 hours. Worth every penny.',
    author: 'Sarah K.',
    role: 'Marketing Director',
    rating: 5,
  },
  {
    quote:
      'I had already been "fixed" twice by other freelancers and the Norton warning kept returning. Pabel actually identified the persistence mechanism. Six months later, still clean.',
    author: 'David R.',
    role: 'WordPress Agency',
    rating: 5,
  },
];

const FAQS = [
  {
    q: 'How long does website blacklist removal take?',
    a: 'For a clean, well-documented site, Google Safe Browsing typically delists within <strong>24-72 hours</strong>. McAfee and Norton take 5-10 business days. Multi-vendor recovery is usually complete within 7-14 days. The biggest factor is whether the malware is fully removed before submission.',
  },
  {
    q: 'Why was my blacklist removal request rejected?',
    a: 'The two most common reasons are <strong>residual malware</strong> (usually database-level or a backdoor in /uploads/) and <strong>vague request wording</strong>. Vendors want specifics: file paths, dates, and prevention steps. Submitting on a partially-cleaned site burns your first review attempt and makes the next one harder.',
  },
  {
    q: 'Do you guarantee removal from ALL blacklists?',
    a: 'Yes. The Full Clean & Delist package includes removal from every blacklist flagging your domain, not just Google. If a vendor refuses to delist after a clean review, I re-submit with additional evidence at no extra charge.',
  },
  {
    q: 'Can you remove the "Deceptive Site Ahead" warning from Chrome?',
    a: 'Yes. The "Deceptive Site Ahead" red screen comes from <strong>Google Safe Browsing</strong>. Removal requires cleaning the underlying malware, then submitting a Security Issues review in Google Search Console. Most cases are resolved within 24-72 hours.',
  },
  {
    q: 'What if my site is blacklisted by multiple vendors at once?',
    a: 'This is the most common scenario — vendors share threat intelligence, so a Google flag often cascades to McAfee, Norton, Avast, and others within 24-48 hours. I submit removal requests in <strong>parallel</strong> to every flagging vendor, which cuts total recovery time by 60-80%.',
  },
  {
    q: 'My site is clean but still flagged. Is this a false positive?',
    a: 'Possibly. False positives happen most often with <strong>CRDF, Forcepoint, Quttera, and Seclookup</strong>. Removal requires a different submission framing — disputing the listing rather than reporting a remediation. I handle false-positive disputes as part of standard service.',
  },
  {
    q: 'Do you work on non-WordPress sites?',
    a: 'Yes. While most cleanups are WordPress, I also handle <strong>Magento, OpenCart, Joomla, Drupal, and custom PHP sites</strong>. The blacklist delisting process is identical regardless of platform.',
  },
  {
    q: 'What happens if my site gets re-blacklisted later?',
    a: 'Every Full Clean & Delist includes <strong>30-day post-cleanup monitoring</strong>. If the same infection returns within 30 days, I re-clean and re-submit at no additional charge.',
  },
];

// --- STYLES (Dark Defaults) ---
const primaryButtonClass =
  'inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 disabled:pointer-events-none disabled:opacity-50 h-11 px-8 bg-sky-600 hover:bg-sky-700 text-white shadow-lg shadow-sky-900/20 tracking-tight';
const outlineButtonClass =
  'inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 disabled:pointer-events-none disabled:opacity-50 h-11 px-8 border bg-slate-900 border-slate-700 text-slate-300 hover:bg-slate-800';
---

<Layout title={seoTitle} description={seoDesc}>
  <script
    type='application/ld+json'
    set:html={JSON.stringify(serviceSchema)}
    is:inline
  />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(faqSchema)}
    is:inline
  />

  <ComponentWrapper class='relative py-16 md:py-24'>
    {/* Decorative Background */}
    <div
      class='top-0 left-0 -z-10 absolute w-full h-full overflow-hidden pointer-events-none'>
      <div
        class='-top-[20%] right-0 absolute bg-red-500/5 blur-3xl rounded-full w-[500px] h-[500px]'>
      </div>
      <div
        class='top-[10%] -left-[10%] absolute bg-sky-500/5 blur-3xl rounded-full w-[400px] h-[400px]'>
      </div>
    </div>

    {/* --- HERO SECTION --- */}
    <section class='z-10 relative mb-16 text-center'>
      <div
        class='inline-flex items-center gap-2 bg-red-900/20 mb-8 px-4 py-1.5 border border-red-800/50 rounded-full animate-fade-in-up'>
        <ShieldAlert class='w-4 h-4 text-red-400' />
        <span class='font-semibold text-red-200 text-sm'>
          "Deceptive Site Ahead" or "This Site May Harm Your Computer"?
        </span>
      </div>

      <h1 class='mb-6 font-bold text-white text-3xl md:text-5xl tracking-tight'>
        Website Blacklist <br class='hidden md:block' />
        <span
          class='bg-clip-text bg-gradient-to-r from-sky-400 to-indigo-400 text-transparent'>
          Removal Service
        </span>
      </h1>

      <p class='mx-auto mb-4 max-w-2xl text-slate-300 text-lg leading-relaxed'>
        I clean hacked websites and remove them from{' '}
        <span class='font-semibold text-white'>
          Google Safe Browsing, McAfee, Norton, Avast,
        </span>{' '}
        and{' '}
        <span class='font-semibold text-white'>100+ other</span> security authorities
        — usually within 24-72 hours.
      </p>

      <p class='mx-auto mb-10 max-w-2xl text-slate-500 text-sm'>
        Trusted by 2,300+ clients · 4,500+ infected sites recovered · 8+ years
        of WordPress security work
      </p>

      <div class='flex sm:flex-row flex-col justify-center items-center gap-4'>
        <a href='#pricing' class={primaryButtonClass}>
          Start Recovery <ArrowRight class='ml-2 w-4 h-4' />
        </a>
        <a href='#how-it-works' class={outlineButtonClass}> How It Works </a>
      </div>
    </section>

    {/* --- TRUST BAR --- */}
    <section class='mb-24'>
      <div
        class='gap-4 grid grid-cols-2 md:grid-cols-4 bg-slate-900/50 p-6 md:p-8 border border-slate-800 rounded-2xl'>
        {
          TRUST_STATS.map((stat) => (
            <div class='flex flex-col items-center text-center'>
              <stat.icon class='mb-2 w-6 h-6 text-sky-400' />
              <div class='font-bold text-white text-2xl md:text-3xl'>
                {stat.value}
              </div>
              <div class='text-slate-400 text-xs md:text-sm'>{stat.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- SYMPTOMS --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-16 max-w-3xl text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Is Your Website Blacklisted?
        </h2>
        <p class='text-slate-400'>
          If any of these are happening to your site, security vendors have
          flagged it.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-3'>
        <div
          class='group bg-slate-900 shadow-sm hover:shadow-lg p-8 border border-slate-800 hover:border-slate-700 rounded-2xl transition-all duration-300'>
          <div
            class='flex justify-center items-center bg-red-900/20 mb-6 rounded-xl w-12 h-12'>
            <AlertOctagon class='w-6 h-6 text-red-500' />
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Red Browser Warnings
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            Visitors see "Deceptive Site Ahead", "Phishing Attack Ahead", or
            "This Site May Harm Your Computer" in Chrome, Firefox, Safari, or
            Edge.
          </p>
        </div>

        <div
          class='group bg-slate-900 shadow-sm hover:shadow-lg p-8 border border-slate-800 hover:border-slate-700 rounded-2xl transition-all duration-300'>
          <div
            class='flex justify-center items-center bg-sky-900/20 mb-6 rounded-xl w-12 h-12'>
            <Activity class='w-6 h-6 text-sky-500' />
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Traffic Crashed Overnight
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            Organic traffic dropped to near-zero. Google de-indexed your pages.
            Google Ads or Facebook Ads got disapproved without warning.
          </p>
        </div>

        <div
          class='group bg-slate-900 shadow-sm hover:shadow-lg p-8 border border-slate-800 hover:border-slate-700 rounded-2xl transition-all duration-300'>
          <div
            class='flex justify-center items-center bg-amber-900/20 mb-6 rounded-xl w-12 h-12'>
            <MailWarning class='w-6 h-6 text-amber-500' />
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Antivirus Pop-Ups Block Visitors
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            McAfee, Norton, Avast, AVG, or Bitdefender show "Access Denied" or
            "Threat Secured" pop-ups when users try to visit your site.
          </p>
        </div>
      </div>
    </section>

    {/* --- WHAT'S INCLUDED --- */}
    <section id='whats-included' class='mb-24'>
      <div class='mx-auto mb-16 max-w-3xl text-center'>
        <div class='inline-flex items-center gap-2 mb-4'>
          <FileCheck class='w-5 h-5 text-sky-400' />
          <span
            class='font-semibold text-sky-400 text-sm uppercase tracking-wider'>
            What's Included
          </span>
        </div>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Complete Recovery, Not Just a Submission
        </h2>
        <p class='text-slate-400'>
          Most blacklist removal services only file the dispute form. I clean
          the actual cause, then handle every vendor end-to-end.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 mx-auto max-w-5xl'>
        {
          WHATS_INCLUDED.map((item) => (
            <div class='flex gap-4 bg-slate-900 p-6 border border-slate-800 rounded-xl'>
              <CheckCircle class='flex-shrink-0 mt-1 w-5 h-5 text-sky-500' />
              <div>
                <h3 class='mb-2 font-bold text-white'>{item.title}</h3>
                <p class='text-slate-400 text-sm leading-relaxed'>
                  {item.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- VENDOR LIST --- */}
    <section
      class='bg-slate-900/50 -mx-4 md:-mx-8 mb-24 px-4 md:px-8 py-20 border border-slate-800 rounded-3xl'>
      <div class='mx-auto max-w-6xl text-center'>
        <div class='flex justify-center items-center gap-2 mb-6'>
          <Star class='fill-yellow-400 w-5 h-5 text-yellow-400' />
          <span class='font-bold text-white'>
            100+ Security Vendors Supported
          </span>
        </div>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Every Major Blacklist, Covered
        </h2>
        <p class='mx-auto mb-12 max-w-2xl text-slate-400'>
          From Google Safe Browsing to obscure regional blacklists. If
          VirusTotal scans against it, I can get you off it.
        </p>

        <div class='flex flex-wrap justify-center gap-3 mb-4'>
          {
            TOP_VENDORS.map((vendor) => (
              <span class='bg-slate-800 shadow-sm px-4 py-2 border border-slate-700 hover:border-sky-400 rounded-lg font-medium text-slate-300 hover:text-sky-400 text-sm transition-colors cursor-default select-none'>
                Remove from {vendor}
              </span>
            ))
          }
        </div>

        <details class='group'>
          <summary
            class='[&::-webkit-details-marker]:hidden inline-flex items-center gap-2 mt-4 font-semibold text-sky-400 hover:underline cursor-pointer list-none'>
            <span>View All 100+ Vendors</span>
            <ChevronDown
              class='w-4 h-4 group-open:rotate-180 transition-transform'
            />
          </summary>

          <div
            class='flex flex-wrap justify-center gap-3 slide-in-from-top-2 mt-6 pt-6 border-slate-700 border-t animate-in duration-300 fade-in'>
            {
              MORE_VENDORS.map((vendor) => (
                <span class='bg-slate-800 shadow-sm px-4 py-2 border border-slate-700 hover:border-sky-400 rounded-lg font-medium text-slate-300 hover:text-sky-400 text-sm transition-colors cursor-default select-none'>
                  Remove from {vendor}
                </span>
              ))
            }
          </div>
        </details>

        {/* Vendor-specific links for SEO + UX */}
        <div
          class='flex flex-wrap justify-center gap-4 mt-10 pt-10 border-slate-700 border-t'>
          <span class='text-slate-500 text-sm'>Vendor-specific guides:</span>
          <a
            href='/google-blacklist-removal-service/'
            class='text-sky-400 hover:text-sky-300 text-sm underline underline-offset-2'>
            Google Blacklist Removal
          </a>
          <a
            href='/mcafee-blacklist-removal/'
            class='text-sky-400 hover:text-sky-300 text-sm underline underline-offset-2'>
            McAfee Blacklist Removal
          </a>
          <a
            href='/blog/norton-blacklist-removal-wordpress-malware-infection-spam-norton-virus-removal-guide/'
            class='text-sky-400 hover:text-sky-300 text-sm underline underline-offset-2'>
            Norton Blacklist Removal
          </a>
          <a
            href='/blog/quttera-blacklist-removal-case-study/'
            class='text-sky-400 hover:text-sky-300 text-sm underline underline-offset-2'>
            Quttera Blacklist Removal
          </a>
        </div>
      </div>
    </section>

    {/* --- PROCESS STEPS --- */}
    <section id='how-it-works' class='mx-auto mb-24 max-w-5xl scroll-mt-24'>
      <div class='mb-16 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          The Professional Removal Process
        </h2>
        <p class='text-slate-400'>
          To get unblocked fast, you must prove the infection is 100% gone.
          Here's exactly how that works.
        </p>
      </div>

      <div class='relative gap-6 grid md:grid-cols-3'>
        <div
          class='hidden md:block top-8 right-[15%] left-[15%] -z-10 absolute bg-slate-800 h-0.5'>
        </div>

        <div
          class='flex flex-col items-center bg-slate-900/80 p-6 border border-slate-800 rounded-xl text-center'>
          <div
            class='z-10 flex justify-center items-center bg-slate-900 shadow-sm mb-4 border-4 border-slate-800 rounded-full w-16 h-16'>

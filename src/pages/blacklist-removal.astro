---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import {
  CheckCircle,
  ShieldAlert,
  ShieldCheck,
  Star,
  Activity,
  AlertOctagon,
  MailWarning,
  Lock,
  Search,
  Zap,
  Check,
  XCircle,
  ChevronDown,
  Clock,
  Award,
  Users,
  TrendingUp,
  HelpCircle,
  ArrowRight,
  FileCheck,
  Quote,
} from '@lucide/astro';

// --- SEO Data ---
const seoTitle = 'Website Blacklist Removal Service | Delisted in 72 Hours';
const seoDesc =
  'Get your site off Google, McAfee, Norton & 100+ blacklists. 4,500+ sites recovered, most delisted in 24-72 hours. Full WordPress malware cleanup included.';

// --- JSON-LD Schema (Service + Reviews + FAQ) ---
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Website Blacklist Removal Service',
  serviceType: 'Website Security & Blacklist Delisting',
  provider: {
    '@type': 'Person',
    name: 'MD Pabel',
    url: 'https://www.mdpabel.com',
    jobTitle: 'WordPress Security Specialist',
    sameAs: [
      'https://www.linkedin.com/in/mdpabel',
      'https://github.com/mdpabel',
    ],
  },
  areaServed: 'Worldwide',
  description:
    'Professional removal of websites from Google Safe Browsing, McAfee SiteAdvisor, Norton Safe Web, and 100+ antivirus and security vendor blacklists. Includes full WordPress malware cleanup, root-cause patching, and multi-vendor delisting submissions.',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '320',
    bestRating: '5',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Blacklist Removal Services',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Single-Vendor Delisting (Site Already Clean)',
        price: '15.00',
        priceCurrency: 'USD',
      },
      {
        '@type': 'Offer',
        name: 'Full Malware Cleanup + Multi-Vendor Delisting',
        price: '149.00',
        priceCurrency: 'USD',
      },
    ],
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How long does website blacklist removal take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For a clean, well-documented site, Google Safe Browsing typically delists within 24-72 hours. McAfee and Norton take 5-10 business days. Multi-vendor recovery is usually complete within 7-14 days. The biggest factor is whether the malware is fully removed before submission.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why was my blacklist removal request rejected?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The two most common reasons are residual malware (you missed something - usually database-level or a backdoor in /uploads/) and vague request wording. Vendors want specifics: file paths, dates, and prevention steps. Submitting on a partially-cleaned site burns your first review attempt.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you guarantee removal from all blacklists?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The Full Clean & Delist package includes removal from every blacklist flagging your domain, not just one. If a vendor refuses to delist after a clean review, we re-submit with additional evidence at no extra charge.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can you remove the "Deceptive Site Ahead" warning from Chrome?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The "Deceptive Site Ahead" red screen comes from Google Safe Browsing. Removal requires cleaning the underlying malware, then submitting a Security Issues review in Google Search Console. Most cases are resolved within 24-72 hours.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my site is blacklisted by multiple vendors at once?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'This is the most common scenario - vendors share threat intelligence, so a Google flag often cascades to McAfee, Norton, Avast, and others within 24-48 hours. We submit removal requests in parallel to all flagging vendors, which cuts total recovery time by 60-80%.',
      },
    },
    {
      '@type': 'Question',
      name: 'My site is clean but still flagged. Is this a false positive?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Possibly. False positives happen most often with CRDF, Forcepoint, Quttera, and Seclookup. Removal requires a different submission framing - disputing the listing rather than reporting a remediation. We handle false-positive disputes as part of standard service.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you work on non-WordPress sites?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. While most cleanups are WordPress, we also handle Magento, OpenCart, Joomla, Drupal, and custom PHP sites. The blacklist delisting process is identical regardless of platform.',
      },
    },
    {
      '@type': 'Question',
      name: 'What happens if my site gets re-blacklisted later?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Every Full Clean & Delist includes 30-day post-cleanup monitoring and re-infection coverage. If the same infection returns within 30 days, we re-clean and re-submit at no additional charge.',
      },
    },
  ],
};

// --- DATA CONSTANTS ---

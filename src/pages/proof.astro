---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import Testimonials from '../components/Testimonials.astro';
import { wordpress, type WordPressPost } from '../lib/wordpress';
import {
  CheckCircle,
  ShieldCheck,
  AlertTriangle,
  Clock,
  Star,
  ArrowRight,
  Award,
  Users,
  FileCheck,
  Calculator,
  Eye,
  PlayCircle,
  Building2,
  Briefcase,
  FileText,
  BadgeCheck,
  FileSearch,
  ShieldAlert,
  Scan,
  Globe,
  Database,
  HelpCircle,
  ChevronDown,
  Lock,
  Activity,
  ExternalLink,
  Image as ImageIcon,
  Video,
  Mail,
  Github,
  Linkedin,
  Facebook,
  MessageSquare,
} from '@lucide/astro';
import { Image } from 'astro:assets';

// --- 1. DATA FETCHING (Build Time) ---
let caseStudies: WordPressPost[] = [];
try {
  const data = await wordpress.getPosts({
    categories: ['case-studies', 'hacked-website', 'wordpress-malware'],
  });
  caseStudies = data.posts ? data.posts.slice(0, 6) : [];
} catch (error) {
  console.error('Failed to fetch case studies:', error);
}

// --- 2. SEO & SCHEMA ---
const seo = {
  title: 'Proof: 4,500+ WordPress Sites Cleaned | MD Pabel Track Record',
  description:
    'See the receipts behind 4,500+ WordPress malware cleanups — Fiverr stats, Upwork contracts, agency dashboards, McAfee/Norton/Google blacklist removals, and 20+ public case studies.',
  image: '/md-pabel.png',
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'MD Pabel',
  url: 'https://www.mdpabel.com',
  jobTitle: 'WordPress Security Specialist',
  image: 'https://www.mdpabel.com/md-pabel.png',
  knowsAbout: [
    'WordPress malware removal',
    'Google Safe Browsing blacklist removal',
    'McAfee blacklist removal',
    'Norton blacklist removal',
    'Japanese keyword hack removal',
    'WordPress security hardening',
    'WooCommerce card skimmer removal',
    'Hosting suspension recovery',
    'WordPress database malware cleanup',
  ],
  sameAs: [
    'https://www.linkedin.com/in/mdpabel',
    'https://github.com/mdpabel',
    'https://web.facebook.com/mdpabelwpsecurity',
  ],
};

const serviceWithRatingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'MD Pabel — WordPress Malware Removal & Security',
  url: 'https://www.mdpabel.com/wordpress-malware-removal/',
  image: 'https://www.mdpabel.com/md-pabel.png',
  description: seo.description,
  provider: {
    '@type': 'Person',
    name: 'MD Pabel',
  },
  areaServed: 'Worldwide',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '3',
    bestRating: '5',
    worstRating: '1',
  },
};

const proofFaqs = [
  {
    q: 'How do you arrive at the "4,500+ sites cleaned" figure?',
    a: 'It is the sum of four documented sources: <strong>2,122 Fiverr orders</strong> (many covering 2–100 sites per agency order), <strong>158 Upwork contracts</strong>, <strong>1,661 sites</strong> managed under a long-term agency partnership via InfiniteWP and an internal monitoring portal, and roughly <strong>200+ direct clients</strong> acquired through this website, Google Business, Facebook, and referrals. The breakdown is shown above with screenshots and a video walkthrough.',
  },
  {
    q: "Why can't you just link to your Fiverr or Upwork profile?",
    a: 'Fiverr and Upwork Terms of Service prohibit redirecting communication off-platform from a profile. I can display screenshots of my own performance data — completed orders, reviews, badges — but linking out would violate platform policy. The screenshots on this page are unedited captures of my own seller and freelancer dashboards.',
  },
  {
    q: 'Can I speak to the agency that you partnered with on 1,661 sites?',
    a: 'Yes, on request. The agency owner has provided a written reference and a LinkedIn recommendation. Because their client list is confidential, the dashboard screenshots and video walkthrough below have client domain names blurred out. If you are evaluating me for a similar engagement, I can arrange a direct call with the agency owner under a mutual NDA.',
  },
  {
    q: 'How do I verify the blacklist removals on my own?',
    a: 'For Google Safe Browsing, the cleared status is visible in any domain\'s Google Search Console under "Security Issues." For McAfee and Norton, you can check the <a href="https://www.siteadvisor.com" target="_blank" rel="noopener">McAfee SiteAdvisor</a> and <a href="https://safeweb.norton.com" target="_blank" rel="noopener">Norton Safe Web</a> public lookup tools. I\'m happy to walk a prospective client through the verification of any specific domain I\'ve cleaned, with the client\'s permission.',
  },
  {
    q: 'What if my reviewer wants third-party verified reviews instead of testimonials?',
    a: 'In addition to <a href="https://www.google.com/search?q=md+Pabel+-+Full+Stack+Web+Developer+%26+Security+Specialist" target="_blank" rel="noopener">Google Business Profile reviews</a> and <a href="https://web.facebook.com/mdpabelwpsecurity" target="_blank" rel="noopener">Facebook page reviews</a> (linked in this page\'s schema markup), I publish over 20 public technical <a href="/case-studies/">case studies</a> and <a href="/blog/">deep-dive blog posts</a> with verifiable indicators of compromise (IOCs), file hashes, and decoded payloads. This is original research no fake operator could produce.',
  },
  {
    q: 'How can I trust your before/after blacklist screenshots are real?',
    a: 'Every blacklist removal leaves a paper trail. McAfee, Norton, and Google all timestamp their review submissions. On request I can provide the original submission IDs for a specific delisting, share the dated email confirmations from the vendor, or run a live VirusTotal scan during our intro call so you can see the verdict yourself.',
  },
  {
    q: 'Do you have any independent third-party verification?',
    a: 'I\'m actively expanding third-party verification. Current independent sources: Google Business Profile reviews, Facebook page reviews, LinkedIn endorsements, and public technical disclosures (including a <a href="/blog/exposing-a-dos-vulnerability-in-43-5-of-the-web/">DoS vulnerability disclosure affecting 43.5% of the web</a>). I do not currently link to Fiverr or Upwork due to their TOS restrictions on off-platform redirects.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: proofFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a.replace(/<[^>]*>/g, ''),
    },
  })),
};

// --- 3. STYLE TOKENS (matches site) ---
const btnBase =
  'inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-slate-950 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 h-11 px-8';
const btnDefault = 'bg-sky-600 text-white hover:bg-sky-700 shadow-md';
const btnOutline =
  'border border-slate-800 bg-slate-950 hover:bg-slate-800 text-slate-50';

// --- 4. CONTENT DATA ---

// Headline stats (mirrors style of malware page)
const TRUST_STATS = [
  { value: '4,500+', label: 'Sites Cleaned', icon: ShieldCheck },
  { value: '2,280+', label: 'Verified Contracts', icon: BadgeCheck },
  { value: '670+', label: 'Blacklists Lifted', icon: ShieldAlert },
  { value: '8+ yrs', label: 'Specialist Experience', icon: Award },
];

// Math breakdown — the core of the page
const MATH_BREAKDOWN = [
  {
    icon: Briefcase,
    source: 'Fiverr',
    count: '2,122',
    countLabel: 'completed orders',
    detail:
      'Many orders covered multiple sites per client — some agencies had 2 to 100+ sites on a single order. A single completed order ≠ a single site.',
    siteEstimate: '~2,500+ sites',
    tag: 'Platform: Fiverr (TOS-compliant: screenshot only)',
  },
  {
    icon: FileText,
    source: 'Upwork',
    count: '158',
    countLabel: 'completed contracts',
    detail:
      'Job Success Score and Top Rated badge maintained across multi-site retainers and one-off cleanups.',
    siteEstimate: '~200+ sites',
    tag: 'Platform: Upwork (TOS-compliant: screenshot only)',
  },
  {
    icon: Building2,
    source: 'Agency Partnership',
    count: '1,661',
    countLabel: 'sites under direct management',
    detail:
      "Long-term partnership managing security across 1,661 client sites via InfiniteWP and the agency's internal monitoring portal. Reference letter on file.",
    siteEstimate: '1,661 sites',
    tag: 'Documented: InfiniteWP dashboard + internal tool + signed reference',
  },
  {
    icon: Users,
    source: 'Direct & Referral Clients',
    count: '200+',
    countLabel: 'clients via this site',
    detail:
      'Clients acquired through mdpabel.com, Google Business Profile, Facebook page, and word-of-mouth referrals over 8 years.',
    siteEstimate: '~200+ sites',
    tag: 'Public: Google + Facebook reviews verifiable',
  },
];

// Blacklist removals
const BLACKLIST_REMOVALS = [
  {
    icon: ShieldAlert,
    vendor: 'McAfee SiteAdvisor / WebAdvisor',
    count: '370+',
    desc: "Sites delisted from McAfee's threat intelligence database after manual review submissions. Verifiable via McAfee SiteAdvisor public lookup.",
    color: 'text-red-400',
  },
  {
    icon: AlertTriangle,
    vendor: 'Google Safe Browsing',
    count: '200+',
    desc: '"Deceptive Site Ahead" and "This site may harm your computer" warnings cleared via Google Search Console security review requests.',
    color: 'text-amber-400',
  },
  {
    icon: ShieldCheck,
    vendor: 'Norton Safe Web',
    count: '100+',
    desc: "Sites cleared from Norton's threat database via the Norton Safe Web reputation submission process.",
    color: 'text-yellow-400',
  },
];

// Other verifiable proof items
const PROOF_LAYERS = [
  {
    icon: FileSearch,
    title: '20+ Public Technical Case Studies',
    desc: 'Each case study documents the malware family, infection vector, decoded payload, file changes, and resolution — verifiable, original research that no fake operator could fabricate.',
    link: '/case-studies/',
    linkLabel: 'View case studies',
  },
  {
    icon: FileText,
    title: 'Malware Logs & IOCs',
    desc: 'Indicators of compromise, file hashes, malicious URLs, and decoded obfuscated payloads from real cleanups — published openly for the security community.',
    link: '/blog/',
    linkLabel: 'Browse malware logs',
  },
  {
    icon: ShieldAlert,
    title: 'Original Vulnerability Disclosure',
    desc: 'Published a denial-of-service vulnerability affecting 43.5% of the web — original research, not borrowed credibility.',
    link: '/blog/exposing-a-dos-vulnerability-in-43-5-of-the-web/',
    linkLabel: 'Read disclosure',
  },
  {
    icon: MessageSquare,
    title: 'Verified Google & Facebook Reviews',
    desc: 'Public reviews from real clients on Google Business Profile and the Facebook business page — both with timestamped, verifiable feedback.',
    link: 'https://www.google.com/search?q=md+Pabel+-+Full+Stack+Web+Developer+%26+Security+Specialist',
    linkLabel: 'See Google reviews',
    external: true,
  },
];

// Verification methodology
const VERIFICATION_METHODS = [
  {
    icon: Scan,
    title: 'VirusTotal scan (70+ engines)',
    desc: 'Every clean site is scanned across 70+ antivirus and threat-intel engines. The clean report is shared with the client before invoicing.',
  },
  {
    icon: Eye,
    title: 'Sucuri SiteCheck',
    desc: 'Public scanner used as an independent verification step. Anyone can re-run it on a domain at any time.',
  },
  {
    icon: ShieldCheck,
    title: 'Wordfence verification',
    desc: 'Server-side scan to confirm no residual malicious files, modified core, or rogue admin accounts remain after cleanup.',
  },
  {
    icon: FileCheck,
    title: 'Detailed change log',
    desc: 'Every cleanup ships with a full report listing every file modified, every database row cleaned, and every vulnerability patched.',
  },
];
---

<Layout title={seo.title} description={seo.description} image={seo.image}>
  <script
    type='application/ld+json'
    set:html={JSON.stringify(personSchema)}
    is:inline
  />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(serviceWithRatingSchema)}
    is:inline
  />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(faqSchema)}
    is:inline
  />

  <ComponentWrapper class='py-12 md:py-20'>
    {/* --- HERO SECTION --- */}
    <section class='mb-16 text-center'>
      <div class='flex justify-center mb-6'>
        <div
          class='inline-flex items-center gap-2 bg-slate-800/50 px-4 py-1.5 border border-slate-700 rounded-full font-medium text-slate-200 text-sm'>
          <BadgeCheck class='w-4 h-4 text-sky-400' />
          <span>Verified · Documented · Receipts inside</span>
        </div>
      </div>

      <h1 class='mb-6 font-bold text-white text-3xl md:text-5xl tracking-tight'>
        Proof of 4,500+ WordPress <br class='hidden md:block' />
        <span
          class='bg-clip-text bg-gradient-to-r from-sky-400 to-indigo-400 text-transparent'>
          Sites Cleaned
        </span>
      </h1>

      <p
        class='mx-auto mb-4 max-w-3xl text-slate-300 text-lg md:text-xl leading-relaxed'>
        Anyone can claim a number. This page shows the receipts: platform
        screenshots, an agency dashboard with 1,661 monitored sites, blacklist
        removal records from McAfee, Google, and Norton, plus 20+ public
        technical case studies.
      </p>

      <p class='mx-auto mb-10 max-w-2xl text-slate-500 text-sm'>
        Built so you don't have to take my word for any single source — each
        layer is independently verifiable.
      </p>

      <div class='flex sm:flex-row flex-col justify-center items-center gap-4'>
        <a
          href='/wordpress-malware-removal/'
          class={`${btnBase} ${btnDefault}`}>
          See Malware Removal Service <ArrowRight class='ml-2 w-4 h-4' />
        </a>
        <a href='/hire-me/' class={`${btnBase} ${btnOutline}`}>
          Talk to Me Directly
        </a>
      </div>
    </section>

    {/* --- QUICK ANSWER (for AI search / featured snippets) --- */}
    <section class='mx-auto mb-20 max-w-4xl'>
      <div
        class='bg-sky-950/30 p-6 md:p-8 border border-sky-900/50 rounded-2xl'>
        <div class='flex items-center gap-2 mb-3'>
          <Calculator class='w-5 h-5 text-sky-400' />
          <span
            class='font-semibold text-sky-400 text-xs uppercase tracking-wider'>
            Quick Answer
          </span>
        </div>
        <p class='text-slate-200 text-base md:text-lg leading-relaxed'>
          The <strong class='text-white'>4,500+ figure</strong> breaks down as: <strong
            class='text-white'>2,122 Fiverr orders</strong
          > (many covering multiple sites per client), <strong
            class='text-white'>158 Upwork contracts</strong
          >, <strong class='text-white'>1,661 sites managed</strong> in a long-term
          agency partnership via InfiniteWP, and <strong class='text-white'
            >200+ direct clients</strong
          > through this site and referrals. Independent verification includes <strong
            class='text-white'>370+ McAfee delistings</strong
          >, <strong class='text-white'
            >200+ Google Safe Browsing removals</strong
          >, <strong class='text-white'>100+ Norton clearances</strong>, plus
          20+ public technical case studies with original IOCs and decoded
          payloads.
        </p>
      </div>
    </section>

    {/* --- TRUST STATS --- */}
    <section class='mb-24'>
      <div
        class='gap-4 grid grid-cols-2 md:grid-cols-4 bg-slate-900/50 p-6 md:p-8 border border-slate-800 rounded-2xl'>
        {
          TRUST_STATS.map((stat) => (
            <div class='flex flex-col items-center text-center'>
              <stat.icon class='mb-2 w-6 h-6 text-sky-400' />
              <div class='font-bold text-white text-2xl md:text-3xl'>
                {stat.value}
              </div>
              <div class='text-slate-400 text-xs md:text-sm'>{stat.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- THE MATH BREAKDOWN --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-12 max-w-3xl text-center'>
        <div class='inline-flex items-center gap-2 mb-4'>
          <Calculator class='w-5 h-5 text-sky-400' />
          <span
            class='font-semibold text-sky-400 text-sm uppercase tracking-wider'>
            The Math
          </span>
        </div>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          How the 4,500+ Number Adds Up
        </h2>
        <p class='text-slate-400'>
          Four independently documented sources. Each is verifiable on its own —
          together they cross 4,500 sites comfortably, with the actual number
          almost certainly higher once Fiverr's multi-site orders are counted.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 mx-auto mb-8 max-w-5xl'>
        {
          MATH_BREAKDOWN.map((item) => (
            <div class='bg-slate-900/50 p-6 md:p-8 border border-slate-800 hover:border-slate-700 rounded-xl transition-colors'>
              <div class='flex justify-between items-start mb-4'>
                <div class='flex justify-center items-center bg-slate-800 border border-slate-700 rounded-full w-12 h-12'>
                  <item.icon class='w-6 h-6 text-sky-400' />
                </div>
                <span class='text-slate-500 text-xs uppercase tracking-wider'>
                  {item.source}
                </span>
              </div>
              <div class='mb-1 font-bold text-white text-4xl md:text-5xl'>
                {item.count}
              </div>
              <div class='mb-4 text-slate-400 text-sm'>{item.countLabel}</div>
              <p class='mb-4 text-slate-300 text-sm leading-relaxed'>
                {item.detail}
              </p>
              <div class='flex justify-between items-center pt-4 border-slate-800 border-t'>
                <span class='font-semibold text-sky-400 text-sm'>
                  {item.siteEstimate}
                </span>
                <span class='text-slate-500 text-xs'>{item.tag}</span>
              </div>
            </div>
          ))
        }
      </div>

      <div
        class='bg-slate-900 mx-auto p-6 border border-slate-800 rounded-xl max-w-5xl text-center'>
        <div
          class='flex flex-wrap justify-center items-center gap-x-3 gap-y-2 text-slate-300 text-sm md:text-base'>
          <span>~2,500+</span>
          <span class='text-slate-600'>+</span>
          <span>~200+</span>
          <span class='text-slate-600'>+</span>
          <span>1,661</span>
          <span class='text-slate-600'>+</span>
          <span>~200+</span>
          <span class='text-slate-600'>=</span>
          <span class='font-bold text-sky-400 text-lg md:text-xl'
            >4,500+ sites</span
          >
        </div>
        <p class='mt-3 text-slate-500 text-xs'>
          Conservative count. The actual figure is likely higher once multi-site
          Fiverr orders are fully tallied.
        </p>
      </div>
    </section>

    {/* --- FIVERR PROOF --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-10 max-w-4xl'>
        <div class='flex items-center gap-3 mb-4'>
          <Briefcase class='w-6 h-6 text-sky-400' />
          <h2 class='font-bold text-white text-2xl md:text-3xl'>
            Fiverr Track Record — 2,122 Completed Orders
          </h2>
        </div>
        <p class='text-slate-400'>
          Fiverr's Terms of Service prohibit linking a profile from off-platform
          marketing pages. The screenshot below is an unedited capture of my
          Fiverr seller dashboard. To verify on Fiverr directly, search for my
          seller name there.
        </p>
      </div>

      <div class='mx-auto max-w-5xl'>
        {
          /* IMAGE PLACEHOLDER — replace src with actual Fiverr dashboard screenshot */
        }
        <div
          class='relative bg-slate-900 mb-4 border border-slate-800 rounded-2xl overflow-hidden'>
          <Image
            src='/proof/fiverr-stats.png'
            alt='MD Pabel Fiverr dashboard showing 2,122 completed orders and 5-star average rating across WordPress malware removal contracts'
            width={1200}
            height={700}
            format='avif'
            quality='high'
            class='w-full h-auto'
          />
        </div>

        <div class='gap-4 grid grid-cols-2 md:grid-cols-4'>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>2,122</div>
            <div class='text-slate-400 text-xs'>Completed Orders</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>5.0★</div>
            <div class='text-slate-400 text-xs'>Average Rating</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>Level 2</div>
            <div class='text-slate-400 text-xs'>Verified Badge</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>8+ yrs</div>
            <div class='text-slate-400 text-xs'>On Platform</div>
          </div>
        </div>
      </div>
    </section>

    {/* --- UPWORK PROOF --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-10 max-w-4xl'>
        <div class='flex items-center gap-3 mb-4'>
          <FileText class='w-6 h-6 text-sky-400' />
          <h2 class='font-bold text-white text-2xl md:text-3xl'>
            Upwork Track Record — 158 Completed Contracts
          </h2>
        </div>
        <p class='text-slate-400'>
          Upwork's TOS has the same restriction on off-platform redirects. The
          screenshot below is my Upwork freelancer dashboard, captured directly
          from the Upwork interface.
        </p>
      </div>

      <div class='mx-auto max-w-5xl'>
        {
          /* IMAGE PLACEHOLDER — replace src with actual Upwork dashboard screenshot */
        }
        <div
          class='relative bg-slate-900 mb-4 border border-slate-800 rounded-2xl overflow-hidden'>
          <Image
            src='/proof/upwork-stats.png'
            alt='MD Pabel Upwork freelancer dashboard showing 158 completed contracts and Job Success Score for WordPress security work'
            width={1200}
            height={700}
            format='avif'
            quality='high'
            class='w-full h-auto'
          />
        </div>

        <div class='gap-4 grid grid-cols-2 md:grid-cols-4'>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>158</div>
            <div class='text-slate-400 text-xs'>Contracts Closed</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>Top Rated</div>
            <div class='text-slate-400 text-xs'>Status</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>100%</div>
            <div class='text-slate-400 text-xs'>Job Success Score</div>
          </div>
          <div
            class='bg-slate-900/50 p-4 border border-slate-800 rounded-xl text-center'>
            <div class='font-bold text-white text-2xl'>5.0★</div>
            <div class='text-slate-400 text-xs'>Client Rating</div>
          </div>
        </div>
      </div>
    </section>

    {/* --- AGENCY PARTNERSHIP (1,661 sites) — the big one --- */}
    <section
      class='bg-slate-900/30 -mx-4 md:-mx-8 mb-24 px-6 md:px-12 py-16 border border-slate-800 rounded-3xl'>
      <div class='mx-auto max-w-5xl'>
        <div class='mb-10 text-center'>
          <div class='inline-flex items-center gap-2 mb-4'>
            <Building2 class='w-5 h-5 text-sky-400' />
            <span
              class='font-semibold text-sky-400 text-sm uppercase tracking-wider'>
              Agency Partnership
            </span>
          </div>
          <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
            1,661 Sites Managed for a WordPress Maintenance Agency
          </h2>
          <p class='mx-auto max-w-3xl text-slate-400'>
            Long-term security partnership with a WordPress maintenance agency.
            All client domains in the dashboard below are blurred to respect the
            agency's confidentiality. The totals (Infected, Blacklisted, Error,

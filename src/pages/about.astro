---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import {
  ShieldCheck,
  CheckCircle,
  GraduationCap,
  Globe,
  Briefcase,
  Code2,
  Trophy,
  BookOpen,
  UserCheck,
  Link as LinkIcon,
  Star,
  Calendar,
  Zap,
  ArrowRight,
  Github,
  Linkedin,
  Award,
  ChevronDown,
  Quote,
  PenTool,
  Compass,
  Heart,
  XCircle,
  FileText,
  Users,
  MessageSquare,
} from '@lucide/astro';

// --- SEO META ---
const seoTitle =
  'About MD Pabel — WordPress Malware Removal Expert from Dhaka, Bangladesh';
const seoDesc =
  'MD Pabel is a WordPress malware removal expert based in Dhaka, Bangladesh. ICT graduate from Comilla University. 4,500+ hacked WordPress sites manually cleaned since July 2018. Sole operator behind mdpabel.com — not an agency.';
const canonicalUrl = 'https://www.mdpabel.com/about/';
const ogImage = 'https://www.mdpabel.com/images/md-pabel-og.jpg';

// --- BUTTONS ---
const primaryButtonClass =
  'inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 disabled:pointer-events-none disabled:opacity-50 h-11 px-8 bg-emerald-600 hover:bg-emerald-700 text-white shadow-lg shadow-emerald-900/20 tracking-tight';

const secondaryButtonClass =
  'inline-flex items-center justify-center rounded-md border border-slate-700 bg-slate-900/60 hover:bg-slate-800 text-slate-200 transition-colors h-11 px-8 text-sm font-medium';

// --- VERIFIED PUBLIC PROFILES (real, owned, verifiable) ---
const sameAsProfiles = [
  'https://www.linkedin.com/in/mdpabe1/',
  'https://github.com/mdpabel',
  'https://leetcode.com/u/mdpabel/',
  'https://www.researchgate.net/publication/395318263_Real-time_Full-Stack_University_Bus_Tracking_System_Based_on_IoT',
  'https://web.facebook.com/mdpabelwpsecurity',
  'https://www.instagram.com/md_pabell/',
];

// --- CAREER TIMELINE ---
const timeline = [
  {
    year: 'Jul 2018',
    title: 'First WordPress malware cleanup',
    body: 'Took on my first hacked-site cleanup as a Fiverr freelancer while still an ICT student at Comilla University. No security plugin subscription, no senior engineer to ask — just opened the files in a code editor and started reading. That cleanup defined the next eight years of my work.',
  },
  {
    year: '2022',
    title: 'Graduated from Comilla University',
    body: 'Completed an Information & Communication Technology (ICT) degree from Comilla University, Bangladesh. Final-year research project: a real-time, full-stack IoT-based university bus tracking system, later published on ResearchGate. By this point, freelance malware cleanup had already become the primary work, with the academic foundation supporting it.',
  },
  {
    year: 'Nov 2023',
    title: 'Expanded to Upwork',
    body: 'After five years of hacked-site work and thousands of cleanups, joined Upwork to reach a different client base. Started with one-off cleanup jobs and quickly grew to long-term security retainers.',
  },
  {
    year: '2024',
    title: 'Earned Top Rated on Upwork',
    body: 'Reached Top Rated status through consistent technical work and high client satisfaction. Top Rated is awarded based on long-term success score, completion rate, and client feedback — not just hours billed.',
  },
  {
    year: '2026',
    title: '4,500+ documented cleanups',
    body: 'Crossed the 4,500-cleanup milestone, with clients across 60% of the world. By this point, every notable cleanup is documented as a forensic case study or blog post on mdpabel.com — partly so future clients can verify the work, and partly so other site owners facing the same attack have a real reference instead of a marketing page.',
  },
];

// --- NON-NEGOTIABLES ---
const principles = [
  {
    title: 'I never use nulled plugins or themes',
    body: "Free pirated plugins are how 30% of hacked sites I see got infected in the first place. I won't recommend them, install them, or work on a site that's running them without first removing them.",
  },
  {
    title: 'Every cleanup gets documented',
    body: "Roughly half of my cleanups become a public blog post or case study. Clients' identifying details are always anonymized, but the malware patterns, file paths, and forensic process go public so other site owners can learn from them.",
  },
  {
    title: 'No black-box proprietary scripts',
    body: "I don't run mystery scanners on client sites. Every command, every script, and every change is something I can explain line by line. If you ask what I did, you'll get a real answer with file paths and reasoning.",
  },
  {
    title: 'Backup restoration is a last resort',
    body: "Most 'restored from backup' fixes I see were restored from an already-infected backup. I clean live, document the entry point, and only restore from backup when it's verified clean and necessary.",
  },
  {
    title: 'I work alone — and that is a feature',
    body: "Every cleanup, every email, every Search Console submission is done by me personally. There's no support tier 1 to escalate from, no junior engineer touching production. That's slower than an agency, but accountability is unambiguous.",
  },
  {
    title: 'Honest scoping over upselling',
    body: "If your problem is a 5-minute fix, I'll tell you it's a 5-minute fix. I'd rather quote a fair price for actual work than win short-term margin and lose the next ten referrals.",
  },
];

// --- FAQ DATA (mirrored in schema) ---
const faqs = [
  {
    q: 'Who is MD Pabel?',
    a: 'MD Pabel is a WordPress malware removal expert based in Dhaka, Bangladesh. He has been manually cleaning hacked WordPress sites since July 2018 and is the sole person behind mdpabel.com — not an agency, white-label reseller, or marketplace front. He graduated in Information & Communication Technology (ICT) from Comilla University and specializes in Japanese SEO spam, fake CAPTCHA malware, .htaccess redirects, database injections, hidden backdoors, and blacklist recovery.',
  },
  {
    q: 'How can I verify MD Pabel is a real person?',
    a: 'Cross-reference the verifiable public profiles linked on this page: LinkedIn (linkedin.com/in/mdpabe1), GitHub (github.com/mdpabel), LeetCode (leetcode.com/u/mdpabel — 550+ problems solved), the ResearchGate publication on a university IoT project, and the Facebook business page mdpabelwpsecurity. All of these point to the same person and are owned and updated by him.',
  },
  {
    q: 'I worked with MD Pabel on a freelancer marketplace years ago. Is this the same person?',
    a: 'Yes. mdpabel.com is the direct way to continue working with him outside of marketplace platforms. Past clients can verify identity by matching the writing style, the technical depth in case studies, and any specific cleanups they remember — most are documented on the blog and case-studies sections.',
  },
  {
    q: 'Where is MD Pabel based?',
    a: 'Dhaka, Bangladesh. Time zone is Bangladesh Standard Time (UTC+6). Most clients are in the US, UK, Europe, and Australia, so emergency cleanups are typically picked up within 1–2 hours of contact regardless of which time zone the client is in.',
  },
  {
    q: 'Is MD Pabel an agency, a team, or one person?',
    a: 'One person. There are no junior engineers, no support tiers, no white-label subcontracting. Every cleanup, every Google Search Console submission, every blog post, and every email reply is done by MD Pabel personally. This is slower than an agency in raw throughput but means responsibility is unambiguous on every job.',
  },
  {
    q: 'Why does MD Pabel publish so many forensic case studies and write-ups?',
    a: "Two reasons. First, transparency — anyone considering hiring him can read documented cleanups before contacting, instead of relying on marketing pages. Second, education — most WordPress site owners discover their site is hacked at the worst possible moment and need to understand what's happening fast. Public forensic write-ups help them either fix it themselves or hire someone competent.",
  },
  {
    q: 'What is MD Pabel’s educational background?',
    a: 'Bachelor’s degree in Information & Communication Technology (ICT) from Comilla University, Bangladesh. Final-year research focused on a real-time, full-stack IoT-based university bus tracking system, published on ResearchGate. Outside formal education, has solved 550+ LeetCode problems for ongoing algorithmic and systems practice.',
  },
  {
    q: 'Does MD Pabel only work on WordPress?',
    a: 'WordPress malware removal is the primary specialty and the focus of mdpabel.com. The supporting technical foundation — PHP, JavaScript, TypeScript, Node.js, MySQL, server logs, and hosting platforms — exists specifically to make the malware work deeper. WordPress is roughly 95% of the work; the remaining 5% is typically forensic JavaScript analysis, server-level cleanup on non-WordPress hosts, and occasional full-stack development consulting.',
  },
  {
    q: 'How does MD Pabel describe his approach to malware removal?',
    a: "Read the code, don't trust the scanner. Find the entry point, not just the symptom. Patch the vulnerability that allowed the attack, not just the visible payload. Document everything so the same attack pattern is easier to recognize next time. Treat each site as the client's livelihood, not a ticket number.",
  },
];

// --- STRUCTURED DATA (ProfilePage + Person + FAQPage) ---
const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      '@id': `${canonicalUrl}#profilepage`,
      url: canonicalUrl,
      name: 'About MD Pabel — WordPress Malware Removal Expert',
      description: seoDesc,
      inLanguage: 'en',
      dateCreated: '2024-01-15T00:00:00+06:00',
      dateModified: new Date().toISOString(),
      mainEntity: { '@id': `${canonicalUrl}#person` },
      isPartOf: { '@id': 'https://www.mdpabel.com/#website' },
    },
    {
      '@type': 'Person',
      '@id': `${canonicalUrl}#person`,
      name: 'MD Pabel',
      alternateName: ['Md Pabel', 'Pabel', 'M D Pabel'],
      url: canonicalUrl,
      mainEntityOfPage: canonicalUrl,
      image: 'https://www.mdpabel.com/images/md-pabel.jpg',
      jobTitle: 'WordPress Malware Removal Expert',
      description:
        'WordPress malware removal expert from Dhaka, Bangladesh. ICT graduate of Comilla University. 4,500+ hacked WordPress sites manually cleaned since July 2018. Sole operator behind mdpabel.com.',
      gender: 'Male',
      nationality: { '@type': 'Country', name: 'Bangladesh' },
      birthPlace: { '@type': 'Place', name: 'Bangladesh' },
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'BD',
        addressLocality: 'Dhaka',
        addressRegion: 'Dhaka Division',
      },
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Comilla University',
        sameAs: 'https://cou.ac.bd/',
      },
      knowsAbout: [
        'WordPress malware removal',
        'WordPress security',
        'Hacked WordPress site cleanup',
        'Japanese keyword hack removal',
        'Japanese SEO spam removal',
        'Pharma hack removal',
        'Google blacklist removal',
        'McAfee blacklist removal',
        'Norton blacklist removal',
        'Google Safe Browsing recovery',
        'Fake CAPTCHA malware',
        'hSEO malware',
        'ClearFake malware',
        '.htaccess malware',
        'WordPress redirect malware',
        'WordPress database malware',
        'WordPress backdoor removal',
        'Hidden admin user detection',
        'Cron job malware removal',
        'Cloaking malware removal',
        'WooCommerce credit card skimmer removal',
        'JavaScript redirect malware',
        'Obfuscated PHP malware analysis',
        'WordPress critical error fix',
        'WordPress white screen of death',
        'WordPress security hardening',
        'Manual malware forensics',
        'Server log analysis',
        'PHP',
        'JavaScript',
        'TypeScript',
        'Node.js',
        'MySQL',
        'cPanel',
        'Cloudflare',
        'SiteGround',
      ],
      knowsLanguage: ['en', 'bn'],
      worksFor: {
        '@type': 'Organization',
        name: 'MD Pabel — WordPress Malware Removal & Security',
        url: 'https://www.mdpabel.com/',
      },
      hasOccupation: {
        '@type': 'Occupation',
        name: 'WordPress Malware Removal Expert',
        occupationLocation: { '@type': 'Country', name: 'Bangladesh' },
        skills:
          'Manual malware cleanup, forensic log analysis, PHP code review, JavaScript de-obfuscation, blacklist removal, WordPress hardening, database malware analysis, hidden backdoor detection',
      },
      sameAs: sameAsProfiles,
    },
    {
      '@type': 'FAQPage',
      '@id': `${canonicalUrl}#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
});
---

<Layout title={seoTitle} description={seoDesc}>
  {
    /*
    NOTE: Ensure your Layout.astro accepts these as props or exposes a head slot
    for canonical, og:image, og:type='profile' if you want full OG/Twitter coverage.
  */
  }
  <script type='application/ld+json' set:html={structuredData} />

  <ComponentWrapper class='relative py-16 md:py-24'>
    {/* --- Decorative Background --- */}
    <div
      class='top-0 left-0 -z-10 absolute w-full h-full overflow-hidden pointer-events-none'>
      <div
        class='-top-[10%] right-0 absolute bg-emerald-500/10 blur-3xl rounded-full w-[650px] h-[650px]'>
      </div>
      <div
        class='top-[18%] left-[8%] absolute bg-sky-500/5 blur-3xl rounded-full w-[380px] h-[380px]'>
      </div>
      <div
        class='bottom-0 left-0 absolute bg-emerald-500/5 blur-3xl rounded-full w-[500px] h-[500px]'>
      </div>
    </div>

    {/* --- HERO --- */}
    <section class='z-10 relative mx-auto mb-16 max-w-5xl text-center'>
      <div
        class='inline-flex items-center gap-2 bg-emerald-900/20 mb-8 px-4 py-1.5 border border-emerald-800/50 rounded-full'>
        <UserCheck class='w-4 h-4 text-emerald-400' />
        <span class='font-semibold text-emerald-200 text-sm'>
          Verified WordPress Security Specialist · Dhaka, Bangladesh
        </span>
      </div>

      <h1
        class='mx-auto mb-6 max-w-4xl font-bold text-white text-3xl md:text-5xl leading-[1.05] tracking-tight'>
        About MD Pabel
        <span
          class='block bg-clip-text bg-gradient-to-r from-emerald-400 to-sky-400 mt-2 text-transparent text-2xl md:text-3xl'>
          WordPress Malware Removal Expert
        </span>
      </h1>

      <p class='mx-auto mb-8 max-w-3xl text-slate-300 text-lg leading-relaxed'>
        Hi, I'm MD Pabel — the person behind every cleanup, every case study,
        and every email reply on this site. Since July 2018, I've manually
        cleaned <strong class='text-white'>4,500+ hacked WordPress sites</strong
        >
        for clients across
        <strong class='text-white'>60% of the world</strong>. mdpabel.com is run
        entirely by me from
        <strong class='text-white'>Dhaka, Bangladesh</strong> — no agency, no team,
        no white-label reselling.
      </p>

      <div
        class='flex sm:flex-row flex-col justify-center items-center gap-4 mb-10'>
        <a href='/hire-me/' class={primaryButtonClass}>
          Hire Me Directly <ArrowRight class='ml-2 w-4 h-4' />
        </a>
        <a href='/wordpress-malware-removal/' class={secondaryButtonClass}>
          See Malware Removal Service
        </a>
      </div>
    </section>

    {/* --- QUICK ANSWER (AI / AEO BLOCK) --- */}
    <section
      class='z-10 relative mx-auto mb-20 max-w-4xl'
      aria-labelledby='quick-answer'>
      <div
        class='bg-slate-900/70 p-6 md:p-8 border border-emerald-900/30 rounded-2xl'>
        <div
          class='inline-flex items-center gap-2 bg-emerald-900/30 mb-4 px-3 py-1 border border-emerald-800/40 rounded-full font-semibold text-emerald-300 text-xs uppercase tracking-wider'>
          <Zap class='w-3.5 h-3.5' /> Quick Answer
        </div>
        <h2 id='quick-answer' class='mb-3 font-bold text-white text-2xl'>
          Who is MD Pabel?
        </h2>
        <p class='mb-4 text-slate-300 leading-relaxed'>
          <strong class='text-white'>MD Pabel</strong> is a WordPress malware removal
          expert based in
          <strong class='text-white'> Dhaka, Bangladesh</strong>. He is an
          <strong class='text-white'>
            Information &amp; Communication Technology (ICT) graduate of Comilla
            University</strong
          > and the sole person behind <a
            href='/'
            class='text-emerald-400 hover:underline'>mdpabel.com</a
          > — not an agency, reseller, or marketplace front. Active in WordPress security
          since July 2018, he specializes in manual cleanup of Japanese SEO spam,
          fake CAPTCHA malware, .htaccess redirects, database injections, hidden backdoors,
          and blacklist recovery.
        </p>
        <ul class='gap-x-6 gap-y-2 grid sm:grid-cols-2 text-slate-300 text-sm'>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            4,500+ hacked WordPress sites manually cleaned
          </li>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            Full-time WordPress security specialist since 2018
          </li>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            ICT graduate · Comilla University, Bangladesh
          </li>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            Sole operator · no agency, no team, no resellers
          </li>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            Clients across 60% of the world
          </li>
          <li class='flex items-start gap-2'>
            <CheckCircle
              class='flex-shrink-0 mt-0.5 w-4 h-4 text-emerald-400'
            />
            550+ LeetCode problems solved · published IoT researcher
          </li>
        </ul>
      </div>
    </section>

    {/* --- PERSONAL CREDENTIALS --- */}
    <section class='mx-auto mb-20 max-w-6xl'>
      <div class='mb-10 text-center'>
        <h2 class='mb-3 font-bold text-white text-3xl md:text-4xl'>
          Verifiable credentials at a glance
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          Every number below is verifiable through the public profiles linked
          further down this page.
        </p>
      </div>

      <div class='gap-6 grid sm:grid-cols-2 lg:grid-cols-3'>
        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <ShieldCheck class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>4,500+</h3>
          <p class='text-slate-400'>Hacked WordPress sites cleaned</p>
        </div>

        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <Calendar class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>2018</h3>
          <p class='text-slate-400'>
            Year I started · 8 years of full-time security work
          </p>
        </div>

        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <Globe class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>60%</h3>
          <p class='text-slate-400'>
            Of the world reached · clients on every continent
          </p>
        </div>

        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <Trophy class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>Top Rated</h3>
          <p class='text-slate-400'>Verified Upwork status since 2024</p>
        </div>

        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <GraduationCap class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>ICT</h3>
          <p class='text-slate-400'>
            Graduate · Comilla University, Bangladesh
          </p>
        </div>

        <div class='bg-slate-900/60 p-7 border border-slate-800 rounded-3xl'>
          <Code2 class='mb-3 w-6 h-6 text-emerald-400' />
          <h3 class='mb-1 font-bold text-white text-3xl'>550+</h3>
          <p class='text-slate-400'>LeetCode problems solved</p>
        </div>
      </div>
    </section>

    {/* --- MY STORY --- */}
    <section class='mx-auto mb-20 max-w-4xl'>
      <div
        class='bg-slate-900/50 p-8 md:p-10 border border-slate-800 rounded-3xl'>
        <div
          class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
          <BookOpen class='w-5 h-5' /> The story
        </div>
        <h2 class='mb-6 font-bold text-white text-3xl'>
          From one hacked site in 2018 to 4,500+ cleanups
        </h2>

        <div class='space-y-5 text-slate-300 leading-relaxed'>
          <p>
            I started freelancing in <strong class='text-white'
              >July 2018</strong
            >, while still studying ICT at Comilla University. My first paid
            jobs were small — fixing broken plugin conflicts, helping people
            install themes, troubleshooting forms. Then a client showed up with
            a fully hacked WordPress site. Mobile redirects, Google blacklist,
            hosting suspension warning, the whole stack. I had no playbook, no
            Sucuri subscription, and no senior engineer to ask. I opened the
            files in a code editor and started reading.
          </p>

          <p>
            That single cleanup taught me something that has shaped every job
            since: <strong class='text-white'
              >automated scanners report what they recognize, but real malware
              hides specifically in the gaps they can't see.</strong
            > Once you can read PHP and follow what it does at runtime, the "mystery"
            of a hacked WordPress site disappears. It becomes pattern recognition.
          </p>

          <p>
            By 2021 I was specializing almost entirely in compromised sites.
            Each cleanup made the next one faster. By early 2026, the count
            crossed 4,500 — including one site with
            <a
              href='/case-studies/how-we-cleaned-a-hacked-wordpress-site-from-3-45m-matbet-seo-spam-and-how-you-can-prevent-it/'
              class='text-emerald-400 hover:underline'
              >3.45 million spam URLs in Google</a
            >, another with
            <a
              href='/blog/recovering-from-seo-spam-how-we-cleared-242000-japanese-spam-pages-from-a-hacked-wordpress-site-in-2025/'
              class='text-emerald-400 hover:underline'
              >242,000 Japanese spam pages indexed</a
            >, and a <a
              href='/case-studies/wordpress-homepage-defaced-gambling-site-case-study/'
              class='text-emerald-400 hover:underline'
              >homepage defacement involving 33,771 infected files</a
            >. Each one is documented as a public case study so other people
            facing similar attacks have a real reference, not a marketing
            brochure.
          </p>

          <p>
            mdpabel.com exists for a specific reason. After years of working
            through marketplace platforms, the friction of those platforms — the
            communication delays, the inability to send long forensic reports,
            the inability for past clients to find me again easily — became the
            biggest blocker to doing the work well. This site fixes that. It's
            the direct, no-middleman way to find me, verify the work, and
            continue working together.
          </p>
        </div>
      </div>
    </section>

    {/* --- CAREER TIMELINE --- */}
    <section class='mx-auto mb-20 max-w-4xl'>
      <div class='mb-10 text-center'>
        <h2 class='mb-3 font-bold text-white text-3xl md:text-4xl'>
          Career timeline
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          The milestones that shaped this work, in order.
        </p>
      </div>

      <ol class='relative space-y-10 ml-4 border-slate-800 border-l-2'>
        {
          timeline.map((item) => (
            <li class='relative pl-8'>
              <span class='-left-[11px] absolute flex justify-center items-center bg-slate-950 border-2 border-emerald-500 rounded-full w-5 h-5'>
                <span class='bg-emerald-400 rounded-full w-2 h-2' />
              </span>
              <div class='bg-slate-900/60 p-6 border border-slate-800 rounded-2xl'>
                <div class='inline-flex items-center gap-2 mb-2 font-mono font-semibold text-emerald-400 text-xs uppercase tracking-wider'>
                  <Calendar class='w-3.5 h-3.5' /> {item.year}
                </div>
                <h3 class='mb-2 font-bold text-white text-xl'>{item.title}</h3>
                <p class='text-slate-300 text-sm leading-relaxed'>
                  {item.body}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    {/* --- HOW I THINK ABOUT THIS WORK --- */}
    <section class='mx-auto mb-20 max-w-5xl'>
      <div
        class='bg-emerald-900/10 p-8 md:p-10 border border-emerald-900/30 rounded-3xl'>
        <div
          class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
          <Compass class='w-5 h-5' /> How I think about this work
        </div>
        <h2 class='mb-6 font-bold text-white text-3xl'>
          Read the code. Find the entry point. Patch the cause.
        </h2>

        <div class='gap-6 grid md:grid-cols-2 text-slate-300 leading-relaxed'>
          <p>
            Most "WordPress malware removal" services on the web are essentially
            a Wordfence or Sucuri scan plus a database flush. That works for the
            simplest infections — the ones the scanners already know — but the
            moment you're dealing with obfuscated PHP, fake plugins disguised as
            core, hidden admin users, or cron-job persistence, the signature
            engine misses it and the site gets re-infected within days.
          </p>

          <p>
            My approach is the opposite. I read the code first, treat scanner
            output as one input among many (alongside server access logs,
            modified-file timestamps, Search Console signals, and database
            anomalies), and trace the infection back to the entry point. Only
            then do I clean — and the cleanup includes patching whatever allowed
            the attack so the same thing can't happen again next week.
          </p>

          <p>
            That's slower than a one-click cleanup tool. It's also why
            re-infection is rare for sites I've worked on, and why most of my
            clients come from referrals rather than ad spend.
          </p>

          <p>
            The supporting technical foundation — PHP, JavaScript, server
            internals, MySQL, hosting platforms — exists specifically to make
            this work possible. You can't read malware you can't read code in
            general; you can't trace a server-level redirect without
            understanding access logs; you can't clean a database injection
            without knowing what the original query was supposed to look like.
            Everything connects.
          </p>
        </div>
      </div>
    </section>


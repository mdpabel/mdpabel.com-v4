---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import {
  ShieldCheck,
  CheckCircle,
  GraduationCap,
  Globe,
  Briefcase,
  Code2,
  Wrench,
  Bug,
  Search,
  Lock,
  MessageSquare,
  Trophy,
  FileCode2,
  Terminal,
  Server,
  BookOpen,
  UserCheck,
  Link as LinkIcon,
} from '@lucide/astro';

// --- SEO DATA ---
const seoTitle =
  'About MD Pabel | WordPress Malware Removal Expert & Full-Stack Developer';
const seoDesc =
  'Meet MD Pabel, a WordPress malware removal expert and full-stack developer from Bangladesh. 4,500+ hacked sites fixed, 2,090+ Fiverr orders, 110+ Upwork jobs, Top Rated on Upwork, and deep experience in WordPress security, PHP, JS, TS, React, Next.js, Astro, servers, and hosting.';

// --- CTA BUTTONS ---
const primaryButtonClass =
  'inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 disabled:pointer-events-none disabled:opacity-50 h-11 px-8 bg-emerald-600 hover:bg-emerald-700 text-white shadow-lg shadow-emerald-900/20 tracking-tight';

const secondaryButtonClass =
  'inline-flex items-center justify-center rounded-md border border-slate-700 bg-slate-900/60 hover:bg-slate-800 text-slate-200 transition-colors h-11 px-8 text-sm font-medium';

// --- PROFILE LINKS ---
// Replace these with your real public profile URLs
const sameAsProfiles = [
  'https://www.fiverr.com/your-profile',
  'https://www.upwork.com/freelancers/your-profile',
  'https://www.linkedin.com/in/your-profile',
  'https://github.com/your-profile',
  'https://leetcode.com/your-profile',
  'https://www.researchgate.net/profile/your-profile',
];

// --- STRUCTURED DATA ---
const structuredData = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    dateModified: new Date().toISOString(),
    mainEntity: {
      '@type': 'Person',
      name: 'MD Pabel',
      alternateName: 'Md Pabel',
      description:
        'WordPress malware removal expert and full-stack developer from Bangladesh. Specializes in hacked WordPress site cleanup, Japanese SEO spam removal, blacklist recovery, and technical troubleshooting.',
      jobTitle: 'WordPress Malware Removal Expert',
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Comilla University',
      },
      knowsAbout: [
        'WordPress malware removal',
        'WordPress security',
        'Google blacklist removal',
        'McAfee blacklist removal',
        'Japanese SEO spam removal',
        'WordPress critical error fixing',
        'JavaScript',
        'TypeScript',
        'Python',
        'Node.js',
        'React',
        'Next.js',
        'Astro',
        'PHP',
        'SQL',
        'MySQL',
        'MongoDB',
        'Server management',
        'Hosting troubleshooting',
      ],
      sameAs: sameAsProfiles,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'MD Pabel',
    jobTitle: 'WordPress Malware Removal Expert',
    description:
      'WordPress malware removal expert and full-stack developer from Bangladesh with deep experience in hacked site cleanup, SEO spam removal, blacklist recovery, and technical troubleshooting.',
    sameAs: sameAsProfiles,
  },
]);
---

<Layout title={seoTitle} description={seoDesc}>
  <script type='application/ld+json' set:html={structuredData} />

  <ComponentWrapper class='relative py-16 md:py-24'>
    {/* Decorative Background */}
    <div
      class='top-0 left-0 -z-10 absolute w-full h-full overflow-hidden pointer-events-none'>
      <div
        class='-top-[10%] right-0 absolute bg-emerald-500/10 blur-3xl rounded-full w-[650px] h-[650px]'>
      </div>
      <div
        class='top-[18%] left-[8%] absolute bg-sky-500/5 blur-3xl rounded-full w-[380px] h-[380px]'>
      </div>
      <div
        class='bottom-0 left-0 absolute bg-emerald-500/5 blur-3xl rounded-full w-[500px] h-[500px]'>
      </div>
    </div>

    {/* --- HERO --- */}
    <section class='z-10 relative mx-auto mb-20 max-w-5xl text-center'>
      <div
        class='inline-flex items-center gap-2 bg-emerald-900/20 mb-8 px-4 py-1.5 border border-emerald-800/50 rounded-full'>
        <UserCheck class='w-4 h-4 text-emerald-400' />
        <span class='font-semibold text-emerald-200 text-sm'>
          Personal Profile • Expertise • Proof
        </span>
      </div>

      <h1
        class='mx-auto mb-6 max-w-4xl font-bold text-white text-3xl md:text-4xl leading-[1.05] tracking-tight'>
        About MD Pabel
        <span
          class='block bg-clip-text bg-gradient-to-r from-emerald-400 to-sky-400 mt-2 text-transparent'>
          WordPress Malware Removal Expert & Full-Stack Developer
        </span>
      </h1>

      <p class='mx-auto mb-10 max-w-3xl text-slate-400 text-lg leading-relaxed'>
        I’m MD Pabel, a WordPress malware removal expert and full-stack
        developer from Bangladesh. I started working on Fiverr in <strong
          class='text-slate-200'>July 2018</strong
        > and on Upwork in
        <strong class='text-slate-200'> November 2023</strong>. Since then, I’ve
        fixed
        <strong class='text-slate-200'> 4,500+ hacked websites</strong>,
        completed
        <strong class='text-slate-200'> 2,090+ Fiverr orders</strong> and
        <strong class='text-slate-200'> 110+ Upwork jobs</strong>, and worked
        with clients across
        <strong class='text-slate-200'> 60% of the world</strong>.
      </p>

      <div
        class='flex sm:flex-row flex-col justify-center items-center gap-4 mb-12'>
        <a href='/hire-me/' class={primaryButtonClass}> Hire Me </a>
        <a href='/wordpress-malware-removal/' class={secondaryButtonClass}>
          View My Services
        </a>
      </div>

      <div class='gap-4 grid sm:grid-cols-3 mx-auto max-w-4xl text-left'>
        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <Trophy class='w-5 h-5 text-emerald-400' />
            Top Rated on Upwork
          </div>
          <p class='text-slate-400 text-sm'>
            Active freelancer with a proven record of technical WordPress and
            web-security work.
          </p>
        </div>

        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <CheckCircle class='w-5 h-5 text-emerald-400' />
            Level 2 on Fiverr
          </div>
          <p class='text-slate-400 text-sm'>
            Long-term Fiverr experience handling malware cleanup, security
            issues, and emergency website repair.
          </p>
        </div>

        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <ShieldCheck class='w-5 h-5 text-emerald-400' />
            4,500+ hacked sites fixed
          </div>
          <p class='text-slate-400 text-sm'>
            Deep hands-on experience with WordPress malware, SEO spam, blacklist
            issues, and broken websites.
          </p>
        </div>
      </div>
    </section>

    {/* --- STATS --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Quick credibility snapshot
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          These are the numbers and background details that define my work and
          experience.
        </p>
      </div>

      <div class='gap-6 grid sm:grid-cols-2 lg:grid-cols-3'>
        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <ShieldCheck class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>4,500+</h3>
          <p class='text-slate-400'>Hacked websites fixed</p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <Briefcase class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>2,090+</h3>
          <p class='text-slate-400'>Fiverr orders completed</p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <CheckCircle class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>110+</h3>
          <p class='text-slate-400'>Upwork jobs completed</p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <Globe class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>60%</h3>
          <p class='text-slate-400'>World coverage of clients</p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <GraduationCap class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>ICT</h3>
          <p class='text-slate-400'>
            Graduate from Comilla University, Bangladesh
          </p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <Code2 class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-2 font-bold text-white text-2xl'>550+</h3>
          <p class='text-slate-400'>LeetCode problems solved</p>
        </div>
      </div>
    </section>

    {/* --- STORY --- */}
    <section class='mx-auto mb-24 max-w-4xl'>
      <div
        class='bg-slate-900/50 p-8 md:p-10 border border-slate-800 rounded-3xl'>
        <h2 class='mb-6 font-bold text-white text-3xl'>My story</h2>

        <div class='space-y-5 text-slate-400 leading-relaxed'>
          <p>
            I built my reputation by solving real technical problems for real
            clients, especially hacked WordPress websites, malware infections,
            SEO spam issues, blacklist warnings, and broken website emergencies.
          </p>

          <p>
            I started freelancing on <strong class='text-slate-200'
              >Fiverr in July 2018</strong
            >, where I spent years working on hacked websites, malware cleanup,
            hosting issues, and WordPress troubleshooting. Later, I expanded to
            <strong class='text-slate-200'> Upwork in November 2023</strong>,
            where I became
            <strong class='text-slate-200'> Top Rated</strong> through consistent
            technical work and client results.
          </p>

          <p>
            Over time, WordPress malware removal became my strongest specialty.
            I have worked on thousands of infections involving cloaking, fake
            plugins, Japanese SEO spam, spam redirects, blacklists, broken
            updates, fatal errors, and hidden persistence.
          </p>

          <p>
            Alongside my security work, I also have a strong technical
            foundation as a full-stack developer. That background helps me
            understand problems beyond surface-level WordPress administration
            and makes my troubleshooting much deeper than simple scanner-based
            cleanup.
          </p>
        </div>
      </div>
    </section>

    {/* --- WHAT I DO --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          What I specialize in
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          My work is focused on technical website recovery, security, and
          full-stack problem solving.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3'>
        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Bug class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            WordPress malware removal
          </h3>
          <p class='text-slate-400'>
            Manual cleanup of hacked WordPress websites, backdoors, fake
            plugins, injected PHP, and hidden persistence.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Search class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>SEO spam cleanup</h3>
          <p class='text-slate-400'>
            Recovery from Japanese SEO spam, cloaked pages, spam URLs, hacked
            search results, and index pollution.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <ShieldCheck class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Blacklist removal help
          </h3>
          <p class='text-slate-400'>
            Cleanup and recovery support for Google Safe Browsing, McAfee, and
            other website reputation issues.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Wrench class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Critical error repair
          </h3>
          <p class='text-slate-400'>
            Fixing broken WordPress websites, plugin conflicts, theme crashes,
            fatal PHP errors, and update failures.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Server class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Server & hosting troubleshooting
          </h3>
          <p class='text-slate-400'>
            Debugging issues from hosting level, file manager, logs, FTP, server
            configuration, and performance bottlenecks.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <FileCode2 class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Full-stack development
          </h3>
          <p class='text-slate-400'>
            Building and troubleshooting with JavaScript, TypeScript, Python,
            Node.js, React, Next.js, Astro, PHP, SQL, and databases.
          </p>
        </div>
      </div>
    </section>

    {/* --- HOW I WORK --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='items-start gap-8 grid lg:grid-cols-[1.05fr_.95fr]'>
        <div class='bg-slate-900/60 p-10 border border-slate-800 rounded-3xl'>
          <h2 class='mb-6 font-bold text-white text-3xl'>How I work</h2>

          <div class='space-y-5'>
            <div class='flex gap-4'>
              <Search class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>I diagnose first</h3>
                <p class='text-slate-400'>
                  I try to understand the root cause before making changes. That
                  means checking symptoms, recent changes, files, plugins,
                  themes, logs, and hosting-level behavior.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <Bug class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>I clean manually</h3>
                <p class='text-slate-400'>
                  I do not rely only on automated scanners. I inspect suspicious
                  files, fake plugins, injected code, spam generators, and
                  persistence mechanisms carefully.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <Lock class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I fix the cause, not just the symptom
                </h3>
                <p class='text-slate-400'>
                  A real fix means removing the active threat, closing the hole
                  that caused it, and helping prevent reinfection or repeated
                  failure.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <CheckCircle class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I validate after repair
                </h3>
                <p class='text-slate-400'>
                  After a cleanup or repair, I verify the website behavior and
                  make sure the result is stable, not just temporarily back
                  online.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div
          class='bg-emerald-900/10 p-10 border border-emerald-900/30 rounded-3xl'>
          <div
            class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
            <MessageSquare class='w-5 h-5' />
            Why clients hire me
          </div>

          <div class='space-y-4 text-slate-400 leading-relaxed'>
            <p>
              Clients usually come to me when the problem is already serious:
              malware, hacked search results, blacklist warnings, fake plugins,
              site-down errors, or a website that has been partially “cleaned”
              but is still broken.
            </p>

            <p>
              They hire me because I understand both the WordPress side and the
              deeper technical side: PHP, JavaScript, servers, hosting, logs,
              databases, and custom debugging.
            </p>

            <p>
              That mix of hands-on malware experience and broader development
              knowledge is what makes my work different from generic one-click
              cleanup services.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* --- TECH STACK --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Technical background
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          These are the tools and technologies I work with regularly.
        </p>
      </div>

      <div class='gap-4 grid sm:grid-cols-2 lg:grid-cols-4'>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          JavaScript
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          TypeScript
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          Python
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          Node.js
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          React
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          Next.js
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          Astro
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          WordPress
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          PHP
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          SQL / MySQL
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          MongoDB
        </div>
        <div
          class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl text-slate-300'>
          Server / Hosting
        </div>
      </div>
    </section>

    {/* --- EDUCATION & PROOF --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='gap-8 grid lg:grid-cols-2'>
        <div class='bg-slate-900/60 p-10 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
            <GraduationCap class='w-5 h-5' />
            Education
          </div>
          <h2 class='mb-4 font-bold text-white text-3xl'>
            Academic background
          </h2>
          <p class='text-slate-400 leading-relaxed'>
            I graduated from <strong class='text-slate-200'
              >Comilla University, Bangladesh</strong
            > with a background in
            <strong class='text-slate-200'> ICT</strong>. That academic
            foundation supports my technical work in software, web systems,
            debugging, and security-oriented problem solving.
          </p>
        </div>

        <div class='bg-slate-900/60 p-10 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
            <LinkIcon class='w-5 h-5' />
            Public proof
          </div>
          <h2 class='mb-4 font-bold text-white text-3xl'>
            Profiles and verification
          </h2>
          <p class='mb-6 text-slate-400 leading-relaxed'>
            A strong personal brand needs public signals. Link your real
            profiles here so visitors and search engines can verify your
            background.
          </p>

          <div class='space-y-3 text-slate-300'>
            <a
              href='https://www.linkedin.com/in/mdpabe1/'
              class='block hover:text-emerald-300 transition-colors'>LinkedIn</a
            >
            <a
              href='https://github.com/mdpabel'
              class='block hover:text-emerald-300 transition-colors'>GitHub</a
            >
            <a
              href='https://leetcode.com/u/mdpabel/'
              class='block hover:text-emerald-300 transition-colors'>LeetCode</a
            >
            <a
              href='https://www.researchgate.net/publication/395318263_Real-time_Full-Stack_University_Bus_Tracking_System_Based_on_IoT'
              class='block hover:text-emerald-300 transition-colors'
              >Research / Publication Profile</a
            >
          </div>
        </div>
      </div>
    </section>

    {/* --- FINAL CTA --- */}
    <section
      class='bg-emerald-900/10 mt-24 py-20 border border-emerald-900/30 rounded-3xl text-center'>
      <div
        class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400'>
        <ShieldCheck class='w-5 h-5' />
        Work with a real specialist
      </div>

      <h2 class='mb-6 font-bold text-white text-3xl md:text-4xl'>
        Need help with a hacked or broken website?
      </h2>

      <p class='mx-auto mb-10 max-w-2xl text-slate-400'>
        If your WordPress site is hacked, blacklisted, spammed, or broken, I can
        help you diagnose the issue, clean it properly, and get it stable again.
      </p>

      <div class='flex md:flex-row flex-col justify-center items-center gap-4'>
        <a
          href='/hire-me/'
          class={`px-12 py-4 rounded-full text-lg ${primaryButtonClass}`}>
          Hire Me
        </a>
        <a
          href='/blog/'
          class='px-12 py-4 border border-slate-700 rounded-full text-slate-200 hover:text-white text-lg transition-colors'>
          Read My Case Studies
        </a>
      </div>
    </section>
  </ComponentWrapper>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import ComponentWrapper from '../../components/component-wrapper.astro';
import {
  ShieldAlert,
  FolderKey,
  FileCode2,
  UserX,
  AlertTriangle,
  Terminal,
  Trash2,
  Activity,
  Database,
  Bug,
  Stethoscope,
} from '@lucide/astro';
import { wordpress } from '../../lib/wordpress';

export async function getStaticPaths() {
  const allPlugins = await wordpress.getAllPosts({
    postType: 'fake_plugin',
  });

  return allPlugins.map((plugin: any) => ({
    params: { slug: plugin.slug },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const acf = plugin.acf || {};

// Helper to parse ACF textareas into arrays safely
const splitLines = (str: string) => {
  if (!str) return [];
  return str
    .split('\n')
    .map((line) => line.trim())
    .filter((line) => line.length > 0);
};

// Process array fields
const aliases = splitLines(acf.aliases);
const searcherQueries = splitLines(acf.searcher_queries);
const visibleSymptoms = splitLines(acf.visible_symptoms);
const droppedFiles = splitLines(acf.dropped_files);
const companionFiles = splitLines(acf.companion_files);
const behaviors = Array.isArray(acf.behaviors) ? acf.behaviors : [];
const cloakingTargets = Array.isArray(acf.cloaking_targets)
  ? acf.cloaking_targets
  : [];

// Generate Dynamic FAQ Schema based on searcher_queries
const faqSchema =
  searcherQueries.length > 0 && acf.quick_answer
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: searcherQueries.map((query) => ({
          '@type': 'Question',
          name: query,
          acceptedAnswer: {
            '@type': 'Answer',
            text: acf.quick_answer,
          },
        })),
      }
    : null;

const seoTitle = `${acf.plugin_display_name || plugin.title} - Malware Removal & Analysis`;
const seoDesc =
  acf.quick_answer ||
  `Details, removal instructions, and indicators of compromise for the ${acf.plugin_display_name} fake WordPress plugin.`;
---

<Layout
  title={seoTitle}
  description={seoDesc}
  image='/images/security-opengraph-image.png'>
  {
    faqSchema && (
      <script type='application/ld+json' set:html={JSON.stringify(faqSchema)} />
    )
  }

  <ComponentWrapper class='pt-12 pb-16 md:pb-24'>
    {/* --- HEADER --- */}
    <header class='mb-10 pb-8 border-slate-700/60 border-b'>
      <div class='flex items-center gap-2 mb-3'>
        <ShieldAlert class='w-5 h-5 text-red-500' />
        <span
          class='font-semibold text-red-400 text-sm uppercase tracking-wider'>
          Malware Advisory
        </span>
        {
          acf.severity && (
            <span
              class={`ml-3 px-2 py-0.5 text-xs font-bold uppercase rounded ${acf.severity.toLowerCase() === 'high' || acf.severity.toLowerCase() === 'critical' ? 'bg-red-900/80 text-red-200' : 'bg-orange-900/80 text-orange-200'}`}>
              {acf.severity} Severity
            </span>
          )
        }
      </div>
      <h1 class='mb-4 font-bold text-white text-3xl md:text-5xl'>
        {acf.plugin_display_name || plugin.title}
        {
          acf.fake_version && (
            <span class='ml-2 font-mono text-slate-500 text-2xl'>
              v{acf.fake_version}
            </span>
          )
        }
      </h1>
      <div class='flex flex-wrap items-center gap-4 text-slate-300 text-lg'>
        <span class='flex items-center gap-2'>
          <FolderKey class='w-5 h-5 text-slate-400' />
          <code class='bg-slate-800 px-2 py-1 rounded text-slate-200 text-base'>
            /{acf.plugin_folder_name || 'unknown'}/
          </code>
        </span>
      </div>
    </header>

    <div class='gap-10 grid grid-cols-1 lg:grid-cols-3'>
      {/* --- MAIN CONTENT COLUMN --- */}
      <div class='space-y-12 lg:col-span-2'>
        {/* AI Overview Box */}
        {
          acf.quick_answer && (
            <section class='bg-blue-950/30 p-6 border-blue-500 border-l-4 rounded-r-lg'>
              <h2 class='flex items-center gap-2 mb-2 font-semibold text-blue-400 text-lg'>
                <AlertTriangle class='w-5 h-5' />
                Quick Answer
              </h2>
              <p class='text-slate-300 leading-relaxed'>{acf.quick_answer}</p>
            </section>
          )
        }

        {/* Primary Purpose & Behavior (Merged Section) */}
        {
          (acf.primary_purpose || behaviors.length > 0) && (
            <section>
              <h2 class='flex items-center gap-2 mb-4 pb-2 border-slate-700/60 border-b font-bold text-white text-2xl'>
                <Activity class='w-6 h-6 text-slate-400' />
                Threat Behavior & Purpose
              </h2>
              {acf.primary_purpose && (
                <p class='mb-6 text-slate-300 leading-relaxed'>
                  {acf.primary_purpose}
                </p>
              )}

              <div class='flex flex-wrap gap-2 mb-4'>
                {behaviors.map((behavior: string) => (
                  <span class='bg-slate-800 px-3 py-1 border border-slate-700 rounded-full text-slate-300 text-sm'>
                    {behavior}
                  </span>
                ))}
              </div>

              {cloakingTargets.length > 0 && (
                <div class='bg-slate-800/40 mt-4 p-4 border border-slate-700/60 rounded-lg'>
                  <span class='block mb-2 font-semibold text-slate-400 text-sm uppercase tracking-wider'>
                    Search Engine Cloaking Targets:
                  </span>
                  <div class='flex flex-wrap gap-2'>
                    {cloakingTargets.map((target: string) => (
                      <span class='bg-indigo-950/50 px-2 py-1 border border-indigo-900/50 rounded text-indigo-300 text-xs'>
                        {target}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </section>
          )
        }

        {/* Technical Details Grid */}
        <section class='gap-4 grid grid-cols-1 sm:grid-cols-2'>
          <div
            class='bg-slate-800/40 p-5 border border-slate-700/60 rounded-lg'>
            <h3
              class='mb-1 font-medium text-slate-400 text-sm uppercase tracking-wider'>
              Main File
            </h3>
            <p class='font-mono text-slate-200 text-sm break-words'>
              {acf.plugin_main_file || 'N/A'}
            </p>
          </div>
          <div
            class='bg-slate-800/40 p-5 border border-slate-700/60 rounded-lg'>
            <h3
              class='mb-1 font-medium text-slate-400 text-sm uppercase tracking-wider'>
              Fake Author
            </h3>
            {
              acf.fake_author_uri ? (
                <p class='text-blue-400 hover:underline break-words'>
                  <a
                    href={acf.fake_author_uri.replace(/[\[\]\(\)]/g, '')}
                    target='_blank'
                    rel='nofollow noreferrer'>
                    {acf.fake_author}
                  </a>
                </p>
              ) : (
                <p class='text-slate-200'>{acf.fake_author || 'None'}</p>
              )
            }
          </div>
          <div
            class='sm:col-span-2 bg-slate-800/40 p-5 border border-slate-700/60 rounded-lg'>
            <h3
              class='mb-1 font-medium text-slate-400 text-sm uppercase tracking-wider'>
              Full Installation Path
            </h3>
            <p class='font-mono text-slate-200 text-sm break-words'>
              {
                acf.plugin_full_path ||
                  acf.install_location ||
                  'wp-content/plugins/'
              }
            </p>
          </div>
          <div
            class='sm:col-span-2 bg-slate-800/40 p-5 border border-slate-700/60 rounded-lg'>
            <h3
              class='mb-1 font-medium text-slate-400 text-sm uppercase tracking-wider'>
              Malware Family
            </h3>
            <span
              class='inline-block bg-red-950/50 mt-1 px-3 py-1 border border-red-900/50 rounded font-medium text-red-400 text-sm'>
              {acf.malware_family || 'Unknown'}
            </span>
          </div>
        </section>

        {/* Malicious Code Example */}
        {
          acf.malicious_code_example && (
            <section>
              <h2 class='flex items-center gap-2 mb-4 pb-2 border-slate-700/60 border-b font-bold text-white text-2xl'>
                <FileCode2 class='w-6 h-6 text-slate-400' />
                Malicious Code Signature
              </h2>
              <p class='mb-4 text-slate-300'>
                If you find the following code signature in your files, your
                site is compromised:
              </p>
              <div class='bg-[#0d1117] p-4 border border-slate-700/60 rounded-lg overflow-x-auto'>
                <pre>
                  <code class='font-mono text-slate-300 text-sm whitespace-pre'>
                    {acf.malicious_code_example}
                  </code>
                </pre>
              </div>
            </section>
          )
        }

        {/* Detection Commands (Grep, SQL, WPCLI) */}
        {
          (acf.grep_commands || acf.sql_queries || acf.wpcli_commands) && (
            <section>
              <h2 class='flex items-center gap-2 mb-4 pb-2 border-slate-700/60 border-b font-bold text-white text-2xl'>
                <Terminal class='w-6 h-6 text-slate-400' />
                Detection & Triage Commands
              </h2>
              <div class='space-y-4'>
                {acf.grep_commands && (
                  <div>
                    <h3 class='mb-2 font-semibold text-slate-400 text-sm'>
                      Server-Side Search (Grep)
                    </h3>
                    <div class='bg-[#0d1117] p-4 border border-slate-700/60 rounded-lg overflow-x-auto'>
                      <pre>
                        <code class='font-mono text-green-400 text-sm'>
                          {acf.grep_commands}
                        </code>
                      </pre>
                    </div>
                  </div>
                )}
                {acf.wpcli_commands && (
                  <div>
                    <h3 class='mb-2 font-semibold text-slate-400 text-sm'>
                      WP-CLI Command
                    </h3>
                    <div class='bg-[#0d1117] p-4 border border-slate-700/60 rounded-lg overflow-x-auto'>
                      <pre>
                        <code class='font-mono text-blue-400 text-sm'>
                          {acf.wpcli_commands}
                        </code>
                      </pre>
                    </div>
                  </div>
                )}
                {acf.sql_queries && (
                  <div>
                    <h3 class='mb-2 font-semibold text-slate-400 text-sm'>
                      Database Query (SQL)
                    </h3>
                    <div class='bg-[#0d1117] p-4 border border-slate-700/60 rounded-lg overflow-x-auto'>
                      <pre>
                        <code class='font-mono text-purple-400 text-sm'>
                          {acf.sql_queries}
                        </code>
                      </pre>
                    </div>
                  </div>
                )}
              </div>
            </section>
          )
        }

        {/* Removal Instructions */}
        {
          acf.removal_steps && (
            <section>
              <h2 class='flex items-center gap-2 mb-4 pb-2 border-slate-700/60 border-b font-bold text-white text-2xl'>
                <Trash2 class='w-6 h-6 text-slate-400' />
                Removal Protocol
              </h2>

              <div class='flex flex-wrap gap-4 mb-6'>
                {acf.removal_difficulty && (
                  <span class='flex items-center gap-2 bg-slate-800 px-3 py-1 border border-slate-700 rounded text-slate-300 text-sm'>
                    <strong>Difficulty:</strong> {acf.removal_difficulty}
                  </span>
                )}
                {acf.recurrence_risk && (
                  <span class='flex items-center gap-2 bg-slate-800 px-3 py-1 border border-slate-700 rounded text-slate-300 text-sm'>
                    <strong>Recurrence Risk:</strong> {acf.recurrence_risk}
                  </span>
                )}
                {acf.requires_database_cleanup && (
                  <span class='flex items-center gap-2 bg-amber-950/40 px-3 py-1 border border-amber-900/50 rounded text-amber-400 text-sm'>
                    <Database class='w-4 h-4' /> Requires DB Cleanup
                  </span>
                )}
              </div>

              {/* Render WYSIWYG HTML steps */}
              <div
                class='prose-invert max-w-none marker:text-slate-400 prose-li:text-slate-300 prose prose-slate'
                set:html={acf.removal_steps}
              />
            </section>
          )
        }

        {/* Evidence Gallery */}
        {
          acf.screenshots && acf.screenshots.length > 0 && (
            <section>
              <h2 class='mb-4 pb-2 border-slate-700/60 border-b font-bold text-white text-2xl'>
                Evidence & Screenshots
              </h2>
              <div class='gap-4 grid grid-cols-1 sm:grid-cols-2 mt-4'>
                {acf.screenshots.map((image: any) => {
                  // Safely grab the full image URL from the complex ACF object
                  const imgSrc =
                    image.full_image_url ||
                    image.url ||
                    (typeof image === 'string' ? image : null);
                  if (!imgSrc) return null;

                  return (
                    <img
                      src={imgSrc}
                      alt={
                        image.alt_text ||
                        image.title ||
                        `Screenshot of ${acf.plugin_display_name} malware`
                      }
                      class='shadow-lg border border-slate-700/60 rounded-lg w-full h-auto object-cover'
                      loading='lazy'
                    />
                  );
                })}
              </div>
            </section>
          )
        }
      </div>

      {/* --- SIDEBAR --- */}
      <aside class='space-y-6'>
        {/* Aliases */}
        {
          aliases.length > 0 && (
            <div class='bg-slate-800/30 p-6 border border-slate-700/60 rounded-lg'>
              <h3 class='flex items-center gap-2 mb-4 font-semibold text-white'>
                <UserX class='w-5 h-5 text-slate-400' />
                Also Known As
              </h3>
              <ul class='space-y-2'>
                {aliases.map((alias) => (
                  <li class='flex items-start gap-2 text-slate-300'>
                    <span class='mt-1 text-slate-500'>↳</span>
                    {alias}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {/* Visible Symptoms */}
        {
          visibleSymptoms.length > 0 && (
            <div class='bg-slate-800/30 p-6 border border-slate-700/60 rounded-lg'>
              <h3 class='flex items-center gap-2 mb-4 font-semibold text-white'>
                <Stethoscope class='w-5 h-5 text-slate-400' />
                Visible Symptoms
              </h3>
              <ul class='space-y-2'>
                {visibleSymptoms.map((symptom) => (
                  <li class='flex items-start gap-2 text-slate-300 text-sm'>
                    <span class='mt-1 text-red-500'>•</span>
                    {symptom}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {/* Dropped & Companion Files */}
        {
          (droppedFiles.length > 0 || companionFiles.length > 0) && (
            <div class='bg-slate-800/30 p-6 border border-slate-700/60 rounded-lg'>
              <h3 class='flex items-center gap-2 mb-4 font-semibold text-white'>
                <Bug class='w-5 h-5 text-slate-400' />
                Associated Files
              </h3>

              {droppedFiles.length > 0 && (
                <div class='mb-4'>
                  <span class='block mb-2 font-semibold text-slate-500 text-xs uppercase'>
                    Dropped Files:
                  </span>
                  <ul class='space-y-1'>
                    {droppedFiles.map((file) => (
                      <li class='font-mono text-slate-300 text-xs break-all'>
                        {file}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {companionFiles.length > 0 && (
                <div>
                  <span class='block mb-2 font-semibold text-slate-500 text-xs uppercase'>
                    Companion Files:
                  </span>
                  <ul class='space-y-1'>
                    {companionFiles.map((file) => (
                      <li class='font-mono text-slate-300 text-xs break-all'>
                        {file}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          )
        }

        {/* Searcher Queries (SEO list) */}
        {
          searcherQueries.length > 0 && (
            <div class='bg-slate-800/30 p-6 border border-slate-700/60 rounded-lg'>
              <h3 class='mb-4 font-semibold text-white'>Common Searches</h3>
              <ul class='space-y-3'>
                {searcherQueries.map((query) => (
                  <li class='text-slate-400 text-sm italic'>"{query}"</li>
                ))}
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </ComponentWrapper>
</Layout>

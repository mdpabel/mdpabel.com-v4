---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ComponentWrapper from '../../components/component-wrapper.astro';

export async function getStaticPaths() {
  const threats = await getCollection('wordpress-threats');
  return threats.map((entry) => ({
    params: { slug: entry.data.slug || entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'wordpress-threats'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data as Record<string, any>;

const asString = (value: unknown): string => {
  if (typeof value === 'string') return value.trim();
  if (typeof value === 'number') return String(value);
  return '';
};

const asArray = (value: unknown): string[] => {
  if (Array.isArray(value)) {
    return value
      .flatMap((item) => (typeof item === 'string' ? [item.trim()] : []))
      .filter(Boolean);
  }
  if (typeof value === 'string' && value.trim()) return [value.trim()];
  return [];
};

const hasValue = (value: unknown): boolean => {
  if (Array.isArray(value)) return value.length > 0;
  if (typeof value === 'string') return value.trim().length > 0;
  return value !== null && value !== undefined && value !== false;
};

const title = asString(data.title) || 'Threat Report';
const description =
  asString(data.description) ||
  'Detailed analysis of WordPress threats, malware behavior, persistence, and cleanup guidance.';
const reportDate = asString(data.reportDate);
const severity = asString(data.severity) || 'Unknown';
const threatType = asString(data.threatType);
const vtScore = asString(data.vtScore);
const vtLink = asString(data.vtLink);
const fileHash = asString(data.fileHash);
const reportType = asString(data.reportType);
const sampleScope = asString(data.sampleScope);

const screenshots = asArray(data.screenshots);
const detectedPaths = asArray(data.detectedPaths);
const affectedComponents = asArray(data.affectedComponents);
const entryPoints = asArray(data.entryPoints);
const persistencePoints = asArray(data.persistencePoints);

const impact = asString(data.impact);
const seenOn = asString(data.seenOn);
const behavior = asString(data.behavior);
const difficulty = asString(data.difficulty);
const recurrence = asString(data.recurrence);
const numberOfSiteFixed = asString(data.numberOfSiteFixed);

const isFUD =
  vtScore.includes('0/') ||
  vtScore.toLowerCase().includes('undetected') ||
  vtScore.toLowerCase().includes('fully undetected');
const isZeroDay =
  vtScore.toLowerCase().includes('zero-day') ||
  vtScore.toLowerCase().includes('unique');

const severityColor =
  severity === 'Critical'
    ? 'border-red-800 bg-red-900/40 text-red-300'
    : severity === 'High'
      ? 'border-orange-800 bg-orange-900/40 text-orange-300'
      : severity === 'Medium'
        ? 'border-amber-800 bg-amber-900/40 text-amber-300'
        : 'border-blue-800 bg-blue-900/40 text-blue-300';

const difficultyColor =
  difficulty === 'Hard'
    ? 'text-red-400'
    : difficulty === 'Moderate'
      ? 'text-orange-400'
      : difficulty === 'Easy'
        ? 'text-green-400'
        : 'text-slate-200';

const metaCards = [
  {
    label: 'Impact Radius',
    value: seenOn || impact || '',
    tone: 'text-white',
  },
  {
    label: 'Removal Difficulty',
    value: difficulty,
    tone: difficultyColor,
  },
  {
    label: 'Recurrence',
    value: recurrence,
    tone: 'text-white',
  },
  {
    label: 'Key Symptom',
    value: behavior,
    tone: 'text-slate-300',
    small: true,
  },
  {
    label: 'Report Type',
    value: reportType,
    tone: 'text-white',
  },
  {
    label: 'Sample Scope',
    value: sampleScope,
    tone: 'text-slate-300',
    small: true,
  },
  {
    label: 'Sites / Cases',
    value: numberOfSiteFixed,
    tone: 'text-white',
  },
  {
    label: 'VirusTotal',
    value: vtScore,
    tone: 'text-white',
  },
].filter((card) => hasValue(card.value));

const technicalLists = [
  { title: 'Detected Paths', items: detectedPaths },
  { title: 'Affected Components', items: affectedComponents },
  { title: 'Entry Points', items: entryPoints },
  { title: 'Persistence Points', items: persistencePoints },
].filter((section) => section.items.length > 0);

const proseClasses =
  'prose prose-slate prose-invert max-w-none ' +
  'prose-headings:mb-4 prose-headings:border-slate-800 prose-headings:pb-2 prose-headings:font-bold prose-headings:text-white prose-headings:break-words md:prose-headings:border-b ' +
  'prose-h2:mt-10 prose-h3:mt-8 ' +
  'prose-p:text-slate-300 prose-p:leading-7 prose-p:break-words prose-p:[overflow-wrap:anywhere] ' +
  'prose-strong:text-white prose-strong:break-words ' +
  'prose-a:text-blue-400 prose-a:no-underline prose-a:break-all hover:prose-a:text-blue-300 ' +
  'prose-ul:text-slate-300 prose-ol:text-slate-300 prose-li:my-1 prose-li:break-words prose-li:[overflow-wrap:anywhere] ' +
  'prose-code:break-all prose-code:rounded prose-code:bg-slate-900 prose-code:px-1 prose-code:py-0.5 prose-code:text-pink-400 ' +
  'prose-pre:max-w-full prose-pre:overflow-x-auto prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-800 prose-pre:bg-slate-950 prose-pre:p-4 md:prose-pre:p-5 ' +
  'prose-img:max-w-full prose-img:rounded-2xl prose-img:border prose-img:border-slate-800 prose-img:shadow-lg';
---

<Layout title={`${title} | Threat Report`} description={description}>
  <ComponentWrapper
    class='mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10 lg:py-12 max-w-full overflow-x-hidden'>
    <header
      class='bg-slate-950/70 mb-8 p-5 sm:p-6 lg:p-8 border border-slate-800 rounded-3xl'>
      <div class='flex flex-wrap items-start gap-2 sm:gap-3 mb-4'>
        <span
          class={`rounded-full border px-3 py-1 text-[11px] font-bold uppercase tracking-[0.18em] ${severityColor}`}>
          {severity}
        </span>

        {
          hasValue(threatType) && (
            <span class='bg-slate-900 px-3 py-1 border border-slate-700 rounded-full font-medium text-[11px] text-slate-300 uppercase tracking-[0.18em]'>
              {threatType}
            </span>
          )
        }

        {
          isFUD && hasValue(vtLink) && (
            <a
              href={vtLink}
              target='_blank'
              rel='noopener noreferrer'
              class='bg-purple-900/40 hover:bg-purple-900/60 px-3 py-1 border border-purple-800 rounded-full font-bold text-[11px] text-purple-300 uppercase tracking-[0.18em] transition'>
              Fully Undetected
            </a>
          )
        }

        {
          isZeroDay && (
            <span class='bg-slate-800 px-3 py-1 border border-slate-700 rounded-full font-bold text-[11px] text-white uppercase tracking-[0.18em]'>
              Zero-Day Variant
            </span>
          )
        }
      </div>

      <h1
        class='max-w-4xl font-extrabold text-white text-2xl sm:text-3xl lg:text-4xl break-words leading-tight'>
        {title}
      </h1>

      {
        hasValue(description) && (
          <p class='mt-4 max-w-4xl text-slate-300 text-sm sm:text-base break-words leading-6 [overflow-wrap:anywhere]'>
            {description}
          </p>
        )
      }

      <div
        class='flex flex-wrap gap-x-4 gap-y-2 mt-5 text-slate-400 text-xs sm:text-sm'>
        {
          hasValue(fileHash) && (
            <span class='break-all'>Case ID: {fileHash}</span>
          )
        }
        {hasValue(reportDate) && <span>Detected: {reportDate}</span>}
        {hasValue(reportType) && <span>Type: {reportType}</span>}
      </div>
    </header>

    {
      metaCards.length > 0 && (
        <section class='gap-4 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 mb-8'>
          {metaCards.map((card) => (
            <div
              class={`rounded-2xl border border-slate-800 bg-slate-900 p-4 ${card.small ? 'xl:col-span-2' : ''}`}>
              <span class='block mb-2 text-[11px] text-slate-500 uppercase tracking-[0.18em]'>
                {card.label}
              </span>
              <div
                class={`break-words leading-relaxed [overflow-wrap:anywhere] ${card.small ? 'text-sm' : 'text-base sm:text-lg'} ${card.tone}`}>
                {card.value}
              </div>
            </div>
          ))}
        </section>
      )
    }

    {
      technicalLists.length > 0 && (
        <section class='bg-slate-950/60 mb-10 p-5 sm:p-6 border border-slate-800 rounded-3xl'>
          <div class='flex flex-wrap justify-between items-center gap-3 mb-5'>
            <h2 class='font-bold text-white text-lg sm:text-xl'>
              Threat Overview
            </h2>
            {hasValue(vtLink) && hasValue(vtScore) && (
              <a
                href={vtLink}
                target='_blank'
                rel='noopener noreferrer'
                class='font-medium text-blue-400 hover:text-blue-300 text-xs sm:text-sm break-all transition'>
                VirusTotal: {vtScore}
              </a>
            )}
          </div>

          <div class='gap-4 grid grid-cols-1 lg:grid-cols-2'>
            {technicalLists.map((section) => (
              <div class='bg-slate-900/80 p-4 border border-slate-800 rounded-2xl'>
                <h3 class='mb-3 font-semibold text-slate-400 text-sm uppercase tracking-[0.18em]'>
                  {section.title}
                </h3>
                <ul class='space-y-2 text-slate-300 text-sm leading-6'>
                  {section.items.map((item) => (
                    <li class='flex gap-2'>
                      <span class='bg-blue-400 mt-2 rounded-full w-1.5 h-1.5 shrink-0' />
                      <span class='break-words [overflow-wrap:anywhere]'>
                        {item}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      screenshots.length > 0 && (
        <section class='mb-10'>
          <div class='flex flex-wrap justify-between items-center gap-3 mb-4'>
            <h2 class='font-bold text-slate-400 text-sm uppercase tracking-[0.18em]'>
              Evidence Screenshots
            </h2>
            <span class='text-slate-500 text-xs sm:text-sm'>
              {screenshots.length} image{screenshots.length === 1 ? '' : 's'}
            </span>
          </div>

          <div class='gap-4 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3'>
            {screenshots.map((img, index) => (
              <a
                href={img}
                target='_blank'
                rel='noopener noreferrer'
                class='group bg-slate-900 border border-slate-800 hover:border-slate-600 rounded-2xl overflow-hidden transition'>
                <img
                  src={img}
                  alt={`${title} screenshot ${index + 1}`}
                  loading='lazy'
                  class='w-full h-56 sm:h-64 object-cover group-hover:scale-[1.02] transition duration-300'
                />
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class='gap-8 grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_320px]'>
      <article
        class={`${proseClasses} min-w-0 max-w-full overflow-x-hidden break-words [overflow-wrap:anywhere]`}>
        <Content />
      </article>

      <aside class='xl:top-24 xl:sticky xl:self-start space-y-4'>
        {
          hasValue(vtScore) && (
            <div class='bg-slate-950/70 p-5 border border-slate-800 rounded-2xl'>
              <h3 class='mb-2 font-bold text-slate-400 text-sm uppercase tracking-[0.18em]'>
                Detection Status
              </h3>
              <p class='text-slate-300 text-sm break-words leading-6 [overflow-wrap:anywhere]'>
                {vtScore}
              </p>
            </div>
          )
        }

        {
          detectedPaths.length > 0 && (
            <div class='bg-slate-950/70 p-5 border border-slate-800 rounded-2xl'>
              <h3 class='mb-3 font-bold text-slate-400 text-sm uppercase tracking-[0.18em]'>
                Sample Files
              </h3>
              <ul class='space-y-2 text-slate-300 text-sm'>
                {detectedPaths.slice(0, 8).map((item) => (
                  <li class='bg-slate-900 px-3 py-2 rounded-lg break-words [overflow-wrap:anywhere]'>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div
          class='bg-slate-900 p-5 border border-slate-800 rounded-2xl text-center'>
          <h3 class='mb-2 font-bold text-white text-lg'>
            Need help removing this?
          </h3>
          <p
            class='mb-5 text-slate-400 text-sm break-words leading-6 [overflow-wrap:anywhere]'>
            {
              hasValue(difficulty) ? (
                <>
                  This threat is rated{' '}
                  <span class='font-semibold text-white'>{difficulty}</span>{' '}
                  difficulty. If you are unsure, avoid partial cleanup.
                </>
              ) : (
                'If you are unsure, avoid partial cleanup. These infections often persist through hidden loaders, fake plugins, or modified theme files.'
              )
            }
          </p>
          <a
            href='/hire-me/'
            class='inline-flex justify-center items-center bg-blue-600 hover:bg-blue-500 px-5 py-3 rounded-xl w-full font-bold text-white text-sm transition'>
            Hire MD Pabel for Cleanup
          </a>
        </div>
      </aside>
    </section>
  </ComponentWrapper>
</Layout>

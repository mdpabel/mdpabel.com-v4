---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import RelatedInternalLinks from '../components/RelatedInternalLinks.astro';
import { TESTIMONIALS } from '../data/testimonials';
import {
  AlertTriangle,
  ArrowRight,
  Award,
  Bug,
  Check,
  CheckCircle,
  ChevronDown,
  Clock,
  Code,
  Database,
  ExternalLink,
  FileCheck,
  FileSearch,
  Globe,
  HelpCircle,
  HeartHandshake,
  Link2,
  Lock,
  MessageSquare,
  RefreshCw,
  Search,
  SearchX,
  ShieldAlert,
  ShieldCheck,
  Star,
  Trash2,
  Users,
  Zap,
  ScanSearch,
} from '@lucide/astro';

// --- 1. SEO DATA ---
const seo = {
  title: 'Japanese Keyword Hack Removal Service | Fix Japanese SEO Spam Fast',
  description:
    'Remove the Japanese keyword hack & Japanese SEO spam from your WordPress site in 24–72 hours. 4,500+ sites cleaned, deindex spam URLs, money-back guarantee.',
  image: '/md-pabel.png',
  canonical: 'https://www.mdpabel.com/remove-japanese-seo-spam/',
};

// If your Layout component supports canonical URLs, pass canonical={seo.canonical} below.

const stripHtml = (value: string) => value.replace(/<[^>]*>/g, '');

// --- 2. FAQ CONTENT + FAQ SCHEMA SOURCE ---
const faqs = [
  {
    q: 'What is the Japanese keyword hack?',
    a: 'The Japanese keyword hack is a hacked-site SEO spam infection where attackers inject Japanese text, fake product pages, spam sitemaps, or cloaked URLs into your WordPress site so they can abuse your domain authority in Google.',
  },
  {
    q: 'Is Japanese SEO spam the same as the Japanese keyword hack?',
    a: 'Usually, yes. Many site owners call it <strong>Japanese SEO spam</strong>, while many security guides and search queries use <strong>Japanese keyword hack</strong>. This service covers both the malware cleanup and the search-result recovery work.',
  },
  {
    q: 'How fast can you remove Japanese SEO spam from WordPress?',
    a: 'Most Japanese keyword hack cleanups take <strong>24–72 hours</strong>, depending on how many spam URLs were generated, whether the infection is cloaked, and whether the attacker left persistence in files, database rows, cron jobs, or fake plugins.',
  },
  {
    q: 'Why does my website look normal but Google shows Japanese pages?',
    a: 'That usually means the infection is cloaked. The malware can show your normal website to you while serving spam content to Googlebot, mobile visitors, or users arriving from search results.',
  },
  {
    q: 'Can a plugin remove the Japanese keyword hack completely?',
    a: 'Plugins can detect some known signatures, but large Japanese spam infections often involve database spam, fake plugins, hidden PHP, modified .htaccess rules, cron-based persistence, or cloaking logic. I clean these manually instead of relying only on scanner output.',
  },
  {
    q: 'Can you remove the spam URLs from Google?',
    a: 'Yes. After the malware generator is removed and the vulnerability is fixed, I help with search cleanup: spam URL discovery, sitemap cleanup, proper 404/410 handling where appropriate, Search Console validation, and deindexing guidance.',
  },
  {
    q: 'Will my rankings recover after cleanup?',
    a: 'Cleanup gives your site the best chance to recover, but rankings depend on the size of the infection, how long the spam was indexed, whether Google applied a security/manual action, and how quickly the site is stabilized. I do not promise fake instant recovery.',
  },
  {
    q: 'What if the Japanese spam comes back after cleanup?',
    a: 'Every cleanup focuses on the root cause, not just visible spam files. I look for persistence points and patch the entry point so the infection does not regenerate. If the same infection returns during the coverage window, I re-check and re-clean it.',
  },
  {
    q: 'Do you only clean WordPress Japanese keyword hacks?',
    a: 'WordPress is my main specialty, especially hacked sites with cloaking, fake plugins, redirects, database spam, and search-result pollution. I can also help with other PHP-based websites and shared hosting environments when the issue is similar.',
  },
];

// --- 3. SCHEMA ---
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${seo.canonical}#service`,
  name: 'Japanese Keyword Hack Removal Service',
  alternateName: [
    'Japanese SEO Spam Cleanup',
    'WordPress Japanese Keyword Hack Removal',
    'Japanese SEO Spam Removal Service',
  ],
  serviceType: 'WordPress Japanese Keyword Hack Removal',
  url: seo.canonical,
  description: seo.description,
  provider: {
    '@type': 'Person',
    name: 'MD Pabel',
    url: 'https://www.mdpabel.com',
    jobTitle: 'WordPress Security Specialist',
    image: 'https://www.mdpabel.com/md-pabel.png',
    sameAs: [
      'https://www.linkedin.com/in/mdpabel',
      'https://github.com/mdpabel',
      'https://web.facebook.com/mdpabelwpsecurity',
    ],
  },
  areaServed: 'Worldwide',
  audience: {
    '@type': 'Audience',
    audienceType:
      'WordPress website owners with Japanese SEO spam or hacked search results',
  },
  offers: {
    '@type': 'Offer',
    price: '89.00',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: 'https://www.mdpabel.com/hire-me/',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${seo.canonical}#faq`,
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: stripHtml(faq.a),
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${seo.canonical}#breadcrumb`,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://www.mdpabel.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'WordPress Malware Removal',
      item: 'https://www.mdpabel.com/wordpress-malware-removal/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Japanese Keyword Hack Removal',
      item: seo.canonical,
    },
  ],
};

// --- 4. STYLE HELPERS ---
const btnBase =
  'inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-slate-950 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 h-11 px-8';
const btnDefault =
  'bg-emerald-600 text-white hover:bg-emerald-700 shadow-md shadow-emerald-950/20';
const btnOutline =
  'border border-slate-800 bg-slate-950/60 hover:bg-slate-800 text-slate-50';

// --- 5. CONTENT DATA ---
const TRUST_STATS = [
  { value: '4,500+', label: 'Hacked Sites Cleaned', icon: ShieldCheck },
  { value: '24–72h', label: 'Typical Cleanup Window', icon: Clock },
  { value: '8+ yrs', label: 'Security Experience', icon: Award },
  { value: '2,300+', label: 'Clients Served', icon: Users },
];

const SYMPTOMS = [
  {
    icon: SearchX,
    title: 'Japanese titles in Google',
    desc: 'Your site looks normal, but Google shows Japanese characters, fake products, or weird snippets.',
  },
  {
    icon: Link2,
    title: 'URLs you never created',
    desc: 'Random folders, fake product pages, tag URLs, or spam pages appear in Google Search Console.',
  },
  {
    icon: ShieldAlert,
    title: 'Cloaking or bot-only spam',
    desc: 'Googlebot sees spam while direct visitors see your normal website.',
  },
  {
    icon: Database,
    title: 'Database SEO spam',
    desc: 'Spam content hides in wp_posts, wp_options, wp_postmeta, or injected menu/widget content.',
  },
  {
    icon: FileSearch,
    title: 'Spam sitemap pollution',
    desc: 'Your sitemap includes URLs you never published, or new spam URLs keep getting generated.',
  },
  {
    icon: Bug,
    title: 'Fake plugin or hidden PHP',
    desc: 'Attackers leave malicious files in plugins, themes, uploads, cache folders, or the site root.',
  },
  {
    icon: Globe,
    title: 'Traffic or ranking crash',
    desc: 'Organic traffic drops after Google indexes hacked Japanese keyword pages instead of your real content.',
  },
  {
    icon: AlertTriangle,
    title: 'Security warnings',
    desc: 'Search Console, browsers, or security scanners flag hacked content, malware, or unsafe pages.',
  },
  {
    icon: RefreshCw,
    title: 'Spam keeps coming back',
    desc: 'You deleted files once, but the spam returned because the root cause or persistence was missed.',
  },
];

const INCLUDED = [
  {
    icon: ScanSearch,
    title: 'Japanese spam diagnosis',
    desc: 'I confirm whether the issue is Japanese keyword hack, cloaked SEO spam, redirects, fake product URLs, or a broader hacked-site infection.',
  },
  {
    icon: Code,
    title: 'Manual file cleanup',
    desc: 'I remove malicious PHP, modified core files, fake plugins, rogue scripts, and suspicious files without deleting your real content.',
  },
  {
    icon: Database,
    title: 'Database spam cleanup',
    desc: 'I check common WordPress database locations where SEO spam hides, including posts, options, metadata, widgets, and injected links.',
  },
  {
    icon: ShieldAlert,
    title: 'Cloaking detection',
    desc: 'I compare what normal visitors, mobile users, and search bots may see so hidden spam does not survive cleanup.',
  },
  {
    icon: Trash2,
    title: 'Spam URL control',
    desc: 'I help stop new spam URLs, clean bad sitemaps, and guide the right 404/410/deindexing path after the malware is removed.',
  },
  {
    icon: Lock,
    title: 'Hardening after cleanup',
    desc: 'I patch the entry point, remove persistence, audit users, and harden the site so the same hack does not return.',
  },
];

const PROCESS_STEPS = [
  {
    icon: Search,
    step: 'Step 1',
    title: 'Diagnose the spam footprint',
    desc: 'I inspect indexed URLs, sitemaps, Search Console symptoms, bot-facing output, files, database rows, and hosting-level clues.',
  },
  {
    icon: Trash2,
    step: 'Step 2',
    title: 'Manually remove the malware',
    desc: 'I clean infected files, hidden PHP, fake plugins, spam injections, database content, .htaccess rules, and modified WordPress components.',
  },
  {
    icon: Bug,
    step: 'Step 3',
    title: 'Remove persistence and patch the cause',
    desc: 'I hunt down backdoors, rogue admin users, malicious cron jobs, writable folders, nulled themes, outdated plugins, and other re-entry points.',
  },
  {
    icon: Globe,
    step: 'Step 4',
    title: 'Deindex and suppress spam URLs',
    desc: 'After the site is clean, I help remove spam signals with sitemap cleanup, correct status codes, Search Console actions, and deindexing guidance.',
  },
  {
    icon: FileCheck,
    step: 'Step 5',
    title: 'Verify clean state',
    desc: 'I re-check the site from multiple angles so hidden cloaking, reinfection triggers, and search-side spam are not left behind.',
  },
  {
    icon: ShieldCheck,
    step: 'Step 6',
    title: 'Harden and stabilize recovery',
    desc: 'I give you practical hardening steps and a change summary so your site has the best chance of recovering search trust.',
  },
];

const CASE_STUDIES = [
  {
    icon: FileSearch,
    title: '50,000+ spam URLs cleanup case study',
    desc: 'Large-scale spam URL recovery showing how hacked URLs were cleaned and search damage was handled.',
    href: '/blog/how-i-removed-50000-spam-urls-and-saved-a-hacked-website-the-ultimate-guide/',
  },
  {
    icon: Globe,
    title: '242,000 Japanese spam pages recovery',
    desc: 'A real Japanese SEO spam case study focused on search damage, index cleanup, and technical recovery.',
    href: '/blog/recovering-from-seo-spam-how-we-cleared-242000-japanese-spam-pages-from-a-hacked-wordpress-site-in-2025/',
  },
  {
    icon: Zap,
    title: 'Japanese keyword hack technical guide',
    desc: 'A deep technical walkthrough for site owners who want to understand detection, removal, and prevention.',
    href: '/blog/japanese-keyword-hack-the-complete-guide-to-detection-removal-prevention-in-2025/',
  },
];

const RELATED_SERVICES = [
  {
    title: 'WordPress Malware Removal',
    desc: 'Full hacked-site cleanup when the Japanese spam is part of a broader infection.',
    href: '/wordpress-malware-removal/',
  },
  {
    title: 'Google Blacklist Removal',
    desc: 'Help with browser warnings, hacked content warnings, and Google Safe Browsing issues.',
    href: '/google-blacklist-removal-service/',
  },
  {
    title: 'Blacklist Removal Service',
    desc: 'Remove warnings from Google, McAfee, Norton, Avast, and other security vendors.',
    href: '/blacklist-removal/',
  },
  {
    title: 'WordPress Pharma Hack Fix',
    desc: 'Cleanup for pharmaceutical SEO spam, fake product pages, and cloaked spam content.',
    href: '/blog/wordpress-pharma-hack-fix-how-to-stop-pharmaceutical-spam-in-google/',
  },
  {
    title: 'Why Malware Keeps Coming Back',
    desc: 'Understand why repeat infections happen and how proper cleanup stops reinfection.',
    href: '/blog/why-wordpress-malware-keeps-coming-back-and-how-to-stop-it-forever/',
  },
  {
    title: 'Hidden Links Malware Guide',
    desc: 'Related SEO spam detection guide for hidden backlinks, cloaked links, and spam injections.',
    href: '/blog/hidden-links-malware-the-simple-guide-to-seo-spam-detection-and-removal/',
  },
];
---

<Layout title={seo.title} description={seo.description} image={seo.image}>
  <script
    type='application/ld+json'
    set:html={JSON.stringify(serviceSchema)}
    is:inline
  />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(faqSchema)}
    is:inline
  />
  <script
    type='application/ld+json'
    set:html={JSON.stringify(breadcrumbSchema)}
    is:inline
  />

  <ComponentWrapper class='relative py-12 md:py-20'>
    <div class='-z-10 absolute inset-0 overflow-hidden pointer-events-none'>
      <div
        class='-top-24 right-0 absolute bg-emerald-500/10 blur-3xl rounded-full w-[620px] h-[620px]'>
      </div>
      <div
        class='top-1/3 left-0 absolute bg-sky-500/5 blur-3xl rounded-full w-[460px] h-[460px]'>
      </div>
    </div>

    {/* --- HERO --- */}
    <section class='mx-auto mb-16 max-w-5xl text-center'>
      <div class='flex justify-center mb-6'>
        <div
          class='inline-flex items-center gap-2 bg-slate-800/50 px-4 py-1.5 border border-slate-700 rounded-full font-medium text-slate-200 text-sm'>
          <Star class='fill-yellow-400 w-4 h-4 text-yellow-400' />
          <span
            >4,500+ hacked sites recovered · Manual Japanese SEO spam cleanup</span
          >
        </div>
      </div>

      <h1
        class='mx-auto mb-6 max-w-4xl font-bold text-white text-3xl md:text-4xl leading-tight tracking-tight'>
        Japanese Keyword Hack Removal
        <span
          class='block bg-clip-text bg-linear-to-r from-emerald-400 to-sky-400 text-transparent'>
          & Japanese SEO Spam Cleanup
        </span>
      </h1>

      <p
        class='mx-auto mb-4 max-w-3xl text-slate-300 text-lg md:text-xl leading-relaxed'>
        If Google is showing Japanese text, fake product pages, spam URLs, or
        weird search snippets you never created, your WordPress site may have
        the <strong class='text-white'>Japanese keyword hack</strong>. I
        manually remove the malware, stop the spam generator, clean persistence,
        and help you recover search visibility.
      </p>

      <p class='mx-auto mb-10 max-w-2xl text-slate-500 text-sm'>
        I'm <strong class='text-slate-300'>MD Pabel</strong> — a WordPress security
        specialist focused on hacked-site cleanup, SEO spam recovery, blacklist removal,
        and post-hack hardening.
      </p>

      <div class='flex sm:flex-row flex-col justify-center items-center gap-4'>
        <a href='#pricing' class={`${btnBase} ${btnDefault}`}>
          Fix My Japanese SEO Spam <ArrowRight class='ml-2 w-4 h-4' />
        </a>
        <a href='#proof' class={`${btnBase} ${btnOutline}`}>
          See Real Case Studies
        </a>
      </div>

      <p
        class='flex justify-center items-center gap-2 mt-6 text-slate-500 text-sm'>
        <Clock class='w-3.5 h-3.5' />
        <span>Typical cleanup: 24–72 hours · Pay after verified clean</span>
      </p>
    </section>

    {/* --- TRUST STATS --- */}
    <section class='mb-20'>
      <div
        class='gap-4 grid grid-cols-2 md:grid-cols-4 bg-slate-900/50 p-6 md:p-8 border border-slate-800 rounded-2xl'>
        {
          TRUST_STATS.map((stat) => (
            <div class='flex flex-col items-center text-center'>
              <stat.icon class='mb-2 w-6 h-6 text-emerald-400' />
              <div class='font-bold text-white text-2xl md:text-3xl'>
                {stat.value}
              </div>
              <div class='text-slate-400 text-xs md:text-sm'>{stat.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- AI QUICK ANSWER --- */}
    <section class='mx-auto mb-24 max-w-4xl'>
      <div
        class='bg-amber-950/20 p-6 md:p-8 border border-amber-900/40 rounded-2xl'>
        <div
          class='inline-flex items-center gap-2 mb-4 font-semibold text-amber-300 text-sm uppercase tracking-wider'>
          <Zap class='w-4 h-4' /> Quick answer
        </div>
        <h2 class='mb-4 font-bold text-white text-2xl md:text-3xl'>
          What is the Japanese keyword hack?
        </h2>
        <p class='text-slate-300 leading-relaxed'>
          The Japanese keyword hack is a WordPress SEO spam infection where
          attackers create Japanese-language spam pages, fake product URLs,
          cloaked search snippets, or spam sitemaps on your domain. The right
          fix is to diagnose the malware, manually remove files and database
          injections, stop reinfection, clean or deindex spam URLs, and harden
          the site after recovery.
        </p>
      </div>
    </section>

    {/* --- SYMPTOMS --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-12 max-w-3xl text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Signs Your Site Has Japanese SEO Spam
        </h2>
        <p class='text-slate-400'>
          These symptoms usually appear before site owners realize the spam is
          being generated by malware, not by normal WordPress content.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3 mx-auto max-w-6xl'>
        {
          SYMPTOMS.map((item) => (
            <div class='flex gap-4 bg-slate-900/50 p-6 border border-slate-800 hover:border-slate-700 rounded-xl transition-colors'>
              <item.icon class='flex-shrink-0 w-6 h-6 text-amber-400' />
              <div>
                <h3 class='mb-2 font-bold text-white'>{item.title}</h3>
                <p class='text-slate-400 text-sm leading-relaxed'>
                  {item.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- CLOAKING DETECTION --- */}
    <section
      class='bg-slate-900/30 -mx-4 md:-mx-8 mb-24 px-6 md:px-12 py-16 border border-slate-800 rounded-3xl'>
      <div
        class='items-start gap-8 grid lg:grid-cols-[1fr_.9fr] mx-auto max-w-6xl'>
        <div>
          <div
            class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400 text-sm uppercase tracking-wider'>
            <Code class='w-5 h-5' /> Cloaking check
          </div>
          <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
            Your site can look clean while Google still sees spam
          </h2>
          <p class='mb-5 text-slate-400 leading-relaxed'>
            Japanese keyword hack infections often use cloaking. That means the
            malware may show your real website to you but show spam to
            Googlebot, mobile users, or visitors coming from search results.
          </p>
          <p class='text-slate-400 leading-relaxed'>
            This is why I do not rely on one browser check. I compare bot-facing
            output, suspicious URLs, sitemaps, database content, and server
            files before calling the cleanup finished.
          </p>
        </div>

        <div
          class='bg-slate-950 p-5 border border-slate-800 rounded-2xl overflow-hidden'>
          <div class='mb-3 text-slate-500 text-xs uppercase tracking-wider'>
            Example manual check
          </div>
          <pre
            class='overflow-x-auto text-slate-300 text-sm leading-relaxed'><code>{`# Compare normal visitor output
curl -L https://example.com/suspicious-url/ | head -80

# Compare Googlebot-style output
curl -A "Googlebot" -L https://example.com/suspicious-url/ | head -80

# Compare mobile output
curl -A "Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X)" \
  -L https://example.com/suspicious-url/ | head -80`}</code></pre>
        </div>
      </div>
    </section>

    {/* --- WHAT'S INCLUDED --- */}
    <section class='mb-24'>
      <div class='mx-auto mb-12 max-w-4xl text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          What’s Included in Japanese Keyword Hack Removal
        </h2>
        <p class='text-slate-400'>
          This is a full recovery workflow: malware cleanup, search cleanup, and
          reinfection prevention.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3 mx-auto max-w-6xl'>
        {
          INCLUDED.map((item) => (
            <div class='bg-slate-900 p-8 border border-slate-800 rounded-2xl'>
              <item.icon class='mb-4 w-7 h-7 text-emerald-400' />
              <h3 class='mb-3 font-bold text-white text-xl'>{item.title}</h3>
              <p class='text-slate-400 text-sm leading-relaxed'>{item.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- PROCESS --- */}
    <section id='process' class='mb-24'>
      <div class='mx-auto mb-12 max-w-4xl text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          The Cleanup Process
        </h2>
        <p class='text-slate-400'>
          The priority is simple: diagnose, manually remove, deindex the spam,
          and harden the site so the same hack does not come back.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3 mx-auto max-w-6xl'>
        {
          PROCESS_STEPS.map((step) => (
            <div class='flex flex-col bg-slate-900/30 p-6 border border-slate-800 rounded-xl'>
              <div class='flex justify-center items-center bg-slate-800 mb-4 border border-slate-700 rounded-full w-12 h-12'>
                <step.icon class='w-6 h-6 text-emerald-400' />
              </div>
              <div class='mb-1 font-bold text-emerald-400 text-xs uppercase tracking-wider'>
                {step.step}
              </div>
              <h3 class='mb-2 font-bold text-white text-lg'>{step.title}</h3>
              <p class='text-slate-400 text-sm leading-relaxed'>{step.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    {/* --- WHY MANUAL --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='items-start gap-8 grid lg:grid-cols-[1.1fr_.9fr]'>
        <div
          class='bg-slate-900/60 p-8 md:p-10 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex items-center gap-2 mb-4 font-semibold text-emerald-400 text-sm uppercase tracking-wider'>
            <Award class='w-5 h-5' /> Why manual cleanup matters
          </div>
          <h2 class='mb-6 font-bold text-white text-3xl'>
            Japanese SEO spam is not just “delete a few pages”
          </h2>

          <div class='space-y-5'>
            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  The spam generator must be stopped
                </h3>
                <p class='text-slate-400'>
                  Deleting indexed URLs is useless if the malware is still
                  creating new ones.
                </p>
              </div>
            </div>
            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  Cloaking must be checked from multiple angles
                </h3>
                <p class='text-slate-400'>
                  A normal browser view does not prove the site is clean for
                  Googlebot or mobile visitors.
                </p>
              </div>

---
import Layout from '../layouts/Layout.astro';
import ComponentWrapper from '../components/component-wrapper.astro';
import {
  ShieldCheck,
  Search,
  Check,
  Zap,
  HeartHandshake,
  ShieldAlert,
  Info,
  Bug,
  Globe,
  Lock,
  MessageSquare,
  CheckCircle,
  AlertOctagon,
  FileSearch,
  ScanSearch,
  Link2,
} from '@lucide/astro';
import RelatedInternalLinks from '../components/RelatedInternalLinks.astro';

// --- SEO DATA ---
const seoTitle =
  'Japanese Keyword Hack Removal Service | Fix Japanese SEO Spam';
const seoDesc =
  'Japanese keyword hack removal service for hacked WordPress websites. I remove Japanese SEO spam, cloaked spam pages, fake product URLs, spam sitemaps, and hidden malware, then help restore your SEO.';

// --- CTA BUTTONS ---
const primaryButtonClass =
  'inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 disabled:pointer-events-none disabled:opacity-50 h-11 px-8 bg-emerald-600 hover:bg-emerald-700 text-white shadow-lg shadow-emerald-900/20 tracking-tight';

const secondaryButtonClass =
  'inline-flex items-center justify-center rounded-md border border-slate-700 bg-slate-900/60 hover:bg-slate-800 text-slate-200 transition-colors h-11 px-8 text-sm font-medium';

// --- FAQ CONTENT ---
const faqs = [
  {
    question: 'What is the Japanese keyword hack?',
    answer:
      'The Japanese keyword hack is a type of SEO spam infection where attackers inject thousands of spam pages, fake product URLs, or cloaked Japanese text into a hacked website to abuse its authority in Google.',
  },
  {
    question: 'Is Japanese SEO spam the same as the Japanese keyword hack?',
    answer:
      'In most cases, yes. Website owners often call it Japanese SEO spam, while Google documentation commonly refers to it as the Japanese keyword hack.',
  },
  {
    question: 'Why does my site look normal but Google shows Japanese pages?',
    answer:
      'That often means the infection is cloaked. The malware may show normal content to human visitors but spam content to search engines or specific user agents.',
  },
  {
    question: 'Can a plugin remove Japanese keyword hack completely?',
    answer:
      'Sometimes a plugin can detect pieces of the infection, but large Japanese spam cases often involve hidden persistence, spam sitemaps, infected database content, fake plugins, or root-level PHP files that need deeper manual cleanup.',
  },
  {
    question: 'Can you help remove Japanese spam URLs from Google?',
    answer:
      'Yes. After the malware is removed and the vulnerability is fixed, I also help with the search cleanup side so spam pages stop polluting your search presence.',
  },
  {
    question: 'Do you only handle WordPress?',
    answer:
      'WordPress is my main specialty, especially hacked WordPress websites with cloaking, spam injections, redirects, and fake plugins. I can also help with other PHP-based websites and shared hosting environments.',
  },
];

// --- STRUCTURED DATA ---
const structuredData = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Japanese Keyword Hack Removal Service',
    serviceType: 'Japanese SEO Spam Removal',
    description:
      'Manual removal of Japanese keyword hack and Japanese SEO spam from hacked WordPress websites, including cloaked spam pages, fake product URLs, malware cleanup, vulnerability repair, and search recovery support.',
    areaServed: 'Worldwide',
    provider: {
      '@type': 'Person',
      name: 'MD Pabel',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
]);
---

<Layout title={seoTitle} description={seoDesc}>
  <script type='application/ld+json' set:html={structuredData} />

  <ComponentWrapper class='relative py-16 md:py-24'>
    {/* Decorative Background */}
    <div
      class='top-0 left-0 -z-10 absolute w-full h-full overflow-hidden pointer-events-none'>
      <div
        class='-top-[10%] right-0 absolute bg-emerald-500/10 blur-3xl rounded-full w-[650px] h-[650px]'>
      </div>
      <div
        class='top-[18%] left-[8%] absolute bg-fuchsia-500/5 blur-3xl rounded-full w-[360px] h-[360px]'>
      </div>
      <div
        class='bottom-0 left-0 absolute bg-sky-500/5 blur-3xl rounded-full w-[500px] h-[500px]'>
      </div>
    </div>

    {/* --- HERO --- */}
    <section class='z-10 relative mx-auto mb-20 max-w-5xl text-center'>
      <div
        class='inline-flex items-center gap-2 bg-emerald-900/20 mb-8 px-4 py-1.5 border border-emerald-800/50 rounded-full'>
        <ShieldCheck class='w-4 h-4 text-emerald-400' />
        <span class='font-semibold text-emerald-200 text-sm'>
          Cloaked Spam Cleanup • Search Recovery Help
        </span>
      </div>

      <h1
        class='mx-auto mb-6 max-w-4xl font-bold text-white text-3xl md:text-4xl leading-[1.05] tracking-tight'>
        Japanese Keyword Hack Removal Service
        <span
          class='block bg-clip-text bg-gradient-to-r from-emerald-400 to-sky-400 mt-2 text-transparent'>
          Fix Japanese SEO Spam on WordPress Properly
        </span>
      </h1>

      <p class='mx-auto mb-10 max-w-3xl text-slate-400 text-lg leading-relaxed'>
        If Google is showing Japanese text, fake product pages, casino spam, or
        weird URLs that you never created, your site may be infected with the
        <strong class='text-slate-200'> Japanese keyword hack</strong>. I remove
        the cloaked malware, clean the spam generator, fix hidden persistence,
        and help you recover your search presence without leaving half the
        infection behind.
      </p>

      <div
        class='flex sm:flex-row flex-col justify-center items-center gap-4 mb-12'>
        <a href='/hire-me/' class={primaryButtonClass}>
          Request Japanese Spam Cleanup
        </a>
        <a href='#proof' class={secondaryButtonClass}>
          See Real Case Studies
        </a>
      </div>

      <div class='gap-4 grid sm:grid-cols-3 mx-auto max-w-4xl text-left'>
        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <CheckCircle class='w-5 h-5 text-emerald-400' />
            4,500+ hacked sites fixed
          </div>
          <p class='text-slate-400 text-sm'>
            Real malware cleanup experience across WordPress, hosting, and
            search-spam recovery.
          </p>
        </div>

        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <Bug class='w-5 h-5 text-emerald-400' />
            Cloaking & persistence cleanup
          </div>
          <p class='text-slate-400 text-sm'>
            I look beyond the visible spam pages and investigate fake plugins,
            hidden PHP, and reinfection points.
          </p>
        </div>

        <div class='bg-slate-900/60 p-5 border border-slate-800 rounded-2xl'>
          <div class='flex items-center gap-2 mb-2 font-semibold text-white'>
            <Search class='w-5 h-5 text-emerald-400' />
            Search recovery support
          </div>
          <p class='text-slate-400 text-sm'>
            Cleanup is only part of the job. I also help with the search-side
            recovery after the hack.
          </p>
        </div>
      </div>
    </section>

    {/* --- QUICK ANSWER --- */}
    <section class='mx-auto mb-24 max-w-4xl'>
      <div
        class='bg-slate-900/50 p-8 md:p-10 border border-slate-800 rounded-3xl'>
        <h2 class='mb-5 font-bold text-white text-3xl'>
          What is Japanese SEO spam?
        </h2>
        <p class='mb-4 text-slate-400 leading-relaxed'>
          Japanese SEO spam is a hacked-site infection where attackers inject
          thousands of spam pages, fake product URLs, hidden Japanese text, or
          cloaked search spam into your website so they can abuse your domain
          authority in Google. Many site owners first notice it when they search
          their brand and suddenly see Japanese characters, fake store listings,
          or weird pages they never published.
        </p>
        <p class='text-slate-400 leading-relaxed'>
          Some users search for <strong class='text-slate-200'
            >Japanese keyword hack</strong
          >. Others search for <strong class='text-slate-200'
            >Japanese SEO spam removal</strong
          >. This page is built to rank for both while staying useful for buyers
          who need real cleanup help now.
        </p>
      </div>
    </section>

    {/* --- SYMPTOMS --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Signs your site is infected with the Japanese keyword hack
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          These are the symptoms most people notice before they start searching
          for help.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-4'>
        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='flex items-center gap-3 mb-4 font-bold text-white text-xl'>
            <Search class='w-6 h-6 text-emerald-400' />
            Japanese titles in Google
          </div>
          <p class='text-slate-400 leading-relaxed'>
            Your site looks normal to you, but Google shows Japanese text, fake
            products, or weird snippets.
          </p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='flex items-center gap-3 mb-4 font-bold text-white text-xl'>
            <Link2 class='w-6 h-6 text-emerald-400' />
            Strange URLs you never created
          </div>
          <p class='text-slate-400 leading-relaxed'>
            Google indexes random folders, fake product pages, or spam URLs
            hidden deep inside the site.
          </p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='flex items-center gap-3 mb-4 font-bold text-white text-xl'>
            <ShieldAlert class='w-6 h-6 text-emerald-400' />
            Cloaking or redirects
          </div>
          <p class='text-slate-400 leading-relaxed'>
            Search engines or mobile visitors see spam, while you keep seeing
            the clean site.
          </p>
        </div>

        <div class='bg-slate-900/60 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='flex items-center gap-3 mb-4 font-bold text-white text-xl'>
            <ScanSearch class='w-6 h-6 text-emerald-400' />
            Search Console problems
          </div>
          <p class='text-slate-400 leading-relaxed'>
            Spam pages, strange sitemap behavior, or hacked content warnings
            start appearing in Search Console.
          </p>
        </div>
      </div>
    </section>

    {/* --- PROOF / CLUSTER --- */}
    <section id='proof' class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          Proof and related case studies
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          These pages strengthen trust and help both users and search engines
          understand that this is a real specialty area.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-3'>
        <a
          href='/blog/how-i-removed-50000-spam-urls-and-saved-a-hacked-website-the-ultimate-guide/'
          class='group block bg-slate-900/60 hover:bg-slate-900 p-8 border border-slate-800 rounded-3xl transition-colors'>
          <FileSearch class='mb-4 w-6 h-6 text-emerald-400' />
          <h3
            class='mb-3 font-bold text-white group-hover:text-emerald-300 text-xl'>
            50,000+ spam URLs cleanup case study
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            Real cleanup story showing large-scale spam URL recovery and search
            cleanup strategy.
          </p>
        </a>

        <a
          href='/blog/recovering-from-seo-spam-how-we-cleared-242000-japanese-spam-pages-from-a-hacked-wordpress-site-in-2025/'
          class='group block bg-slate-900/60 hover:bg-slate-900 p-8 border border-slate-800 rounded-3xl transition-colors'>
          <Globe class='mb-4 w-6 h-6 text-emerald-400' />
          <h3
            class='mb-3 font-bold text-white group-hover:text-emerald-300 text-xl'>
            242,000 Japanese spam pages recovery
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            Large WordPress SEO-spam case study showing search damage and
            technical recovery work.
          </p>
        </a>

        <a
          href='/blog/how-to-fix-japanese-keyword-hack-in-wordpress-the-hard-way/'
          class='group block bg-slate-900/60 hover:bg-slate-900 p-8 border border-slate-800 rounded-3xl transition-colors'>
          <Zap class='mb-4 w-6 h-6 text-emerald-400' />
          <h3
            class='mb-3 font-bold text-white group-hover:text-emerald-300 text-xl'>
            Deep technical guide
          </h3>
          <p class='text-slate-400 text-sm leading-relaxed'>
            Detailed walkthrough for advanced WordPress owners who want to
            understand the infection more deeply.
          </p>
        </a>
      </div>
    </section>

    {/* --- LONG FORM ARTICLE --- */}
    <article
      class='prose-invert mx-auto mb-24 max-w-4xl text-slate-400 leading-relaxed prose'>
      <h2 class='mb-6 font-bold text-white text-3xl'>
        Why Japanese keyword hack infections are so damaging
      </h2>
      <p>
        This type of malware is dangerous because it attacks your SEO, your
        brand trust, and often your server resources at the same time. Instead
        of simply defacing the homepage, the attacker often generates large
        volumes of low-quality spam pages designed to rank in Google. In many
        cases, the infection is cloaked, so the site owner sees a normal website
        while search engines see a spam farm.
      </p>
      <p>
        That is why many site owners do not realize how bad the infection is
        until their branded search results look broken, fake pages get indexed,
        or a client points out weird Japanese snippets in Google.
      </p>

      <div
        class='bg-slate-900/50 my-12 p-8 border border-slate-800 rounded-2xl'>
        <h3
          class='flex items-center gap-2 mb-4 font-bold text-emerald-400 text-xl'>
          <HeartHandshake class='w-6 h-6' />
          Cleanup first, search recovery second
        </h3>
        <p>
          The right order matters. First, remove the malware and fix the
          vulnerability. Then clean up the search-side damage. If the root cause
          is still active, the spam pages can come back and keep polluting
          Google.
        </p>
      </div>

      <h2 class='mb-6 font-bold text-white text-3xl'>
        Japanese keyword hack removal for WordPress
      </h2>
      <p>
        WordPress websites are especially common targets because attackers can
        hide the infection in fake plugins, compromised themes, root-level PHP
        files, database injections, malicious uploads, cron-based persistence,
        or modified core files.
      </p>
      <p>
        If your infection is broader than spam pages alone, you may also need a
        full
        <a
          href='/wordpress-malware-removal/'
          class='text-emerald-400 hover:text-emerald-300 underline underline-offset-4'
          >WordPress malware removal service</a
        >. And if the hack has triggered warnings in search or browsers, you may
        also need
        <a
          href='/google-blacklist-removal-service/'
          class='text-emerald-400 hover:text-emerald-300 underline underline-offset-4'
          >Google blacklist removal help</a
        >.
      </p>
    </article>

    {/* --- WHAT'S INCLUDED --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          What’s included in my Japanese SEO spam removal service
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          This is a real cleanup service, not just a scan or generic report.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3'>
        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Bug class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>Malware cleanup</h3>
          <p class='text-slate-400'>
            Removal of the spam generator, malicious PHP, fake plugins, hidden
            scripts, and common WordPress persistence points.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Search class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Spam page investigation
          </h3>
          <p class='text-slate-400'>
            Review of strange indexed URLs, fake product pages, spam folders,
            cloaked pages, and search-result pollution.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <ShieldAlert class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>Cloaking detection</h3>
          <p class='text-slate-400'>
            I check whether the infection is serving different content to bots,
            mobile visitors, or search engines.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Lock class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Hardening after cleanup
          </h3>
          <p class='text-slate-400'>
            Cleanup is followed by practical hardening so the same infection
            does not come back next week.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <Globe class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Search recovery help
          </h3>
          <p class='text-slate-400'>
            I help with the cleanup steps needed so Google stops seeing your
            site as a spam source.
          </p>
        </div>

        <div class='bg-slate-900 p-8 border border-slate-800 rounded-3xl'>
          <FileSearch class='mb-4 w-6 h-6 text-emerald-400' />
          <h3 class='mb-3 font-bold text-white text-xl'>
            Manual investigation
          </h3>
          <p class='text-slate-400'>
            I do not stop at the first visible file. I look for the hidden parts
            that cause reinfection.
          </p>
        </div>
      </div>
    </section>

    {/* --- PROCESS --- */}
    <section id='process' class='mx-auto mb-24 max-w-6xl'>
      <div class='mb-12 text-center'>
        <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl'>
          My Japanese keyword hack cleanup process
        </h2>
        <p class='mx-auto max-w-3xl text-slate-400'>
          The page is structured around the real workflow clients need.
        </p>
      </div>

      <div class='gap-6 grid md:grid-cols-2 lg:grid-cols-3'>
        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            01
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Confirm the infection
          </h3>
          <p class='text-slate-400'>
            I verify whether the problem is Japanese SEO spam, cloaking, fake
            product pages, redirects, or a broader hacked-site issue.
          </p>
        </div>

        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            02
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Audit files and persistence
          </h3>
          <p class='text-slate-400'>
            I inspect plugins, themes, uploads, root-level files, database
            content, cron jobs, and suspicious users.
          </p>
        </div>

        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            03
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Remove the spam engine
          </h3>
          <p class='text-slate-400'>
            I clean the malware, remove the spam generator, and stop the site
            from producing more hacked URLs.
          </p>
        </div>

        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            04
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Fix the vulnerability
          </h3>
          <p class='text-slate-400'>
            After cleanup, I address the hole that let the attackers in so the
            infection does not come straight back.
          </p>
        </div>

        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            05
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Handle the search-side cleanup
          </h3>
          <p class='text-slate-400'>
            Once the site is truly clean, I help with the next steps needed so
            the spam pages stop damaging search visibility.
          </p>
        </div>

        <div class='bg-slate-900/70 p-8 border border-slate-800 rounded-3xl'>
          <div
            class='inline-flex justify-center items-center bg-emerald-900/30 mb-5 rounded-full w-10 h-10 font-bold text-emerald-300 text-sm'>
            06
          </div>
          <h3 class='mb-3 font-bold text-white text-xl'>
            Stabilize after recovery
          </h3>
          <p class='text-slate-400'>
            I treat Japanese SEO spam as a full recovery problem, not just a
            one-file cleanup.
          </p>
        </div>
      </div>
    </section>

    {/* --- WHY CHOOSE ME --- */}
    <section class='mx-auto mb-24 max-w-6xl'>
      <div class='items-start gap-8 grid lg:grid-cols-[1.1fr_.9fr]'>
        <div class='bg-slate-900/60 p-10 border border-slate-800 rounded-3xl'>
          <h2 class='mb-6 font-bold text-white text-3xl'>
            Why site owners hire me for Japanese SEO spam removal
          </h2>

          <div class='space-y-5'>
            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I understand this specific hack
                </h3>
                <p class='text-slate-400'>
                  This is not generic malware cleanup. Japanese SEO spam behaves
                  differently because it often mixes cloaking, spam generation,
                  and search-result pollution.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I already have topical proof on this site
                </h3>
                <p class='text-slate-400'>
                  My site already includes case studies and technical writeups
                  around large Japanese spam incidents, which strengthens trust
                  and helps buyers evaluate my process.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I focus on recovery, not just detection
                </h3>
                <p class='text-slate-400'>
                  The goal is not just to find spam. The goal is to stop the
                  generator, clean the site, and restore search trust.
                </p>
              </div>
            </div>

            <div class='flex gap-4'>
              <Check class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
              <div>
                <h3 class='mb-1 font-semibold text-white'>
                  I work well with related service clusters
                </h3>
                <p class='text-slate-400'>
                  If the hack also caused broader malware damage or blacklist
                  issues, I can help with those related recovery paths too.
                </p>
              </div>
            </div>
          </div>

---
const phone = '8801323390163';
const message = encodeURIComponent(
  'Hi, my WordPress site may be hacked. Website URL: Issue:',
);
const whatsappUrl = `https://wa.me/${phone}?text=${message}`;
---

<a
  href={whatsappUrl}
  target='_blank'
  rel='noopener noreferrer'
  aria-label='Chat on WhatsApp'
  data-clarity-event='floating_whatsapp_click'
  class='group hidden top-1/2 right-4 z-30 fixed md:flex flex-col items-center gap-2 bg-slate-900/95 shadow-xl backdrop-blur-sm p-3 border border-green-500 hover:border-green-500 rounded-2xl text-white hover:scale-105 transition-all -translate-y-1/2'>
  <svg
    xmlns='http://www.w3.org/2000/svg'
    viewBox='0 0 32 32'
    class='fill-[#25D366] w-6 h-6 shrink-0'
    aria-hidden='true'>
    <path
      d='M19.11 17.35c-.27-.14-1.59-.78-1.84-.87-.25-.09-.43-.14-.61.14-.18.27-.7.87-.86 1.05-.16.18-.32.2-.59.07-.27-.14-1.13-.42-2.16-1.35-.8-.71-1.34-1.58-1.5-1.85-.16-.27-.02-.42.12-.56.12-.12.27-.32.41-.48.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.48-.07-.14-.61-1.47-.84-2.02-.22-.53-.45-.46-.61-.47h-.52c-.18 0-.48.07-.73.34-.25.27-.95.93-.95 2.27 0 1.34.98 2.64 1.11 2.82.14.18 1.92 2.93 4.66 4.11.65.28 1.16.45 1.56.58.66.21 1.25.18 1.72.11.52-.08 1.59-.65 1.82-1.28.23-.63.23-1.17.16-1.28-.07-.11-.25-.18-.52-.32Z'
    ></path>
    <path
      d='M16.03 3.2c-7.04 0-12.75 5.71-12.75 12.75 0 2.24.58 4.43 1.69 6.36L3.2 28.8l6.66-1.74a12.7 12.7 0 0 0 6.17 1.58h.01c7.03 0 12.76-5.72 12.76-12.75 0-3.41-1.33-6.61-3.74-9.02A12.66 12.66 0 0 0 16.03 3.2Zm0 23.2h-.01a10.5 10.5 0 0 1-5.35-1.46l-.38-.23-3.95 1.03 1.05-3.85-.25-.4a10.53 10.53 0 0 1-1.61-5.6c0-5.82 4.73-10.55 10.56-10.55 2.82 0 5.47 1.1 7.46 3.09a10.48 10.48 0 0 1 3.09 7.46c0 5.82-4.74 10.55-10.56 10.55Z'
    ></path>
  </svg>

  <span
    class='font-semibold text-[11px] uppercase tracking-[0.18em] rotate-180 [writing-mode:vertical-rl]'>
    WhatsApp
  </span>
</a>

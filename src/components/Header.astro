---
import {
  Rocket,
  Menu,
  X,
  ChevronDown,
  BookOpen,
  Bug,
  Briefcase,
  Compass,
  FileTerminal,
  ShieldAlert,
  Languages,
  FileWarning,
  Code2,
  Cpu,
  Lock,
  ScanLine,
  Search,
  MessageCircle,
} from '@lucide/astro';
import ComponentWrapper from './component-wrapper.astro';
import OfferTopbar from './offer-topbar.astro';

interface NavLink {
  type: 'link';
  name: string;
  href: string;
  prefetch?: 'load' | 'hover' | 'tap';
}

interface NavDropdownChild {
  name: string;
  href: string;
  desc: string;
  icon: any;
  badge?: string;
  clarityEvent?: string;
}

interface NavDropdown {
  type: 'dropdown';
  name: string;
  children: NavDropdownChild[];
}

type NavItem = NavLink | NavDropdown;

const navItems: NavItem[] = [
  {
    name: 'About',
    href: '/about/',
    type: 'link',
    prefetch: 'load',
  },
  {
    name: 'Services',
    type: 'dropdown',
    children: [
      {
        name: 'Malware Removal',
        href: '/wordpress-malware-removal/',
        desc: 'Clean hacked sites & secure them',
        icon: ShieldAlert,
        clarityEvent: 'nav_malware_removal_click',
      },
      {
        name: 'Japanese SEO Spam',
        href: '/remove-japanese-seo-spam/',
        desc: 'Fix cloaked spam & de-index pages',
        icon: Languages,
        clarityEvent: 'nav_japanese_seo_spam_click',
      },
      {
        name: 'Blacklist Removal',
        href: '/blacklist-removal/',
        desc: 'Remove Google & McAfee warnings',
        icon: FileWarning,
        clarityEvent: 'nav_blacklist_removal_click',
      },
      {
        name: 'Fullstack Dev',
        href: '#',
        desc: 'Custom React/Node web apps',
        icon: Code2,
        badge: 'Soon',
      },
      {
        name: 'Headless WP',
        href: '#',
        desc: 'High-performance Astro/Next.js sites',
        icon: Cpu,
        badge: 'Soon',
      },
      {
        name: 'Security Care',
        href: '#',
        desc: '24/7 Monitoring & Protection',
        icon: Lock,
        badge: 'Soon',
      },
    ],
  },
  {
    name: 'Resources',
    type: 'dropdown',
    children: [
      {
        name: 'Blog',
        href: '/blog/',
        desc: 'Latest security news & tips',
        icon: BookOpen,
        clarityEvent: 'nav_blog_click',
      },

      {
        name: 'Case Studies',
        href: '/case-studies/',
        desc: 'Real cleanup stories & results',
        icon: Briefcase,
        clarityEvent: 'nav_case_studies_click',
      },
      {
        name: 'Security Guides',
        href: '/guides/',
        desc: 'Step-by-step tutorials',
        icon: Compass,
        clarityEvent: 'nav_security_guides_click',
      },
      {
        name: 'Malware Logs',
        href: '/malware-log/',
        desc: 'Raw forensic analysis logs',
        icon: FileTerminal,
        clarityEvent: 'nav_malware_logs_click',
      },

      {
        name: 'Contact Me',
        href: 'https://wa.me/8801323390163?text=Hi%2C%20my%20WordPress%20site%20may%20be%20hacked.%20Website%20URL%3A%20Issue%3A',
        desc: 'Urgent help for hacked site',
        icon: MessageCircle,
        clarityEvent: 'nav_contact_whatsapp_click',
      },
    ],
  },
];
---

<>
  <header
    id='main-header'
    class='top-0 z-40 sticky bg-slate-900/90 backdrop-blur-md border-slate-800 border-b w-full overflow-x-clip transition-colors duration-300'>
    <OfferTopbar />
    <div class='py-4'>
      <ComponentWrapper>
        <nav class='relative flex justify-between items-center mx-auto'>
          <div class='flex items-center gap-8'>
            <a
              href='/'
              aria-label='Home'
              class='flex items-center gap-3 font-bold text-white text-xl tracking-tight'>
              <div
                class='flex justify-center items-center bg-white shadow-sm border border-slate-300 rounded-lg w-9 h-9'>
                <Rocket class='w-5 h-5 text-slate-950' />
              </div>
              <span>MD Pabel</span>
            </a>

            <div class='hidden lg:flex items-center gap-1'>
              {
                navItems.map((item) =>
                  item.type === 'link' ? (
                    <a
                      href={item.href}
                      class='hover:bg-slate-800 px-3 py-2 rounded-full font-medium text-slate-300 hover:text-white text-base transition-colors'
                      data-astro-prefetch={item.prefetch}>
                      {item.name}
                    </a>
                  ) : (
                    <div class='group relative px-4 py-2'>
                      <button
                        type='button'
                        class='flex items-center gap-1 font-medium text-slate-300 group-hover:text-white text-base transition-colors cursor-pointer'>
                        {item.name}
                        <ChevronDown class='w-4 h-4 group-hover:rotate-180 transition-transform' />
                      </button>

                      <div class='invisible group-hover:visible top-full left-1/2 z-50 absolute opacity-0 group-hover:opacity-100 pt-4 w-[600px] origin-top transition-all -translate-x-1/2 translate-y-2 group-hover:translate-y-0 duration-200 ease-out transform'>
                        <div class='relative gap-2 grid grid-cols-2 bg-slate-900 shadow-xl p-4 border border-slate-700 rounded-2xl'>
                          <div class='-top-2 left-1/2 absolute bg-slate-900 border-slate-700 border-t border-l w-4 h-4 rotate-45 -translate-x-1/2 transform' />
                          {item.children.map((subItem) => (
                            <a
                              href={subItem.href}
                              class={`group/item relative flex items-start gap-4 p-3 rounded-xl transition-colors z-10 ${
                                subItem.badge
                                  ? 'opacity-70 cursor-default'
                                  : 'hover:bg-slate-800/50'
                              }`}
                              data-clarity-event={
                                subItem.badge ? undefined : subItem.clarityEvent
                              }
                              onclick={
                                subItem.badge ? 'return false;' : undefined
                              }>
                              <div class='bg-slate-800 group-hover/item:bg-sky-600 p-2 rounded-lg text-sky-400 group-hover/item:text-white transition-colors'>
                                <subItem.icon class='w-5 h-5' />
                              </div>
                              <div>
                                <div class='flex items-center gap-2 font-semibold text-white group-hover/item:text-sky-400 text-base transition-colors'>
                                  {subItem.name}
                                  {subItem.badge && (
                                    <span class='bg-amber-900/30 px-1.5 py-0.5 rounded font-bold text-[10px] text-amber-400 uppercase tracking-wide'>
                                      {subItem.badge}
                                    </span>
                                  )}
                                </div>
                                <p class='mt-0.5 text-slate-400 text-xs'>
                                  {subItem.desc}
                                </p>
                              </div>
                            </a>
                          ))}
                        </div>
                      </div>
                    </div>
                  ),
                )
              }
            </div>
          </div>

          <ul class='hidden lg:flex justify-end items-center gap-4'>
            <li>
              <form class='relative flex items-center site-search-form'>
                <Search class='left-3 absolute w-4 h-4 text-slate-400' />
                <input
                  type='search'
                  name='q'
                  placeholder='Search...'
                  class='bg-slate-800/50 py-2 pr-4 pl-9 border border-slate-700 focus:border-sky-500 rounded-full focus:outline-none focus:ring-1 focus:ring-sky-500 w-48 text-slate-200 text-sm transition-all'
                  required
                />
              </form>
            </li>

            <li>
              <a
                href='/free-wordpress-scan/'
                class='flex items-center gap-2 font-medium text-slate-400 hover:text-white text-base transition-colors'
                data-clarity-event='header_free_scan_click'>
                <ScanLine class='w-4 h-4' />
                Free Scan
              </a>
            </li>

            <li>
              <a
                href='/hire-me/'
                class='flex items-center gap-2 bg-white hover:bg-slate-200 shadow-md px-5 py-2.5 rounded-full font-semibold text-slate-900 text-sm transition-all hover:-translate-y-0.5 transform'
                data-astro-prefetch='load'
                data-clarity-event='header_hire_me_click'>
                Hire Me
              </a>
            </li>
          </ul>

          <div class='lg:hidden flex items-center gap-4'>
            <button
              type='button'
              id='menu-open-btn'
              aria-label='Open Menu'
              aria-controls='mobile-menu'
              aria-expanded='false'
              class='hover:bg-slate-800 p-2 rounded-full text-white transition-colors cursor-pointer'>
              <Menu class='w-6 h-6' />
            </button>
          </div>
        </nav>
      </ComponentWrapper>
    </div>
  </header>

  <div
    id='mobile-menu'
    class='lg:hidden z-[100] fixed inset-0 flex flex-col bg-slate-900 transition-transform translate-x-full duration-300 ease-in-out'
    aria-hidden='true'>
    <div
      class='flex justify-between items-center px-6 py-4 border-slate-800 border-b'>
      <div class='flex items-center gap-3'>
        <div
          class='flex justify-center items-center bg-white rounded-lg w-8 h-8'>
          <Rocket class='w-4 h-4 text-slate-950' />
        </div>
        <span class='font-bold text-white text-lg'>Menu</span>
      </div>

      <button
        type='button'
        id='menu-close-btn'
        aria-label='Close Menu'
        class='bg-slate-800 p-2 rounded-full text-slate-400 hover:text-white transition-colors cursor-pointer'>
        <X class='w-6 h-6' />
      </button>
    </div>

    <div class='flex-1 bg-slate-900 px-6 py-6 overflow-y-auto'>
      <div class='mb-6 pb-6 border-slate-800/50 border-b'>
        <form class='relative flex items-center w-full site-search-form'>
          <Search class='left-3 absolute w-5 h-5 text-slate-400' />
          <input
            type='search'
            name='q'
            placeholder='Search site...'
            class='bg-slate-800 py-3 pr-4 pl-10 border border-slate-700 focus:border-sky-500 rounded-xl focus:outline-none w-full text-slate-200 text-base transition-all'
            required
          />
        </form>
      </div>

      <ul class='space-y-2'>
        {
          navItems.map((item) =>
            item.type === 'link' ? (
              <li>
                <a
                  href={item.href}
                  class='block py-3 border-slate-800/50 border-b font-medium text-slate-200 text-lg mobile-link'
                  data-astro-prefetch={item.prefetch}>
                  {item.name}
                </a>
              </li>
            ) : (
              <li class='border-slate-800/50 border-b'>
                <details class='group'>
                  <summary class='flex justify-between items-center py-3 font-medium text-slate-200 text-lg cursor-pointer list-none'>
                    {item.name}
                    <ChevronDown class='w-5 h-5 text-slate-500 group-open:rotate-180 transition-transform' />
                  </summary>

                  <div class='space-y-4 pb-4 pl-4'>
                    {item.children.map((subItem) => (
                      <a
                        href={subItem.href}
                        class={`flex items-center gap-3 py-2 ${
                          subItem.badge
                            ? 'opacity-60 cursor-default'
                            : 'mobile-link text-slate-400 hover:text-sky-400'
                        }`}
                        data-clarity-event={
                          subItem.badge
                            ? undefined
                            : `mobile_${subItem.clarityEvent}`
                        }
                        onclick={subItem.badge ? 'return false;' : undefined}>
                        <subItem.icon class='w-4 h-4' />
                        <span class='text-base'>{subItem.name}</span>
                        {subItem.badge && (
                          <span class='bg-amber-900/30 ml-auto px-1.5 py-0.5 rounded font-bold text-[10px] text-amber-400 uppercase tracking-wide'>
                            {subItem.badge}
                          </span>
                        )}
                      </a>
                    ))}
                  </div>
                </details>
              </li>
            ),
          )
        }
      </ul>
    </div>

    <div class='bg-slate-900 p-6 border-slate-800 border-t'>
      <a
        href='/hire-me/'
        class='flex justify-center items-center bg-sky-600 hover:bg-sky-700 shadow-sm mb-3 py-3.5 rounded-xl w-full font-semibold text-white transition-colors'
        data-astro-prefetch='load'
        data-clarity-event='mobile_header_hire_me_click'>
        Hire Me
      </a>

      <a
        href='/free-wordpress-scan/'
        class='flex justify-center items-center gap-2 bg-slate-800 py-3.5 border border-slate-600 rounded-xl w-full font-medium text-slate-300 transition-colors'
        data-clarity-event='mobile_header_free_scan_click'>
        <ScanLine class='w-4 h-4' />
        Free Scan
      </a>
    </div>
  </div>
</>

<script is:inline>
  function initMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const openBtn = document.getElementById('menu-open-btn');
    const closeBtn = document.getElementById('menu-close-btn');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const searchForms = document.querySelectorAll('.site-search-form');

    if (!menu || !openBtn || !closeBtn) return;
    if (openBtn.dataset.bound === 'true') return;

    openBtn.dataset.bound = 'true';
    closeBtn.dataset.bound = 'true';

    const toggleMenu = (isOpen) => {
      if (isOpen) {
        menu.classList.remove('translate-x-full');
        menu.classList.add('translate-x-0');
        menu.setAttribute('aria-hidden', 'false');
        openBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.remove('translate-x-0');
        menu.classList.add('translate-x-full');
        menu.setAttribute('aria-hidden', 'true');
        openBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    };

    openBtn.addEventListener('click', () => toggleMenu(true));
    closeBtn.addEventListener('click', () => toggleMenu(false));

    mobileLinks.forEach((link) => {
      if (link.dataset.bound === 'true') return;
      link.dataset.bound = 'true';
      link.addEventListener('click', () => toggleMenu(false));
    });

    searchForms.forEach((form) => {
      if (form.dataset.bound === 'true') return;
      form.dataset.bound = 'true';

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const currentForm = e.currentTarget;
        const input = currentForm?.querySelector('input[name="q"]');

        if (input && input.value.trim()) {
          const query = encodeURIComponent(
            input.value.trim() + ' site:mdpabel.com',
          );
          window.open(`https://www.google.com/search?q=${query}`, '_blank');
          input.value = '';
          toggleMenu(false);
        }
      });
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>

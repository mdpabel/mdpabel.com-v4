---
import { ArrowRight, CheckCircle2 } from '@lucide/astro';
import { services } from '../data/services';
---

<section id='services' class='relative py-16 md:py-20'>
  <div class='mx-auto mb-12 max-w-3xl text-center'>
    <span
      class='inline-flex items-center gap-2 bg-emerald-500/10 mb-4 px-4 py-1.5 border border-emerald-500/20 rounded-full font-mono font-medium text-emerald-400 text-xs uppercase tracking-widest'>
      <span class='bg-emerald-400 rounded-full w-1.5 h-1.5 animate-pulse'
      ></span>
      Security Services
    </span>

    <h2 class='mb-4 font-bold text-white text-3xl md:text-4xl text-center'>
      WordPress Malware Removal Services
    </h2>

    <p class='mx-auto max-w-2xl text-slate-400 md:text-lg'>
      Fixed-price cleanup options for hacked WordPress sites, fake CAPTCHA
      malware, SEO spam, blacklist warnings, and broken website emergencies.
    </p>
  </div>

  <div class='gap-5 grid md:grid-cols-2 lg:grid-cols-3 mx-auto max-w-6xl'>
    {
      services.map((service) => {
        const Icon = service.icon;

        return (
          <article
            class={`group relative flex min-h-[360px] flex-col overflow-hidden rounded-3xl border p-6 transition-all duration-300 ${
              service.featured
                ? 'border-emerald-500/30 bg-emerald-950/20 shadow-2xl shadow-emerald-950/20'
                : 'border-slate-700/60 bg-slate-800/50 hover:border-emerald-500/20 hover:bg-slate-800/70'
            }`}>
            {service.featured && (
              <div class='top-5 right-5 absolute bg-emerald-500/10 px-3 py-1 border border-emerald-500/20 rounded-full font-semibold text-emerald-300 text-xs'>
                Most requested
              </div>
            )}

            <div class='flex justify-center items-center bg-slate-900/50 mb-6 border border-slate-700 rounded-xl w-12 h-12'>
              <Icon class='w-5 h-5 text-emerald-400' />
            </div>

            <div class='mb-5'>
              <h3 class='mb-3 font-bold text-white text-xl leading-snug'>
                {service.title}
              </h3>

              <p class='text-slate-300 text-sm leading-relaxed'>
                {service.desc}
              </p>
            </div>

            <div class='bg-slate-950/35 mb-6 p-4 border border-slate-700/60 rounded-2xl'>
              <p class='text-slate-500 text-xs'>{service.priceNote}</p>
              <div class='flex items-end gap-2 mt-1'>
                <span class='font-bold text-white text-4xl tracking-tight'>
                  {service.price}
                </span>
                {service.priceNote === 'Per vendor' && (
                  <span class='pb-1 text-slate-400 text-sm'>/ vendor</span>
                )}
              </div>
            </div>

            <div class='space-y-3 mb-7'>
              {service.includes.map((item) => (
                <div class='flex items-start gap-3 text-slate-300 text-sm'>
                  <CheckCircle2 class='mt-0.5 w-4 h-4 text-emerald-400 shrink-0' />
                  <span>{item}</span>
                </div>
              ))}
            </div>

            <a
              href={service.href}
              class={`mt-auto inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold transition-colors ${
                service.featured
                  ? 'bg-emerald-500 text-slate-950 hover:bg-emerald-400'
                  : 'border border-slate-700 bg-slate-900/60 text-slate-200 hover:border-emerald-500/30 hover:text-white'
              }`}>
              {service.cta}
              <ArrowRight class='w-4 h-4 transition-transform group-hover:translate-x-1 duration-300' />
            </a>
          </article>
        );
      })
    }
  </div>

  <div
    class='bg-slate-800/40 mx-auto mt-10 p-5 md:p-6 border border-slate-700/60 rounded-3xl max-w-6xl'>
    <div
      class='flex md:flex-row flex-col md:justify-between md:items-center gap-5'>
      <div class='flex items-start gap-3'>
        <CheckCircle2 class='mt-1 w-5 h-5 text-emerald-400 shrink-0' />
        <div>
          <p class='font-semibold text-white'>
            Not sure which service you need?
          </p>
          <p class='mt-1 text-slate-300 text-sm leading-6'>
            If your WordPress site is hacked, redirecting, showing fake
            verification, blacklisted, or broken, start with a manual
            inspection.
          </p>
        </div>
      </div>

      <a
        href='/hire-me/'
        class='inline-flex justify-center items-center bg-white hover:bg-slate-200 px-6 py-3 rounded-full font-semibold text-slate-950 text-sm transition-colors shrink-0'>
        Get Help Now
      </a>
    </div>
  </div>
</section>

---
import { Rocket, Mail, Contact, User, Briefcase, Compass } from '@lucide/astro';
import ComponentWrapper from './component-wrapper.astro';
import ThemeToggle from './ThemeToggle.astro';

const currentYear = new Date().getFullYear();

const phone = '8801323390163';
const message = encodeURIComponent(
  'Hi, my WordPress site may be hacked. Website URL: Issue:',
);
const whatsappUrl = `https://wa.me/${phone}?text=${message}`;
---

<footer class='border-slate-800 border-t'>
  <ComponentWrapper class='py-8'>
    <div class='flex md:flex-row flex-col justify-between items-start gap-8'>
      {/* --- LOGO & DESCRIPTION --- */}
      <div class='flex flex-col gap-4'>
        <a
          href='/'
          aria-label='Home'
          class='flex items-center font-medium text-white text-lg'>
          <div
            class='flex justify-center items-center bg-slate-800 border border-slate-700 rounded w-10 h-10'>
            <Rocket class='w-5 h-5 text-white' />
          </div>
          <span class='ml-2 font-semibold'>MD Pabel</span>
        </a>

        <p class='max-w-xs text-slate-400 text-sm'>
          Building innovative solutions for the future. Subscribe to our
          newsletter for updates.
        </p>

        <div class='flex flex-wrap gap-3 pt-1'>
          <a
            href={whatsappUrl}
            target='_blank'
            rel='noopener noreferrer'
            aria-label='WhatsApp'
            title='WhatsApp'
            class='inline-flex justify-center items-center bg-slate-900 hover:bg-[#25D366]/10 border border-slate-700 hover:border-[#25D366]/50 rounded-lg w-10 h-10 text-[#25D366] transition-all'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 32 32'
              class='w-5 h-5'
              fill='currentColor'
              aria-hidden='true'>
              <path
                d='M19.11 17.18c-.27-.14-1.58-.78-1.83-.87-.24-.09-.42-.14-.6.14-.18.27-.69.87-.85 1.05-.16.18-.31.2-.58.07-.27-.14-1.13-.42-2.15-1.33-.79-.71-1.33-1.58-1.49-1.85-.16-.27-.02-.41.12-.55.12-.12.27-.31.4-.47.13-.16.18-.27.27-.45.09-.18.04-.34-.02-.47-.07-.14-.6-1.45-.82-1.98-.22-.53-.44-.46-.6-.46h-.51c-.18 0-.47.07-.71.34-.24.27-.93.91-.93 2.22 0 1.31.96 2.58 1.09 2.76.13.18 1.88 2.87 4.55 4.02.64.28 1.14.44 1.53.56.64.2 1.22.17 1.68.1.51-.08 1.58-.65 1.8-1.28.22-.63.22-1.17.16-1.28-.07-.11-.24-.18-.51-.31Z'
              ></path>
              <path
                d='M16.01 3.2c-7 0-12.68 5.67-12.68 12.67 0 2.23.58 4.41 1.68 6.33L3.2 28.8l6.79-1.78a12.7 12.7 0 0 0 6.02 1.53h.01c6.99 0 12.68-5.68 12.68-12.68 0-3.39-1.32-6.57-3.72-8.96A12.6 12.6 0 0 0 16.01 3.2Zm0 23.2h-.01a10.6 10.6 0 0 1-5.39-1.48l-.39-.23-4.03 1.06 1.08-3.93-.25-.4a10.5 10.5 0 0 1-1.61-5.55c0-5.85 4.76-10.61 10.61-10.61 2.83 0 5.49 1.1 7.49 3.11a10.52 10.52 0 0 1 3.11 7.49c0 5.85-4.76 10.61-10.61 10.61Z'
              ></path>
            </svg>
          </a>

          <a
            href='https://www.linkedin.com/in/mdpabe1/'
            target='_blank'
            rel='noopener noreferrer'
            aria-label='LinkedIn'
            title='LinkedIn'
            class='inline-flex justify-center items-center bg-slate-900 hover:bg-[#0A66C2]/10 border border-slate-700 hover:border-[#0A66C2]/50 rounded-lg w-10 h-10 text-[#0A66C2] transition-all'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              class='w-5 h-5'
              fill='currentColor'
              aria-hidden='true'>
              <path
                d='M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.05-1.86-3.05-1.87 0-2.15 1.46-2.15 2.96v5.66H9.32V9h3.42v1.56h.05c.48-.9 1.64-1.86 3.38-1.86 3.61 0 4.28 2.38 4.28 5.48v6.27ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z'
              ></path>
            </svg>
          </a>

          <a
            href='https://leetcode.com/u/mdpabel/'
            target='_blank'
            rel='noopener noreferrer'
            aria-label='LeetCode'
            title='LeetCode'
            class='inline-flex justify-center items-center bg-slate-900 hover:bg-[#FFA116]/10 border border-slate-700 hover:border-[#FFA116]/50 rounded-lg w-10 h-10 text-[#FFA116] transition-all'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 32 32'
              class='w-5 h-5'
              aria-hidden='true'>
              <path
                fill='currentColor'
                d='M18.64 6.28a1.5 1.5 0 0 1 2.12 0 1.5 1.5 0 0 1 0 2.12l-8.48 8.48 8.48 8.48a1.5 1.5 0 1 1-2.12 2.12l-9.54-9.54a1.5 1.5 0 0 1 0-2.12l9.54-9.54Z'
              ></path>
              <path
                fill='currentColor'
                d='M14.84 24.16h8.52a1.5 1.5 0 1 1 0 3h-8.52a1.5 1.5 0 1 1 0-3Z'
                opacity='.95'></path>
              <path
                fill='#B3B3B3'
                d='M21.41 4.62a1.5 1.5 0 0 1 2.12 0l4.18 4.18a1.5 1.5 0 0 1 0 2.12l-7.83 7.83a1.5 1.5 0 0 1-2.12-2.12l6.77-6.77-3.12-3.12a1.5 1.5 0 0 1 0-2.12Z'
              ></path>
            </svg>
          </a>

          <a
            href='https://github.com/mdpabel'
            target='_blank'
            rel='noopener noreferrer'
            aria-label='GitHub'
            title='GitHub'
            class='inline-flex justify-center items-center bg-slate-900 hover:bg-white/10 border border-slate-700 hover:border-white/40 rounded-lg w-10 h-10 text-white transition-all'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              class='w-5 h-5'
              fill='currentColor'
              aria-hidden='true'>
              <path
                d='M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.42-4.04-1.42-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.08 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.29-1.23 3.29-1.23.66 1.65.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.62-2.8 5.65-5.48 5.95.43.37.82 1.1.82 2.22v3.29c0 .32.21.69.83.57A12 12 0 0 0 12 .5Z'
              ></path>
            </svg>
          </a>
        </div>
      </div>

      {/* --- QUICK LINKS --- */}
      <div class='flex flex-col gap-4'>
        <h4 class='font-semibold text-white text-lg'>Quick Links</h4>
        <ul class='flex flex-col gap-2'>
          <li>
            <a
              href='/about/'
              class='flex items-center gap-2 text-slate-300 hover:text-white transition-colors'>
              <User class='w-4 h-4' />
              About
            </a>
          </li>
          <li>
            <a
              href='/wordpress-malware-removal/'
              class='flex items-center gap-2 text-slate-300 hover:text-white transition-colors'>
              <Briefcase class='w-4 h-4' />
              WordPress Malware Removal
            </a>
          </li>
          <li>
            <a
              href='/blog/'
              class='flex items-center gap-2 text-slate-300 hover:text-white transition-colors'>
              <Compass class='w-4 h-4' />
              Blog
            </a>
          </li>
        </ul>
      </div>

      {/* --- GET IN TOUCH --- */}
      <div class='flex flex-col gap-4'>
        <h4 class='font-semibold text-white text-lg'>Get in Touch</h4>
        <ul class='flex flex-col gap-2'>
          <li>
            <a
              href='https://mdpabe1.substack.com/'
              target='_blank'
              rel='noopener noreferrer'
              class='flex items-center gap-2 text-slate-300 hover:text-white transition-colors'>
              <Mail class='w-4 h-4' />
              Newsletter
            </a>
          </li>
          <li>
            <a
              href='/hire-me/'
              class='flex items-center gap-2 text-slate-300 hover:text-white transition-colors'>
              <Contact class='w-4 h-4' />
              Hire Me
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* --- COPYRIGHT --- */}
    <div class='mt-8 pt-4 border-slate-800 border-t text-center'>
      <div class='flex justify-center md:justify-between items-center'>
        <p class='text-slate-400 text-sm'>
          &copy; {currentYear} MD Pabel. All rights reserved.
        </p>

        <ThemeToggle />
      </div>
    </div>
  </ComponentWrapper>
</footer>

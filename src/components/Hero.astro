---
// 1. Import Zero-JS Icons
import { CheckCircle, ShieldCheck, Star } from '@lucide/astro';

import ComponentWrapper from './component-wrapper.astro';
---

<section class='relative py-20 overflow-hidden'>
  <!-- <HeroGlow /> -->

  <ComponentWrapper
    class='z-10 relative gap-x-10 gap-y-8 grid grid-cols-1 md:grid-cols-3'>
    {/* --- LEFT SECTION (Text Content) --- */}
    <div class='md:col-span-2'>
      {/* H1 Headline */}
      <h1 class='mb-2 font-bold text-white text-3xl md:text-4xl'>
        WordPress Malware Removal Service by a 4,500+ Cleanup Veteran
      </h1>

      {/* H2 Subheadline */}
      <h2 class='pt-2 pb-4 font-semibold text-slate-300 text-xl md:text-2xl'>
        Manual hacked-site cleanup, Japanese SEO spam removal, fake CAPTCHA
        malware, redirect fixes, and Google blacklist recovery — done by hand,
        guaranteed.
      </h2>

      {/* Description */}
      <p class='my-4 text-slate-300 text-lg leading-relaxed'>
        Hi, I'm MD Pabel. If your WordPress site is hacked, redirecting to spam,
        blacklisted by Google, or showing fake Cloudflare verification — I clean
        it manually, file by file. No automated scripts that miss backdoors. No
        data loss. 4,500+ real cleanups, 5★ on Fiverr (Level 2 Seller) and
        Upwork (Top Rated).
      </p>

      {/* --- STATS INDICATORS --- */}
      <div class='flex flex-wrap gap-4 mb-8'>
        <div
          class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
          <CheckCircle class='w-4 h-4 text-white' />
          4,500+ sites cleaned
        </div>
        <div
          class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
          <Star class='w-4 h-4 text-white' />
          5.0 / 5 average rating
        </div>
        <div
          class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
          <ShieldCheck class='w-4 h-4 text-white' />
          4–24h typical turnaround
        </div>

        <div
          class='flex items-center gap-2 bg-slate-800 px-3 py-2 border border-slate-700 rounded-lg font-medium text-slate-300 text-sm'>
          <ShieldCheck class='w-4 h-4 text-white' />
          30-day reinfection guarantee
        </div>
      </div>
    </div>

    {/* --- RIGHT SECTION (Animated Scanner) --- */}
    <div class='hidden md:block col-span-1 mt-12 md:mt-0 shrink-0'>
      <div
        class='relative flex justify-center items-center bg-slate-800/50 shadow-lg border border-slate-700 rounded-2xl overflow-hidden'>
        {/* THE SVG ANIMATION */}
        <svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 200' class=''>
          <defs>
            <linearGradient id='scanGradient' x1='0%' y1='0%' x2='0%' y2='100%'>
              <stop
                offset='0%'
                style='stop-color:rgb(16, 185, 129);stop-opacity:0'></stop>
              <stop
                offset='50%'
                style='stop-color:rgb(16, 185, 129);stop-opacity:0.5'></stop>
              <stop
                offset='100%'
                style='stop-color:rgb(16, 185, 129);stop-opacity:0.8'></stop>
            </linearGradient>
            <clipPath id='shieldMask'>
              <path
                d='M100 20C100 20 40 35 40 90C40 145 100 180 100 180C100 180 160 145 160 90C160 35 100 20 100 20Z'
              ></path>
            </clipPath>
          </defs>

          <path
            d='M100 20C100 20 40 35 40 90C40 145 100 180 100 180C100 180 160 145 160 90C160 35 100 20 100 20Z'
            fill='none'
            stroke='currentColor'
            stroke-width='4'
            class='text-slate-600'></path>

          <g clip-path='url(#shieldMask)'>
            <g class='animate-malware-clear'>
              <circle cx='100' cy='90' r='30' class='fill-red-900/30'></circle>
              <circle cx='90' cy='80' r='4' class='fill-red-500 animate-pulse'
              ></circle>
              <circle
                cx='110'
                cy='85'
                r='5'
                class='fill-red-500 animate-pulse delay-75'></circle>
              <circle
                cx='100'
                cy='105'
                r='3'
                class='fill-red-500 animate-pulse delay-150'></circle>
              <path
                d='M85 95L115 95'
                stroke='red'
                stroke-width='2'
                stroke-linecap='round'
                class='animate-glitch-line'></path>
            </g>

            <rect
              x='0'
              y='-50'
              width='200'
              height='50'
              fill='url(#scanGradient)'
              class='animate-scanner'></rect>
            <line
              x1='0'
              y1='0'
              x2='200'
              y2='0'
              stroke='rgb(16, 185, 129)'
              stroke-width='2'
              class='shadow-[0_0_10px_rgb(16,185,129)] animate-scanner-line'
            ></line>

            <g class='opacity-0 animate-secure-appear'>
              <circle cx='100' cy='90' r='35' class='fill-emerald-500/20'
              ></circle>
              <path
                d='M80 95 L95 110 L125 75'
                fill='none'
                stroke='rgb(16, 185, 129)'
                stroke-width='8'
                stroke-linecap='round'
                stroke-linejoin='round'
                class='animate-draw-check'></path>
            </g>
          </g>
        </svg>
      </div>
    </div>
  </ComponentWrapper>
</section>

<style>
  .animate-scanner,
  .animate-scanner-line {
    animation: scanDown 3s ease-in-out infinite;
  }

  .animate-malware-clear {
    animation: clearMalware 3s ease-in-out infinite;
  }

  .animate-secure-appear {
    animation: appearSecure 3s ease-in-out infinite;
  }

  .animate-glitch-line {
    animation: glitchX 0.2s steps(2) infinite;
  }

  @keyframes scanDown {
    0%,
    100% {
      transform: translateY(0);
    }
    45%,
    55% {
      transform: translateY(250px);
    }
  }

  @keyframes clearMalware {
    0%,
    25% {
      opacity: 1;
    }
    40%,
    100% {
      opacity: 0;
    }
  }

  @keyframes appearSecure {
    0%,
    35% {
      opacity: 0;
    }
    50%,
    90% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  @keyframes glitchX {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(3px);
    }
  }
</style>
